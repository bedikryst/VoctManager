# ==========================================================================
# infra/backup.env.example
# --------------------------------------------------------------------------
# Copy to infra/backup.env ON THE DROPLET and fill in the real values. This
# file is sourced by infra/backup.sh; infra/backup.env itself is gitignored
# because it holds secrets. Full walkthrough: docs/backups.md.
# ==========================================================================

# --- Off-site (Google Shared Drive via rclone) ----------------------------
# rclone remote + path where archives are pushed. The remote is created once
# with `rclone config` against a service account bound to a Shared Drive in the
# foundation's Workspace — step-by-step in docs/backups.md.
RCLONE_REMOTE=voct-drive:backups

# Absolute path to rclone.conf. rclone reads this variable natively; setting it
# explicitly means a cron run (minimal environment, possibly a different $HOME)
# always finds the config.
RCLONE_CONFIG=/root/.config/rclone/rclone.conf

# --- Failure alerting (healthchecks.io or a self-hosted equivalent) -------
# Ping URL for THIS backup job. On success the script pings the bare URL; on
# failure it pings <url>/fail; on start <url>/start. A missed success ping is
# what emails you. NO trailing slash.
HEALTHCHECK_URL=https://hc-ping.com/00000000-0000-0000-0000-000000000000

# --- Optional overrides (defaults shown) ----------------------------------
# BACKUP_DIR=/root/voct-backups
# KEEP_DAYS=14
