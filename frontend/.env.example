# ==========================================
# VoctManager Frontend Environment Variables
# Author: Krystian Bugalski
# Instructions: Copy this file to '.env' and replace the dummy values.
# Note: Vite requires all accessible variables to start with 'VITE_'
# ==========================================

# --- API Connection ---
# The base URL of the Django backend API. 
# For local development: http://localhost:8000
# For production, leave empty ('') to use relative paths through Nginx proxy,
# or set the full production domain (e.g., https://test.voctensemble.com)
VITE_API_URL=http://localhost:8000


# ==========================================
# GOOGLE CLOUD PLATFORM (Logistics & Maps)
# ==========================================
VITE_GOOGLE_MAPS_FRONTEND_KEY=your_google_maps_frontend_api_key_here
VITE_GOOGLE_MAP_ID=your_google_mapId_here


# ==========================================
# WEB PUSH (VAPID)
# ==========================================
# Public half of the VAPID keypair. The matching VAPID_PRIVATE_KEY lives in the backend env.
# Generate a pair with: npx web-push generate-vapid-keys
# IMPORTANT: must be passed as a Docker build ARG for production builds — see Dockerfile.
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here