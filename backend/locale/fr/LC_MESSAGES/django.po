# ── password_changed ───────────────────────────────────────────────────────

#: templates/emails/password_changed.html templates/emails/password_changed.txt
msgid "Security Notice"
msgstr "Avis de sécurité"

#: templates/emails/password_changed.html templates/emails/password_changed.txt
msgid "Your password has been changed"
msgstr "Votre mot de passe a été modifié"

#: templates/emails/password_changed.html templates/emails/password_changed.txt
msgid "We are writing to confirm that your VoctManager password was recently changed."
msgstr "Nous vous écrivons pour confirmer que le mot de passe de votre compte VoctManager a été récemment modifié."

#: templates/emails/password_changed.html templates/emails/password_changed.txt
msgid "If you made this change, no further action is required."
msgstr "Si vous êtes à l'origine de cette modification, aucune action n'est requise."

#: templates/emails/password_changed.html templates/emails/password_changed.txt
msgid "Did not make this change?"
msgstr "Vous n'avez pas effectué cette modification ?"

#: templates/emails/password_changed.html templates/emails/password_changed.txt
msgid "If you did not make this change, please contact our administration team immediately to secure your account."
msgstr "Si vous n'avez pas effectué cette modification, veuillez contacter immédiatement notre équipe d'administration pour sécuriser votre compte."

#: templates/emails/password_changed.html templates/emails/password_changed.txt
msgid "This security alert was sent to:"
msgstr "Cette alerte de sécurité a été envoyée à :"

# ── account_deleted ────────────────────────────────────────────────────────

#: templates/emails/account_deleted.html templates/emails/account_deleted.txt
msgid "Account Closure"
msgstr "Clôture de compte"

#: templates/emails/account_deleted.html templates/emails/account_deleted.txt
msgid "Your VoctManager account has been closed"
msgstr "Votre compte VoctManager a été clôturé"

#: templates/emails/account_deleted.html templates/emails/account_deleted.txt
msgid "We have successfully processed your account deletion request."
msgstr "Nous avons traité avec succès votre demande de suppression de compte."

#: templates/emails/account_deleted.html templates/emails/account_deleted.txt
msgid "All personal data associated with your account has been permanently removed from our systems in compliance with our privacy policy."
msgstr "Toutes les données personnelles associées à votre compte ont été définitivement supprimées de nos systèmes conformément à notre politique de confidentialité."

#: templates/emails/account_deleted.html templates/emails/account_deleted.txt
msgid "It has been our honour to have you as part of the VoctEnsemble community."
msgstr "Ce fut un honneur de vous compter parmi la communauté VoctEnsemble."

#: templates/emails/account_deleted.html templates/emails/account_deleted.txt
msgid "This confirmation was sent to:"
msgstr "Cette confirmation a été envoyée à :"

