# ── account_activation ─────────────────────────────────────────────────────

#: templates/emails/account_activation.html
#: templates/emails/account_activation.txt
msgid "VoctManager Invitation"
msgstr "Invitation VoctManager"

#: templates/emails/account_activation.html
#: templates/emails/account_activation.txt
msgid "Activate your artist profile"
msgstr "Activez votre profil d'artiste"

#: templates/emails/account_activation.html
#: templates/emails/account_activation.txt
#, python-format
msgid "Hello %(first_name)s,"
msgstr "Bonjour %(first_name)s,"

#: templates/emails/account_activation.html
#: templates/emails/account_activation.txt
msgid "Hello,"
msgstr "Bonjour,"

#: templates/emails/account_activation.html
#: templates/emails/account_activation.txt
msgid ""
"Your exclusive access to VoctManager has been prepared. Complete the final "
"activation step to set your secure password and enter the operational "
"workspace used for our projects and rehearsals."
msgstr ""
"Votre accès exclusif à VoctManager est prêt. Complétez l'étape finale "
"d'activation pour définir votre mot de passe sécurisé et accéder à l'espace "
"de travail dédié à nos projets et répétitions."

#: templates/emails/account_activation.html
#: templates/emails/account_activation.txt
msgid "Security Notice:"
msgstr "Avis de sécurité :"

#: templates/emails/account_activation.html
#: templates/emails/account_activation.txt
msgid ""
"This activation link is unique to your account. For your security, it will "
"expire automatically. Please do not share it with anyone."
msgstr ""
"Ce lien d'activation est unique à votre compte. Pour votre sécurité, il "
"expirera automatiquement. Veuillez ne pas le partager avec qui que ce soit."

#: templates/emails/account_activation.html
msgid "Activate Account"
msgstr "Activer mon compte"

#: templates/emails/account_activation.html
msgid ""
"If the button does not work, securely copy and paste this link into your "
"browser:"
msgstr ""
"Si le bouton ne fonctionne pas, copiez et collez ce lien dans votre "
"navigateur :"

#: templates/emails/account_activation.txt
msgid "VOCTMANAGER INVITATION"
msgstr "INVITATION VOCTMANAGER"

#: templates/emails/account_activation.txt
msgid "ACTIVATE ACCOUNT NOW:"
msgstr "ACTIVEZ VOTRE COMPTE MAINTENANT :"

#: templates/emails/account_activation.txt
msgid ""
"If you did not expect this message, contact the VoctEnsemble administration "
"team."
msgstr ""
"Si vous n'attendiez pas ce message, veuillez contacter l'équipe "
"d'administration de VoctEnsemble."

# ── welcome_email ──────────────────────────────────────────────────────────

#: templates/emails/welcome_email.html templates/emails/welcome_email.txt
msgid "Welcome"
msgstr "Bienvenue"

#: templates/emails/welcome_email.html templates/emails/welcome_email.txt
msgid "Welcome to VoctEnsemble"
msgstr "Bienvenue chez VoctEnsemble"

#: templates/emails/welcome_email.html templates/emails/welcome_email.txt
msgid ""
"We are thrilled to welcome you to VoctManager — the digital heart of our "
"artistic operations. This platform was designed to streamline our creative "
"process, from repertoire management to concert logistics, ensuring you can "
"focus entirely on the music."
msgstr ""
"Nous sommes ravis de vous accueillir sur VoctManager — le cœur numérique de "
"nos opérations artistiques. Cette plateforme a été conçue pour fluidifier "
"notre processus créatif, de la gestion du répertoire à la logistique "
"concertante, afin que vous puissiez vous concentrer entièrement sur la musique."

#: templates/emails/welcome_email.html templates/emails/welcome_email.txt
msgid ""
"Your profile has been successfully provisioned. You can now log in to view "
"your upcoming projects, access sheet music, and review rehearsal schedules."
msgstr ""
"Votre profil a été créé avec succès. Vous pouvez désormais vous connecter "
"pour consulter vos projets à venir, accéder aux partitions et consulter les "
"calendriers de répétitions."

#: templates/emails/welcome_email.html templates/emails/welcome_email.txt
msgid "Projects &amp; Repertoire"
msgstr "Projets &amp; Répertoire"

#: templates/emails/welcome_email.html templates/emails/welcome_email.txt
msgid "Projects & Repertoire"
msgstr "Projets & Répertoire"

#: templates/emails/welcome_email.html templates/emails/welcome_email.txt
msgid "View your upcoming projects, concert programmes, and casting assignments."
msgstr "Consultez vos projets à venir, les programmes de concerts et les distributions."

#: templates/emails/welcome_email.html templates/emails/welcome_email.txt
msgid "Sheet Music"
msgstr "Partitions"

#: templates/emails/welcome_email.html templates/emails/welcome_email.txt
msgid "Access your digital score library — scores and audio materials, organised by project."
msgstr "Accédez à votre bibliothèque numérique — partitions et enregistrements audio, organisés par projet."

#: templates/emails/welcome_email.html templates/emails/welcome_email.txt
msgid "Rehearsal Schedule"
msgstr "Calendrier des répétitions"

#: templates/emails/welcome_email.html templates/emails/welcome_email.txt
msgid "Stay up to date with rehearsal times, locations, and any last-minute changes."
msgstr "Restez informé des horaires de répétitions, des lieux et de toute modification de dernière minute."

#: templates/emails/welcome_email.html
msgid "Access Your Dashboard"
msgstr "Accéder à mon tableau de bord"

#: templates/emails/welcome_email.txt
msgid "Access Your Dashboard here:"
msgstr "Accéder à votre tableau de bord ici :"

#: templates/emails/welcome_email.html templates/emails/welcome_email.txt
msgid ""
"If you experience any issues logging in, please reach out to the "
"administration team."
msgstr ""
"Si vous rencontrez des difficultés pour vous connecter, veuillez contacter "
"l'équipe d'administration."

