# Normalize line endings: store text as LF in the repo, check out per-platform.
# This silences the "LF will be replaced by CRLF" warnings on Windows.
* text=auto

# Explicit binaries (never normalize).
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.mp3   binary
*.wav   binary
