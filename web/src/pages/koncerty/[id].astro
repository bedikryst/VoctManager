---
/**
 * @file [id].astro
 * @description Dedicated concert page (/koncerty/[id]). Generated by getStaticPaths()
 *  ONLY for entries flagged with `hasPage: true` in the `concerts` collection — by design,
 *  not every concert deserves a page. A page exists when the entry carries real depth: a
 *  reflection, a Latin inscriptio, a curated program with per-work source notes and — where
 *  the booklet preserved it — the sung word itself with a Polish translation.
 *
 *  The page reads like the ensemble's own programme book: a dark full-bleed nave (hero +
 *  reflection), then the visitor "sits down to read the programme" on parchment (the program
 *  with its expandable sung texts), a composer's voice, the voices of the evening (per-evening
 *  roster), documentary photographs, and finally the Via that runs on — prev / next Obraz,
 *  the road that does not dead-end. Each station burns its own candle: `--candle` inside
 *  <main> is re-toned from the concert `accent` (lib/candle), while the chrome keeps gold.
 * @architecture Astro islands 2026
 * @module pages/koncerty/[id]
 */
import type { ImageMetadata } from "astro";
import { getCollection } from "astro:content";
import { getImage, Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteChrome from "../../components/SiteChrome.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import BleedImage from "../../components/BleedImage.astro";
import { bleedPair, photoOptional } from "../../lib/photos";
import { candleFrom } from "../../lib/candle";
import { videoAsset } from "../../lib/videos";
import { VaultIsland } from "../../islands/landing/VaultIsland";
import { VideoPlayer } from "../../islands/landing/video/VideoPlayer";
import "../../styles/vault.css";
import "../../styles/vplayer.css";

export async function getStaticPaths() {
  const concerts = await getCollection("concerts", ({ data }) => data.hasPage);
  return concerts.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const c = entry.data;
// The hero takes the station's canonical photograph (`heroImg`) — the same file /o-nas shows
// as the milestone — rather than a second byte-identical copy under the `st-*-bg-desktop`
// name. `bg` stays what it is: the pre-blurred card wash for /koncerty.
const bg = bleedPair(c.heroImg ?? c.bg);
const ogImage = (await getImage({ src: bg.desktop, width: 1200, format: "webp" })).src;

// ── The station's own light: `--candle` inside <main> takes the concert accent's hue at
// the base gold's OKLCH lightness (build-time hex — no runtime CSS feature risk). Gold
// accents pass through unchanged; the chrome and vault outside <main> keep brand gold.
const candle = candleFrom(c.accent);

// ── Via neighbours: only page-bearing concerts (a non-page neighbour would 404). The road
// runs THROUGH the detail pages — a walk, not a set of dead-ends. Skips a slot when there
// is no page-bearing neighbour on that side.
const ordered = (await getCollection("concerts")).sort((a, b) => a.data.order - b.data.order);
const walk = ordered.filter((e) => e.data.hasPage);
const here = walk.findIndex((e) => e.id === entry.id);
const prev = here > 0 ? walk[here - 1] : null;
const next = here >= 0 && here < walk.length - 1 ? walk[here + 1] : null;

// ── Poster + documentary gallery. photoOptional so a slot can be declared in YAML before its
// image lands on disk — a missing file is silently skipped rather than breaking the build.
const posterImg = c.poster ? photoOptional(c.poster) : undefined;
const gallery: { img: ImageMetadata; alt: string; caption?: string }[] = [];
for (const g of c.gallery) {
  const img = photoOptional(g.img);
  if (img) gallery.push({ img, alt: g.alt ?? "", caption: g.caption });
}

const hasTour = c.dates.length > 0;

// ── The conductor stood that evening too: every roster (Voces) closes with the conductor,
// pulled from the credits so no YAML entry has to repeat him. Program-header obsada keeps
// its own line — a programme book names the conductor in both places.
const conductorCredit = c.credits.find((cr) => /dyrygent/i.test(cr.role));
// A page carries the sung word when any work — or any clasp, since in 9 Kart the psalm itself
// lives in the returns rather than in the work rows — prints its text. The provenance line hangs
// off this, so a clasp-only page must still own up to where its texts come from.
const hasText = c.program.some((p) => p.text || p.textPl || p.claspText || p.claspTextPl);

// ── `realizacja` is a free-text credit line owned by the /koncerty listing, and each evening fills
// it with whatever extra hand it had: "Realizacja: Ars Sonora Studio", "Skrzypce: Radu Ropotan",
// "Organy: …". Split a leading "Rola:" so the colophon prints a true credit instead of filing a
// violinist under "Realizacja". No prefix ⇒ the line really is a realizacja credit.
const realizacjaCredit = (() => {
  if (!c.realizacja) return undefined;
  const m = c.realizacja.match(/^\s*([^:]{2,24}?)\s*:\s*(.+)$/);
  return m ? { role: m[1], name: m[2] } : { role: "Realizacja", name: c.realizacja };
})();

// ── Concert film: still for the in-flow player. Falls back to the hero bg when no dedicated
// poster is set. The MP4 source is consumed by VideoPlayer, never exposed as a native anchor.
const filmPoster = c.video ? (photoOptional(c.video.poster ?? "") ?? bg.desktop) : undefined;
const filmPosterSrc = filmPoster
  ? (await getImage({ src: filmPoster, width: 1600, format: "webp" })).src
  : undefined;
const filmVideoSrc = c.video ? videoAsset(c.video.asset) : undefined;

// ── Programme grouped into movements (the salvation-history acts). Numbering runs continuously
// across acts (the bis carries "bis"); consecutive works sharing a movement id sit under one act
// header. A concert with no `movements` collapses to a single unlabelled group → the flat list.
type Movement = (typeof c.movements)[number];
type ProgItem = (typeof c.program)[number];
const movementsById = new Map(c.movements.map((m) => [m.id, m]));
const programGroups: { movement?: Movement; items: { p: ProgItem; num: string }[] }[] = [];
let runningNum = 0;
for (const p of c.program) {
  const num = p.bis ? "bis" : String(++runningNum).padStart(2, "0");
  const mv = p.movement ? movementsById.get(p.movement) : undefined;
  const tail = programGroups.at(-1);
  if (tail && tail.movement?.id === mv?.id) tail.items.push({ p, num });
  else programGroups.push({ movement: mv, items: [{ p, num }] });
}

const title = `${c.title} — Koncerty Duchowe · VoctEnsemble`;
const description = c.essence;

// ── JSON-LD: a tour emits one MusicEvent per date; a single-date concert keeps one event.
const performer = { "@type": "MusicGroup", name: "VoctEnsemble" };
const baseEvent = {
  "@type": "MusicEvent",
  name: c.title,
  performer,
  eventStatus: "https://schema.org/EventCompleted",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
};
const startDate = c.date ? (c.time ? `${c.date}T${c.time}:00` : c.date) : undefined;
const events = hasTour
  ? c.dates.map((d) => ({
      ...baseEvent,
      startDate: d.time ? `${d.date}T${d.time}:00` : d.date,
      location: { "@type": "Place", name: d.venue },
    }))
  : [
      {
        ...baseEvent,
        ...(startDate ? { startDate } : {}),
        location: {
          "@type": "Place",
          name: c.venue ?? c.meta,
          ...(c.address ? { address: c.address } : {}),
        },
      },
    ];
const jsonLd =
  events.length === 1
    ? { "@context": "https://schema.org", ...events[0] }
    : events.map((e) => ({ "@context": "https://schema.org", ...e }));

// Weekday-free long date for the tour rows (dates are ISO in YAML).
const plDate = (iso: string): string =>
  new Date(`${iso}T00:00:00`).toLocaleDateString("pl-PL", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
---

<BaseLayout
  title={title}
  description={description}
  path={`/koncerty/${entry.id}`}
  image={ogImage}
  bodyClass="page-koncert-detail"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <a class="skip-link" href="#tresc">Przejdź do treści</a>
  <SiteChrome current="/koncerty" tone="dark" />

  <main id="tresc" style={`--candle: ${candle}`}>
    {/* ── Hero: full-bleed church, latin inscriptio, title, meta ───────────── */}
    <section class="kd-hero" aria-label={c.title}>
      <div class="kd-hero-media" aria-hidden="true">
        <BleedImage desktop={bg.desktop} mobile={bg.mobile} alt="" eager animate />
      </div>
      <div class="kd-hero-veil" aria-hidden="true"></div>

      <div class="kd-hero-inner">
        <p class="kd-hero-eyebrow reveal">
          <span>Obraz {c.roman}</span>
          <span class="kd-dot" aria-hidden="true">·</span>
          <span class="lat">{c.latin}</span>
        </p>
        <h1 class="kd-hero-title reveal" data-d="1">{c.title}</h1>
        <p class="kd-hero-meta reveal" data-d="1">{c.meta}{c.time ? ` · godz. ${c.time}` : ""}</p>

        {c.inscriptio && (
          <p class="kd-inscriptio reveal" data-d="2">
            <em class="kd-inscriptio-lat">{c.inscriptio}</em>
            {c.inscriptioPl && (
              <>
                <span class="kd-dot" aria-hidden="true">·</span>
                <span class="kd-inscriptio-pl">{c.inscriptioPl}</span>
              </>
            )}
            {c.inscriptioRef && <span class="kd-inscriptio-ref">{c.inscriptioRef}</span>}
          </p>
        )}

        <span class="kd-hero-cue reveal" data-d="3" aria-hidden="true">Wejdź w wieczór</span>
      </div>
    </section>

    {/* ── Prologue: the threshold of the evening — draws the reader across the doorway
          into the experience before the reflection. ─────────────────────────────── */}
    {c.prologue && (
      <section class="kd-band kd-prologue" aria-label="Próg wieczoru">
        <div class="kd-wrap kd-narrow">
          <span class="kd-prologue-mark" aria-hidden="true"></span>
          <span class="kd-section-label micro reveal">
            <span class="lat">Ante concentum</span>
            <span class="kd-dot" aria-hidden="true">·</span>
            <span>Próg wieczoru</span>
          </span>
          <p class="kd-prologue-text reveal" data-d="1">{c.prologue}</p>
        </div>
      </section>
    )}

    {/* ── Verbum: the spoken threshold word — a live introduction transcribed, lightly
          edited for readability (subtractive only), never paraphrased. Fulfils the promise
          the prologue makes ("o. Naliwajko wprowadza…"); the unsigned `bridge` line hands
          the reader onward — the hush before the first work — so the narrative baton the
          prologue used to carry now falls AFTER the word was actually spoken. ─────────── */}
    {c.verbum && (
      <section class="kd-band kd-verbum" aria-label="Słowo wprowadzające">
        <div class="kd-wrap kd-narrow">
          <span class="kd-section-label micro reveal">
            <span class="lat">Verbum</span>
            <span class="kd-dot" aria-hidden="true">·</span>
            <span>Słowo wprowadzające</span>
          </span>
          <blockquote class="kd-verbum-quote reveal" data-d="1">
            <p>{c.verbum.quote}</p>
          </blockquote>
          <p class="kd-verbum-cite reveal" data-d="2">{c.verbum.speaker}</p>

          <details class="kd-verbum-full reveal" data-d="2">
            <summary>
              <span class="kd-text-cue">Całe słowo wprowadzenia</span>
              <span class="kd-text-icon" aria-hidden="true"></span>
            </summary>
            <div class="kd-verbum-body">
              {c.verbum.text.split("\n\n").map((para) => (
                <p>{para}</p>
              ))}
            </div>
          </details>

          {c.verbum.bridge && <p class="kd-verbum-bridge reveal">{c.verbum.bridge}</p>}
          <p class="kd-verbum-note micro">Zapis słowa wprowadzającego, nieznacznie zredagowany dla czytelności.</p>
        </div>
      </section>
    )}

    {/* ── Tour dates (multi-city). Single-date concerts keep the date in `meta`. ─ */}
    {hasTour && (
      <section class="kd-band kd-tour" aria-label="Wykonania">
        <div class="kd-wrap">
          <span class="kd-section-label micro reveal">
            <span class="lat">Itinerarium</span>
            <span class="kd-dot" aria-hidden="true">·</span>
            <span>Wykonania</span>
          </span>
          <ol class="kd-tour-list">
            {c.dates.map((d, i) => (
              <li class="kd-tour-row reveal" data-d={String((i % 3) + 1)}>
                <span class="kd-tour-date">{plDate(d.date)}</span>
                <span class="kd-tour-venue">{d.venue}</span>
                {d.time && <span class="kd-tour-time">godz. {d.time}</span>}
              </li>
            ))}
          </ol>
        </div>
      </section>
    )}

    {/* ── Reflection: Florent's authored paragraph + our unsigned bridge note ─── */}
    {(c.reflection || c.reflectionNote) && (
      <section class="kd-band kd-reflection" aria-label="Refleksja">
        <div class="kd-wrap kd-narrow">
          <span class="kd-section-label micro reveal">
            <span class="lat">Reflectio</span>
            <span class="kd-dot" aria-hidden="true">·</span>
            <span>Refleksja</span>
          </span>
          {c.reflection && <p class="kd-reflection-text reveal" data-d="1">{c.reflection}</p>}
          {c.reflectionAttribution && (
            <p class="kd-reflection-attrib micro reveal" data-d="2">{c.reflectionAttribution}</p>
          )}
          {c.reflectionNote && (
            <p class="kd-reflection-note reveal" data-d="2">{c.reflectionNote}</p>
          )}
        </div>
      </section>
    )}

    {/* ── Program: the programme book. Founder's name for the evening, obsada,
          then each work with scoring, source verse and — where kept — the sung
          word with its Polish translation (native <details>, zero JS). ───────── */}
    {c.program.length > 0 && (
      <section class="kd-band kd-band-soft kd-program-band tone-light" id="program" aria-label="Program koncertu">
        <div class="kd-wrap">
          <header class="kd-section-head">
            <span class="kd-section-label micro reveal">
              <span class="lat">Programma</span>
              <span class="kd-dot" aria-hidden="true">·</span>
              <span>Program koncertu</span>
            </span>
            {c.programLede && <h2 class="kd-section-title reveal" data-d="1">{c.programLede}</h2>}

            {(c.credits.length > 0 || realizacjaCredit) && (
              <dl class="kd-credits reveal" data-d="2" aria-label="Obsada">
                {c.credits.map((cr) => (
                  <div class="kd-credit">
                    <dt>{cr.role}</dt>
                    <dd>{cr.name}</dd>
                  </div>
                ))}
                {realizacjaCredit && (
                  <div class="kd-credit">
                    <dt>{realizacjaCredit.role}</dt>
                    <dd>{realizacjaCredit.name}</dd>
                  </div>
                )}
              </dl>
            )}

            {c.programArc && <p class="kd-program-arc reveal" data-d="3">{c.programArc}</p>}
          </header>

          <ol class="kd-program">
            {programGroups.map((grp) => (
              <>
                {grp.movement?.interlude && (
                  <li class="kd-interlude reveal" aria-label="Przerywnik biblijny">
                    <p class="kd-interlude-lat">{grp.movement.interlude.lat}</p>
                    {grp.movement.interlude.pl && (
                      <p class="kd-interlude-pl">{grp.movement.interlude.pl}</p>
                    )}
                    {grp.movement.interlude.ref && (
                      <span class="kd-interlude-ref micro">{grp.movement.interlude.ref}</span>
                    )}
                  </li>
                )}
                {grp.movement && (
                  <li class="kd-movement reveal">
                    <h3 class="kd-movement-head">
                      <span class="kd-movement-lat">{grp.movement.lat}</span>
                      <span class="kd-movement-pl">{grp.movement.pl}</span>
                    </h3>
                    {grp.movement.line && <p class="kd-movement-line">{grp.movement.line}</p>}
                  </li>
                )}
                {grp.items.map(({ p, num }) => (
                  <>
                    <li class:list={["kd-program-item", "reveal", { "is-bis": p.bis }]}>
                      <span class="kd-program-num micro">{num}</span>
                      <div class="kd-program-body">
                    <p class="kd-program-composer">
                      <span class="kd-program-composer-name">{p.composer}</span>
                      {p.years && <span class="kd-program-years"> · {p.years}</span>}
                    </p>
                    <p class="kd-program-work">
                      <em>{p.work}</em>
                      {p.year && <span class="kd-program-year">{p.year}</span>}
                      {p.voicing && <span class="kd-program-voicing">{p.voicing}</span>}
                      {p.duration && <span class="kd-program-duration">{p.duration}</span>}
                    </p>
                    {(p.inscriptio || p.inscriptioPl) && (
                      <p class="kd-program-inscriptio">
                        {p.inscriptio && <em class="kd-program-inscriptio-lat">{p.inscriptio}</em>}
                        {p.inscriptio && p.inscriptioPl && (
                          <span class="kd-dot" aria-hidden="true">·</span>
                        )}
                        {p.inscriptioPl && <span class="kd-program-inscriptio-pl">{p.inscriptioPl}</span>}
                        {p.inscriptioRef && (
                          <span class="kd-program-inscriptio-ref"> ({p.inscriptioRef})</span>
                        )}
                      </p>
                    )}
                    {/* The rubric: not what was sung — what was done. A missal prints its
                        instructions apart from its texts; so does this. */}
                    {p.rubric && (
                      <p class="kd-rubric">
                        <span class="kd-rubric-mark" aria-hidden="true"></span>
                        <span>{p.rubric}</span>
                      </p>
                    )}
                    {p.note && <p class="kd-program-note-work">{p.note}</p>}
                    {(p.text || p.textPl) && (
                      <details class="kd-text">
                        <summary>
                          <span class="kd-text-cue">Tekst i przekład</span>
                          <span class="kd-text-icon" aria-hidden="true"></span>
                        </summary>
                        <div class:list={["kd-text-cols", { "is-single": !(p.text && p.textPl) }]}>
                          {p.text && <p class="kd-text-orig">{p.text}</p>}
                          {p.textPl && <p class="kd-text-pl">{p.textPl}</p>}
                        </div>
                      </details>
                    )}
                      </div>
                    </li>
                    {/* The clasp: a marker when it only names a seam ("Przerwa"), a sung beat when
                        it brings words back (9 Kart — Psalm 51 returning between the psalms). It is
                        content either way, so it stays in the accessibility tree. */}
                    {p.clasp && (
                      <li class:list={["kd-clasp", "reveal", { "is-sung": p.claspText || p.claspTextPl }]}>
                        <span class="kd-clasp-rule"><span>{p.clasp}</span></span>
                        {p.claspText && <p class="kd-clasp-lat">{p.claspText}</p>}
                        {p.claspTextPl && <p class="kd-clasp-pl">{p.claspTextPl}</p>}
                      </li>
                    )}
                  </>
                ))}
              </>
            ))}
          </ol>

          {(c.spotify || hasText || c.programNote) && (
            <div class="kd-program-foot reveal">
              {c.programNote && <p class="kd-program-note kd-program-note-lead">{c.programNote}</p>}
              {hasText && (
                <p class="kd-program-note micro">
                  {c.textNote ??
                    "Teksty łacińskie i oryginalne — z programów zespołu; przekłady polskie własne."}
                </p>
              )}
              {c.spotify && (
                <a
                  class="kd-spotify-link micro"
                  href={c.spotify}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  wybrzmiało m.in. na Spotify <span aria-hidden="true">↗</span>
                </a>
              )}
            </div>
          )}
        </div>
      </section>
    )}

    {/* ── Pull quote: composer voice on a single work in the program ────────── */}
    {c.pullQuote && (
      <section class="kd-band kd-pullquote tone-light" aria-label="Cytat">
        <div class="kd-wrap kd-narrow">
          <blockquote class="kd-quote reveal">
            <p>{c.pullQuote.text}</p>
            <cite class="kd-cite">
              <span class="kd-cite-name">{c.pullQuote.attribution}</span>
              {c.pullQuote.about && <span class="kd-cite-about micro">{c.pullQuote.about}</span>}
            </cite>
          </blockquote>
        </div>
      </section>
    )}

    {/* ── Voces: the singers as they stood THAT evening — a per-evening cast, never the
          ensemble's fixed roster (guests happen, people move on). Names are consent-cleared
          for concert pages only. The cast closes with the conductor (from credits — he stood
          there too). The quiet factual footnote (`roster.note`) belongs to the whole block.
          Placed before the film/gallery so the names lead into the images. ── */}
    {c.roster && c.roster.groups.length > 0 && (
      <section class="kd-band kd-band-soft kd-voces tone-light" aria-label="Głosy wieczoru">
        <div class="kd-wrap">
          <span class="kd-section-label micro reveal">
            <span class="lat">Voces</span>
            <span class="kd-dot" aria-hidden="true">·</span>
            <span>Głosy wieczoru</span>
          </span>
          <dl class="kd-voces-grid">
            {c.roster.groups.map((g, i) => (
              <div class="kd-voces-group reveal" data-d={String((i % 3) + 1)}>
                <dt class="kd-voces-voice micro">{g.voice}</dt>
                {g.names.map((n) => (
                  <dd class="kd-voces-name">{n}</dd>
                ))}
                {g.detail && <dd class="kd-voces-detail">{g.detail}</dd>}
              </div>
            ))}
            {conductorCredit && (
              <div class="kd-voces-group reveal" data-d={String((c.roster.groups.length % 3) + 1)}>
                <dt class="kd-voces-voice micro">{conductorCredit.role}</dt>
                <dd class="kd-voces-name">{conductorCredit.name}</dd>
              </div>
            )}
          </dl>
          {c.roster.note && <p class="kd-voces-note reveal">{c.roster.note}</p>}
        </div>
      </section>
    )}

    {/* ── Film: selected fragments of the evening. The player hydrates eagerly after
          ClientRouter swaps and starts independently from the landing resume state. ── */}
    {c.video && filmVideoSrc && (
      <section class="kd-band kd-film" aria-label="Zapis wieczoru">
        <div class="kd-wrap">
          <span class="kd-section-label micro reveal">
            <span class="lat">Imago viva</span>
            <span class="kd-dot" aria-hidden="true">·</span>
            <span>Zapis wieczoru</span>
          </span>
          <div class:list={["kd-film-player", "reveal", { "is-portrait": c.video.portrait }]} data-d="1">
            <VideoPlayer
              client:load
              src={filmVideoSrc}
              poster={filmPosterSrc}
              caption={c.video.caption}
              note={c.video.note}
              portrait={c.video.portrait}
              tone="dark"
              resume={false}
            />
          </div>
        </div>
      </section>
    )}

    {/* ── Documentary gallery — the evening's own images ────────────────────── */}
    {gallery.length > 0 && (
      <section class="kd-band kd-gallery" aria-label="Obrazy wieczoru">
        <div class="kd-wrap">
          <span class="kd-section-label micro reveal">
            <span class="lat">Imagines</span>
