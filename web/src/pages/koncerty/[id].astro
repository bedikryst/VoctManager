        </nav>
      </div>
    </section>
  </main>

  <SiteFooter />

  <VaultIsland client:idle />
  <script>
    import "../../scripts/vault-triggers.ts";
  </script>

  {/* Chrome tone: flip to the paper treatment while a parchment section sits under the bar
      (same contract as /koncerty). Page-scoped, ClientRouter-safe. */}
  <script>
    let toneIO: IntersectionObserver | undefined;
    const setupKdTone = () => {
      toneIO?.disconnect();
      const chrome = document.getElementById("chrome");
      const light = [...document.querySelectorAll(".tone-light")];
      if (!chrome || light.length === 0) return;
      const active = new Set<Element>();
      toneIO = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) active.add(e.target);
            else active.delete(e.target);
          }
          chrome.classList.toggle("is-light", active.size > 0);
        },
        { rootMargin: "-64px 0px -90% 0px", threshold: 0 },
      );
      light.forEach((el) => toneIO!.observe(el));
    };
    document.addEventListener("astro:page-load", setupKdTone);
  </script>
