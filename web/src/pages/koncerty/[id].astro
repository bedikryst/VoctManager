---
/**
 * @file [id].astro
 * @description Dedicated concert page (/koncerty/[id]). Generated by getStaticPaths()
 *  ONLY for entries flagged with `hasPage: true` in the `concerts` collection — by design,
 *  not every concert deserves a page. A page exists when the entry carries: a Florent-authored
 *  reflection, a Latin inscriptio, a curated program with per-work source notes, and (optionally)
 *  a composer pull-quote. Editorial restraint is structural: the YAML data layer enforces it.
 *  Hero is dark (full-bleed station bg + veil); body bands are parchment (the visitor "sits
 *  down to read the program book").
 * @architecture Astro islands 2026
 * @module pages/koncerty/[id]
 */
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteChrome from "../../components/SiteChrome.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import BleedImage from "../../components/BleedImage.astro";
import { bleedPair } from "../../lib/photos";
import { VaultIsland } from "../../islands/landing/VaultIsland";
import "../../styles/vault.css";

export async function getStaticPaths() {
  const concerts = await getCollection("concerts", ({ data }) => data.hasPage);
  return concerts.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const c = entry.data;
const bg = bleedPair(c.bg);
const ogImage = (await getImage({ src: bg.desktop, width: 1200, format: "webp" })).src;

const title = `${c.title} — Koncerty Duchowe · VoctEnsemble`;
const description = c.essence;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MusicEvent",
  name: c.title,
  // startDate only when a real day exists — vague YAML dates stay out (no fabrication).
  ...(c.date ? { startDate: c.date } : {}),
  location: { "@type": "Place", name: c.venue ?? c.meta },
  performer: { "@type": "MusicGroup", name: "VoctEnsemble" },
  eventStatus: "https://schema.org/EventCompleted",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
};
---

<BaseLayout
  title={title}
  description={description}
  path={`/koncerty/${entry.id}`}
  image={ogImage}
  bodyClass="page-koncert-detail"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <a class="skip-link" href="#tresc">Przejdź do treści</a>
  <SiteChrome current="/koncerty" tone="dark" />

  <main id="tresc">
    {/* ── Hero: full-bleed church, latin inscriptio, title, meta ───────────── */}
    <section class="kd-hero" aria-label={c.title}>
      <div class="kd-hero-media" aria-hidden="true">
        <BleedImage desktop={bg.desktop} mobile={bg.mobile} alt="" eager />
      </div>
      <div class="kd-hero-veil" aria-hidden="true"></div>

      <div class="kd-hero-inner">
        <p class="kd-hero-eyebrow micro">
          <span>Obraz {c.roman}</span>
          <span class="kd-dot" aria-hidden="true">·</span>
          <span class="lat">{c.latin}</span>
        </p>
        <h1 class="kd-hero-title">{c.title}</h1>
        <p class="kd-hero-meta">{c.meta}</p>

        {c.inscriptio && (
          <p class="kd-inscriptio">
            <em class="kd-inscriptio-lat">{c.inscriptio}</em>
            {c.inscriptioPl && (
              <>
                <span class="kd-dot" aria-hidden="true">·</span>
                <span class="kd-inscriptio-pl">{c.inscriptioPl}</span>
              </>
            )}
            {c.inscriptioRef && (
              <span class="kd-inscriptio-ref">{c.inscriptioRef}</span>
            )}
          </p>
        )}
      </div>
    </section>

    {/* ── Reflection: Florent's authored paragraph ─────────────────────────── */}
    {c.reflection && (
      <section class="kd-band kd-reflection" aria-label="Refleksja">
        <div class="kd-wrap kd-narrow">
          <span class="kd-section-label micro">
            <span class="lat">Reflectio</span>
            <span class="kd-dot" aria-hidden="true">·</span>
            <span>Refleksja</span>
          </span>
          <p class="kd-reflection-text">{c.reflection}</p>
          {c.reflectionAttribution && (
            <p class="kd-reflection-attrib micro">{c.reflectionAttribution}</p>
          )}
        </div>
      </section>
    )}

    {/* ── Program: composer + life-dates + work + year + liturgical source ─── */}
    {c.program.length > 0 && (
      <section class="kd-band kd-band-soft kd-program-band" aria-label="Program koncertu">
        <div class="kd-wrap">
          <header class="kd-section-head">
            <span class="kd-section-label micro">
              <span class="lat">Programma</span>
              <span class="kd-dot" aria-hidden="true">·</span>
              <span>Program koncertu</span>
            </span>
            <h2 class="kd-section-title">{c.program.length} utworów{c.program.some((p) => p.bis) ? " + bis" : ""}</h2>
          </header>

          <ol class="kd-program">
            {c.program.map((p, i) => (
              <li class:list={["kd-program-item", { "is-bis": p.bis }]}>
                <span class="kd-program-num micro">{p.bis ? "—" : String(i + 1).padStart(2, "0")}</span>
                <div class="kd-program-body">
                  <p class="kd-program-composer">
                    <span class="kd-program-composer-name">{p.composer}</span>
                    {p.years && <span class="kd-program-years"> · {p.years}</span>}
                  </p>
                  <p class="kd-program-work">
                    <em>{p.work}</em>
                    {p.year && <span class="kd-program-year"> · {p.year}</span>}
                    {p.bis && <span class="kd-program-bis-mark micro">bis</span>}
                  </p>
                  {(p.inscriptio || p.inscriptioPl) && (
                    <p class="kd-program-inscriptio">
                      {p.inscriptio && <em class="kd-program-inscriptio-lat">{p.inscriptio}</em>}
                      {p.inscriptio && p.inscriptioPl && (
                        <span class="kd-dot" aria-hidden="true">·</span>
                      )}
                      {p.inscriptioPl && <span class="kd-program-inscriptio-pl">{p.inscriptioPl}</span>}
                      {p.inscriptioRef && <span class="kd-program-inscriptio-ref"> ({p.inscriptioRef})</span>}
                    </p>
                  )}
                </div>
              </li>
            ))}
          </ol>

          <div class="kd-program-foot">
            {c.spotify && (
              <a
                class="kd-spotify-link micro"
                href={c.spotify}
                target="_blank"
                rel="noopener noreferrer"
              >
                wybrzmiało m.in. na Spotify <span aria-hidden="true">↗</span>
              </a>
            )}
            {c.realizacja && <p class="kd-realizacja micro">{c.realizacja}</p>}
          </div>
        </div>
      </section>
    )}

    {/* ── Pull quote: composer voice on a single work in the program ────────── */}
    {c.pullQuote && (
      <section class="kd-band kd-pullquote" aria-label="Cytat">
        <div class="kd-wrap kd-narrow">
          <blockquote class="kd-quote">
            <p>{c.pullQuote.text}</p>
            <cite class="kd-cite">
              <span class="kd-cite-name">{c.pullQuote.attribution}</span>
              {c.pullQuote.about && (
                <span class="kd-cite-about micro">{c.pullQuote.about}</span>
              )}
            </cite>
          </blockquote>
        </div>
      </section>
    )}

    {/* ── Back link ────────────────────────────────────────────────────────── */}
    <section class="kd-band kd-back" aria-label="Powrót do cyklu">
      <div class="kd-wrap">
        <a class="kd-back-link micro" href="/koncerty">
          <span aria-hidden="true">←</span> Wszystkie Koncerty Duchowe
        </a>
      </div>
    </section>
  </main>

  <SiteFooter />

  <VaultIsland client:idle />
  <script>
    import "../../scripts/vault-triggers.ts";
  </script>
</BaseLayout>

<style>
  /* ── Reset on this page only ────────────────────────────────────────────── */
  .page-koncert-detail { background: var(--dark, #080807); color: var(--paper, #f4f1e9); }
  main { display: block; }
  .skip-link { position: absolute; left: -9999px; top: auto; }
  .skip-link:focus { left: 16px; top: 16px; background: var(--paper); color: var(--ink); padding: 10px 14px; border-radius: 4px; z-index: 99; }

  /* ── Hero ──────────────────────────────────────────────────────────────── */
  .kd-hero { position: relative; min-height: 100svh; display: flex; align-items: flex-end; padding: 0 max(28px, 5vw) clamp(72px, 10vw, 124px); color: var(--paper); overflow: hidden; isolation: isolate; }
  .kd-hero-media { position: absolute; inset: 0; z-index: -2; }
  .kd-hero-media :global(picture),
  .kd-hero-media :global(img) { width: 100%; height: 100%; display: block; object-fit: cover; }
  .kd-hero-veil { position: absolute; inset: 0; z-index: -1; pointer-events: none;
    background:
      linear-gradient(180deg, rgba(8,8,7,.44) 0%, rgba(8,8,7,.1) 38%, rgba(8,8,7,.82) 100%),
      linear-gradient(72deg, rgba(8,8,7,.72) 0%, rgba(8,8,7,.22) 46%, transparent 72%); }

  .kd-hero-inner { max-width: 1180px; width: 100%; margin: 0 auto; }
  .kd-hero-eyebrow { display: inline-flex; align-items: center; gap: 10px; font-family: var(--mono); font-size: 11px; letter-spacing: .26em; text-transform: uppercase; color: rgba(244, 241, 233, .72); margin: 0 0 22px; }
  .kd-hero-eyebrow .lat { font-family: var(--serif); font-style: italic; text-transform: none; letter-spacing: 0; font-size: 16px; color: var(--candle); }
  .kd-hero-title { font-family: var(--serif); font-weight: 300; line-height: .98; font-size: clamp(48px, 9vw, 124px); letter-spacing: -.01em; margin: 0; color: var(--paper); }
  .kd-hero-meta { font-family: var(--mono); font-size: clamp(11.5px, 1vw, 13px); letter-spacing: .18em; text-transform: uppercase; color: rgba(244, 241, 233, .68); margin: 26px 0 0; }

  .kd-inscriptio { margin: clamp(36px, 5vw, 56px) 0 0; max-width: 720px; font-family: var(--serif); font-weight: 300; font-size: clamp(16px, 1.5vw, 20px); line-height: 1.55; color: rgba(244, 241, 233, .82); }
  .kd-inscriptio-lat { font-style: italic; color: var(--candle); margin-right: 12px; }
  .kd-inscriptio-pl { color: rgba(244, 241, 233, .72); margin-left: 4px; }
  .kd-inscriptio-ref { display: inline-block; margin-left: 14px; font-family: var(--mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: rgba(244, 241, 233, .5); }

  .kd-dot { margin: 0 8px; color: rgba(244, 241, 233, .42); }

  /* ── Bands (body) ──────────────────────────────────────────────────────── */
  .kd-band { padding: clamp(84px, 13vw, 184px) max(28px, 5vw); position: relative; }
  .kd-band-soft { background: var(--paper, #f4f1e9); color: var(--ink, #161514); }
  .kd-wrap { max-width: 1180px; margin: 0 auto; }
  .kd-narrow { max-width: 760px; }

  .kd-section-head { margin: 0 0 clamp(40px, 6vw, 72px); }
  .kd-section-label { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 10.5px; letter-spacing: .26em; text-transform: uppercase; color: var(--candle); margin: 0 0 22px; }
  .kd-section-label .lat { font-family: var(--serif); font-style: italic; text-transform: none; letter-spacing: 0; font-size: 14px; }
  .kd-section-title { font-family: var(--serif); font-weight: 300; line-height: 1.04; font-size: clamp(36px, 5.6vw, 76px); letter-spacing: -.01em; color: var(--ink); margin: 0; max-width: 18ch; }

  /* ── Reflection ────────────────────────────────────────────────────────── */
  .kd-reflection { background: var(--dark, #080807); color: var(--paper, #f4f1e9); text-align: left; }
  .kd-reflection .kd-section-label { color: var(--candle); }
  .kd-reflection-text { font-family: var(--serif); font-style: italic; font-weight: 300; font-size: clamp(22px, 2.5vw, 34px); line-height: 1.5; color: rgba(244, 241, 233, .92); margin: 18px 0 0; max-width: 24ch; max-width: 760px; letter-spacing: -.005em; }
  .kd-reflection-attrib { margin: clamp(34px, 5vw, 56px) 0 0; color: rgba(244, 241, 233, .56); }

  /* ── Program ───────────────────────────────────────────────────────────── */
  .kd-program-band { color: var(--ink); }
  .kd-program { list-style: none; margin: 0; padding: 0; border-bottom: 1px solid var(--line, rgba(22,21,20,.16)); }
  .kd-program-item { display: grid; grid-template-columns: max-content 1fr; gap: clamp(20px, 3vw, 44px); padding: clamp(28px, 4vw, 44px) 0; border-top: 1px solid var(--line, rgba(22,21,20,.16)); align-items: start; }
  .kd-program-item.is-bis { border-top-style: dashed; }
  .kd-program-num { font-family: var(--mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--candle); padding-top: 6px; min-width: 28px; text-align: right; }
  .kd-program-item.is-bis .kd-program-num { color: var(--ink-muted, #746d62); }
  .kd-program-body { display: grid; gap: 8px; min-width: 0; }
  .kd-program-composer { margin: 0; font-family: var(--mono); font-size: 11.5px; letter-spacing: .14em; text-transform: uppercase; color: var(--ink, #161514); }
  .kd-program-composer-name { font-weight: 500; }
  .kd-program-years { color: var(--ink-muted, #746d62); font-weight: 300; }
  .kd-program-work { margin: 0; font-family: var(--serif); font-size: clamp(22px, 2.4vw, 32px); font-weight: 300; line-height: 1.18; color: var(--ink); letter-spacing: -.005em; }
  .kd-program-work em { font-style: italic; }
  .kd-program-year { font-family: var(--mono); font-style: normal; font-size: 12.5px; letter-spacing: .14em; color: var(--ink-muted, #746d62); margin-left: 4px; vertical-align: 2px; }
  .kd-program-bis-mark { display: inline-block; margin-left: 12px; padding: 3px 10px; border: 1px solid var(--candle); border-radius: 999px; color: var(--candle); vertical-align: 5px; }

  .kd-program-inscriptio { margin: 4px 0 0; font-family: var(--serif); font-size: clamp(14px, 1.2vw, 16px); line-height: 1.55; color: var(--ink-muted, #746d62); }
  .kd-program-inscriptio-lat { font-style: italic; color: var(--ink-soft, #34302b); }
  .kd-program-inscriptio-pl { color: var(--ink-muted, #746d62); }
  .kd-program-inscriptio-ref { font-family: var(--mono); font-style: normal; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--ink-muted, #746d62); }

  .kd-program-foot { display: flex; flex-wrap: wrap; gap: 12px 28px; align-items: baseline; margin: clamp(40px, 5vw, 64px) 0 0; }
  .kd-spotify-link { font-family: var(--mono); font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: var(--candle); border-bottom: 1px solid transparent; padding-bottom: 2px; transition: border-color .3s var(--ease, ease); }
  .kd-spotify-link:hover { border-bottom-color: var(--candle); }
  .kd-realizacja { font-family: var(--mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--ink-muted, #746d62); margin: 0; }

  /* ── Pull quote ────────────────────────────────────────────────────────── */
  .kd-pullquote { background: var(--paper-soft, #ebe6da); color: var(--ink, #161514); }
  .kd-quote { margin: 0; }
  .kd-quote p { font-family: var(--serif); font-style: italic; font-weight: 300; font-size: clamp(22px, 2.6vw, 34px); line-height: 1.45; color: var(--ink); margin: 0; letter-spacing: -.005em; }
  .kd-quote p::before { content: "« "; color: var(--candle); }
  .kd-quote p::after { content: " »"; color: var(--candle); }
  .kd-cite { display: flex; flex-direction: column; gap: 6px; margin-top: clamp(28px, 4vw, 44px); padding-top: 18px; border-top: 1px solid var(--line, rgba(22,21,20,.16)); font-style: normal; }
  .kd-cite-name { font-family: var(--serif); font-style: italic; font-size: clamp(16px, 1.5vw, 20px); color: var(--ink); }
  .kd-cite-about { font-family: var(--mono); font-size: 10.5px; letter-spacing: .22em; text-transform: uppercase; color: var(--ink-muted, #746d62); }

  /* ── Back ──────────────────────────────────────────────────────────────── */
  .kd-back { background: var(--dark, #080807); padding-top: clamp(60px, 7vw, 88px); padding-bottom: clamp(60px, 7vw, 88px); }
  .kd-back-link { font-family: var(--mono); font-size: 11px; letter-spacing: .26em; text-transform: uppercase; color: rgba(244, 241, 233, .72); display: inline-flex; align-items: center; gap: 10px; border-bottom: 1px solid transparent; padding-bottom: 4px; transition: color .3s var(--ease, ease), border-color .3s var(--ease, ease); }
  .kd-back-link:hover { color: var(--candle); border-bottom-color: var(--candle); }

  /* ── Reveal stays opt-out: this page does not depend on it ─────────────── */
  @media (max-width: 720px) {
    .kd-program-item { grid-template-columns: 1fr; gap: 6px; }
    .kd-program-num { text-align: left; padding-top: 0; }
  }
</style>
