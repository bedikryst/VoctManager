  .kd-text-icon::before,
  .kd-text-icon::after { content: ""; position: absolute; background: currentColor; transition: transform .35s var(--ease, ease), opacity .35s var(--ease, ease); }
  .kd-text-icon::before { left: 0; top: 4.5px; width: 10px; height: 1px; }
