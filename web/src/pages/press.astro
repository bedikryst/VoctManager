const TRADITIONAL = [
  { title: "Gaudete", note: "XVI w. · aranż. Brian Kay" },
  { title: "O Virgo Splendens", note: "XIV w. · Llibre Vermell de Montserrat" },
  { title: "Salve Regina", note: "tradycyjna melodia z Oksytanii" },
  { title: "Tantum ergo sacramentum", note: "XVII w. · polifonia korsykańska" },
] as const;

const COLLABORATORS = [
  { role: "Reżyseria świateł", name: "Ada Bystrzycka", entity: "Multiscena" },
  { role: "Realizacja dźwięku", name: "Jakub Garbacz", entity: "Ars Sonora Studio" },
  { role: "Animacja wizualna", name: "Sebastian Kuźma", entity: "ART Agencja Rzemieślników Teatralnych" },
  { role: "Skrzypce (gość)", name: "Radu Ropotan", entity: "Wołanie Gór · Szczawnica" },
] as const;

const INSTITUTIONAL_PARTNERS = [
  "Fundacja Carpe Diem · Łódź",
  "Ośrodek Kultury Norwida · Mistrzejowice",
  "Gmina Łapsze Niżne",
  "GOK Łapsze Niżne",
  "ZEW Niedzica",
  "Zamek Dunajec",
  "ACN — Pomoc Kościołowi w Potrzebie",
] as const;

