---
/**
 * @file press.astro
 * @description Press kit / booking decision surface — a dedicated audience track separate
 *  from the landing. Landing serves the audience (the rite, the atmosphere); /press serves
 *  the festival programmer, the venue booker, the editor pitching a feature. Same sacred
 *  palette, soberer register: real recordings, hard facts, paste-ready biogram, published
 *  press coverage, direct booking.
 *
 *  HONESTY CHARTER (same rule as the landing/koncerty/o-nas soul refactors): nothing on
 *  this page is placeholder or invented. Videos come from PATHS (`p.video` — omitted where
 *  no footage exists, never fabricated); the extended biogram is the team's own verbatim
 *  text (docs/about); press mentions are real published links; facts are computed from
 *  data. Sections that need assets or team sign-off (downloadable pakiet, tech rider,
 *  director bio/portrait) are ABSENT until those exist — the materials section says so
 *  plainly and routes to e-mail instead of pretending.
 *
 *  Video slots render through the landing's shared VideoPlayer island (custom chrome,
 *  one-video-at-a-time coordination, out-of-view pause) — never native controls. The hero
 *  plays the same Kontemplacja Wcielenia film as the landing's modal (shared browser cache
 *  + shared resume position).
 *
 *  Reachable only via direct URL for now — no link from the landing. Florent shares
 *  voctensemble.com/press in his outreach emails.
 * @architecture Astro islands 2026
 * @module pages/press
 */
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteChrome from "../components/SiteChrome.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { photo, bleedPair } from "../lib/photos";
import { PATHS } from "../data/landing/paths";
import { VaultIsland } from "../islands/landing/VaultIsland";
import { VideoPlayer } from "../islands/landing/video/VideoPlayer";
import "../styles/vault.css";
import "../styles/vplayer.css";

const title = "Press kit — VoctEnsemble";
const description =
  "Materiały dla programatorów festiwali, kuratorów i redakcji: zapisy koncertów, biogram do programu, pełny repertuar siedmiu wieków, publikacje o zespole i bezpośredni booking VoctEnsemble.";

const ogImage = (
  await getImage({ src: bleedPair("hero-landing").desktop, width: 1200, format: "webp" })
).src;

// Hero film — the REAL Kontemplacja Wcielenia registration (same file the landing's hero
// modal plays: shared browser cache, shared resume position). The credit is sourced from
// paths.ts (`credit` on the wcielenie entry) — it belongs to THIS footage.
const HERO_VIDEO = "/video/landing-modal.mp4";
const heroPoster = (
  await getImage({ src: bleedPair("chor-spot").desktop, width: 1600, format: "webp" })
).src;

const VIGNETTES: ReadonlyArray<{
  readonly n: string;
  readonly title: string;
  readonly body: readonly string[];
  readonly mantra?: string;
}> = [
  {
    n: "I",
    title: "Skąd się wzięliśmy.",
    body: [
      "Z tęsknoty, natchnienia i marzenia. Jak anachoreci, w odosobnieniu, z daleka od zgiełku i muzyki — zatęskniono za muzyką. Wizja muzyki jako powiew ducha, który przemienia świat swoją polifonią, otulając i przenikając do głębi człowieka — rezonując i znajdując miejsce w jego duszy niczym żywy organizm.",
    ],
    mantra: "Music — Silence — Contemplation. W ciszy rodzi się muzyka. W ciszy się kontempluje. Muzyka jest kontemplacją duszy w czasie.",
  },
  {
    n: "II",
    title: "Co robimy.",
    body: [
      "Koncerty Duchowe — Concerts Spirituels. Oprawy liturgiczne, msze ślubne, ważne uroczystości kościelne.",
      "Na scenie i przy realizacjach spotykamy się m.in. z reżyserką świateł Adą Bystrzycką (Multiscena), realizatorem dźwięku Jakubem Garbaczem (Ars Sonora Studio), Sebastianem Kuźmą (animacja wizualna) i skrzypkiem Radu Ropotanem (Wołanie Gór); instytucjonalnie — z Fundacją Carpe Diem i Ośrodkiem Kultury Norwida w krakowskich Mistrzejowicach.",
    ],
  },
  {
    n: "III",
    title: "Co śpiewamy.",
    body: [
      "Dzielimy się — przemyślanymi narracjami muzycznymi utkanymi z utworów, w których muzyka i słowo są odbiciem lustrzanym samych siebie. Muzyka jako odbicie duszy słowa, słowa niesione i wyrażane przez ułożenie dźwięków.",
      "Ubóstwiamy heterofonię, politonalność i polifonię. Interesuje nas świat — widzialny i niematerialny. Muzyka sakralna wokalna jest naszą towarzyszką w tej wędrówce — czerpie z geniuszu ludzkiego, z Biblii i z mądrości przodków.",
    ],
  },
];

// Full repertoire A-Z. Source: artist input. Format: composer + life years (optional) + works.
// Year suffix on a work is either a precise composition date or a reasonable approximation.
