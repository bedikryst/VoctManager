const LITURGIES = [
  {
    date: "16 maja 2026",
    title: "Sanktuarium św. Andrzeja Boboli · Warszawa",
    context:
      "Liturgia w uroczystość św. Andrzeja Boboli, w 100-lecie obu polskich prowincji jezuickich. Mszy przewodniczył abp Adrian Galbas, homilię wygłosił przełożony generalny jezuitów o. Arturo Sosa SJ.",
  },
  {
    date: "16 stycznia 2025",
    title: "28. Dzień Judaizmu · Kraków",
    context:
      "Liturgia w Kaplicy św. Doroty pod przewodnictwem bp. Roberta Chrząszcza oraz występ w Synagodze Tempel — wspomnienie bł. p. Tadeusza Jakubowicza.",
  },
  {
    date: "na zapytanie",
    title: "Liturgie ślubne i uroczystości kościelne",
    context:
      "Dotychczasowe oprawy: Kolegiata św. Anny w Krakowie oraz Opactwo Benedyktynów w Tyńcu. Jesteśmy dyspozycyjni dla parafii, par i organizatorów.",
  },
] as const;

// Published coverage — REAL links only (source: docs/about). Each entry is a verifiable
// external document. No pull-quotes until someone re-reads the pieces and picks them by hand.
const PRESS_MENTIONS = [
  {
    outlet: "Gość Niedzielny",
    kind: "Artykuł",
    title: "Niedzica. Koncert dedykowany Strefie Gazy",
    context: "Relacja z koncertu Aeternam — Epitafium dla Gazy w Niedzicy.",
    href: "https://krakow.gosc.pl/doc/9466268.Niedzica-Koncert-dedykowany-Strefie-Gazy",
  },
  {
    outlet: "Onet / KAI",
    kind: "Artykuł",
    title: "Muzyczna modlitwa w Niedzicy — koncert dla Strefy Gazy",
    context: "Depesza Katolickiej Agencji Informacyjnej o tym samym wieczorze.",
    href: "https://www.onet.pl/informacje/kai/muzyczna-modlitwa-w-niedzicy-koncert-dla-strefy-gazy/l3pn8kc,30bc1058",
  },
  {
    outlet: "Episkopat Polski",
    kind: "Fotorelacja",
    title: "Uroczystość św. Andrzeja Boboli w Warszawie",
    context: "Oficjalna fotorelacja Konferencji Episkopatu Polski z liturgii ze śpiewem zespołu.",
    href: "https://flic.kr/s/aHBqjCU2Dw",
  },
  {
    outlet: "Sanktuarium św. Andrzeja Boboli",
    kind: "Transmisja",
    title: "Msza w 100-lecie polskich prowincji jezuickich",
    context: "Zapis liturgii, którą śpiewem oprawił zespół — pod przewodnictwem abp. Adriana Galbasa, z homilią o. Artura Sosy SJ.",
    href: "https://www.youtube.com/live/Bpxl8ozPa3s",
  },
] as const;

const totalComposers = REPERTOIRE.length;
const totalWorks = REPERTOIRE.reduce((acc, c) => acc + c.works.length, 0) + TRADITIONAL.length;

// Sober register: real numbers in Arabic (the Roman numerals are the landing's poetry —
// a programmer scans facts, they don't decode numerals). Counts derive from data, so they
// can't rot into lies when the next concert or piece lands.
const FACTS = [
  { num: "12", label: "głosów zwykle na scenie" },
  { num: String(PATHS.length), label: "Koncertów Duchowych w cyklu" },
  { num: String(totalWorks), label: `utworów w repertuarze · ${totalComposers} kompozytorów` },
  { num: "7 wieków", label: "muzyki sakralnej · od XIV w." },
  { num: "2024", label: "debiut · Kontemplacja Wcielenia" },
  { num: "Kraków", label: "siedziba · Fundacja VoctFoundation" },
] as const;

// Register rows join the landing's editorial layer (PATHS) with the concerts collection
// (SSoT for the roman numeral + the real year) and resolve each entry's poster for the
// player. `video` passes through untouched — rows without footage render NO player
// (paths.ts rule: "omit when no footage exists, never fabricate").
const concertData = new Map((await getCollection("concerts")).map((c) => [c.id, c.data]));
const register = await Promise.all(
  PATHS.map(async (p) => {
    const meta = concertData.get(p.concertId);
    return {
      ...p,
      roman: meta?.roman ?? "",
      yearLabel: meta?.date?.slice(0, 4) ?? meta?.viaDate.match(/\d{4}/)?.[0] ?? "",
      posterSrc: p.video
        ? (await getImage({ src: photo(p.poster), width: 900, format: "webp" })).src
        : undefined,
    };
  }),
);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MusicGroup",
  // Same entity node the landing declares (/#ensemble) — /press describes the SAME
  // MusicGroup, not a twin with a divergent URL. The page is noindex; the graph stays
  // coherent for anything that still reads it.
  "@id": "https://voctensemble.com/#ensemble",
  name: "VoctEnsemble",
  url: "https://voctensemble.com",
  description,
  founder: { "@type": "Person", name: "Florent de Bazelaire" },
  genre: ["Sacred music", "Choral music", "Polifonia"],
  sameAs: [
    "https://www.instagram.com/voctensemble/",
    "https://www.facebook.com/voctensemble/",
    "https://www.youtube.com/@VoctEnsemble-nb7gh",
  ],
};
---

<BaseLayout title={title} description={description} path="/press" image={ogImage} bodyClass="page-press">
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <meta name="robots" content="noindex,follow" />
  </Fragment>

  <a class="skip-link" href="#tresc">Przejdź do treści</a>
  <SiteChrome current="/press" tone="dark" />

  <main id="tresc">
    {/* ── HERO · real concert registration ─────────────────────────────── */}
    <section class="press-hero" aria-label="Press kit VoctEnsemble">
      <div class="press-hero-inner">
        <p class="press-eyebrow"><span class="lat">Press kit</span> · Concerts Spirituels</p>
        <h1 class="press-hero-title">
          <span>VoctEnsemble</span>
          <em>Koncerty Duchowe.</em>
        </h1>
        <p class="press-hero-positioning">
          Profesjonalny zespół wokalny — muzyka sakralna od XIV wieku po współczesność.
          Autorski cykl <em>Concerts Spirituels</em>, oprawy liturgii i ważnych uroczystości. Kraków.
        </p>
        <p class="press-hero-lede">
          Zamiast obietnic — zapis. Tak brzmimy w nawie bazyliki.
        </p>

        <div class="press-hero-video">
          <VideoPlayer
            client:visible
            src={HERO_VIDEO}
            poster={heroPoster}
            tone="dark"
            caption="Kontemplacja Wcielenia · Bazylika NSPJ w Krakowie · 2024"
            note="Rejestracja: Jakub Garbacz, Ars Sonora Studio"
          />
        </div>

        <div class="press-hero-actions">
          <a
            class="press-cta press-cta--solid"
            href="mailto:booking@voctensemble.com?subject=Zaproszenie%20VoctEnsemble"
          >
            Zaproś / napisz do nas
          </a>
          <a class="press-cta" href="#materialy">Materiały prasowe ↓</a>
        </div>
        <a class="press-scroll-cue" href="#fakty">
          Materiały dla programatorów <span aria-hidden="true">↓</span>
        </a>
      </div>
    </section>

    {/* ── FACTS row · light parchment ──────────────────────────────────── */}
    <section class="press-facts tone-light" id="fakty" aria-label="Dane zespołu">
      <ul class="press-facts-grid">
        {FACTS.map((f) => (
          <li class="press-fact">
            <span class="press-fact-num">{f.num}</span>
            <span class="press-fact-label">{f.label}</span>
          </li>
        ))}
      </ul>
    </section>

    {/* ── JUMP · in-page index so a skimming programmer reaches the decision sections fast ── */}
    <nav class="press-jump" aria-label="Spis sekcji">
      <a href="#o-nas">O zespole</a>
      <a href="#biogram">Biogram</a>
      <a href="#koncerty">Koncerty</a>
      <a href="#repertuar">Repertuar</a>
      <a href="#liturgie">Liturgie</a>
      <a href="#wspolpraca">Współpraca</a>
      <a href="#prasa">Pisali o nas</a>
      <a href="#materialy">Materiały</a>
      <a href="#booking">Booking</a>
    </nav>

    {/* ── VIGNETTES · the founder's three questions, compressed for a working reader ── */}
    <section class="press-vignettes tone-light" id="o-nas" aria-label="O zespole">
      <div class="press-section-head">
        <span class="press-eyebrow"><span class="lat">De nobis</span> · Kim jesteśmy</span>
        <h2>Skąd się wzięliśmy, co robimy, co śpiewamy.</h2>
      </div>
      <div class="press-vignettes-grid">
        {VIGNETTES.map((v) => (
          <article class="press-vignette">
            <p class="press-vignette-num">{v.n}</p>
            <h3 class="press-vignette-title">{v.title}</h3>
            {v.body.map((p) => <p>{p}</p>)}
            {v.mantra && <p class="press-vignette-mantra"><em>{v.mantra}</em></p>}
          </article>
        ))}
      </div>
    </section>

    {/* ── EXTENDED BIO · the team's own verbatim text, paste-ready ─────── */}
    <section class="press-bio tone-light" id="biogram" aria-label="Biogram rozszerzony">
      <div class="press-section-head">
        <span class="press-eyebrow"><span class="lat">Biographia</span> · Biogram</span>
        <h2>Biogram do programu festiwalu, plakatu, recenzji.</h2>
        <p class="press-section-lede">
          Ok. 2100 znaków — tekst własny zespołu, gotowy do kopiowania w całości.
        </p>
      </div>
      <div class="press-bio-text">
        <p>
          <strong>VoctEnsemble</strong> to nowoczesna formacja wokalna, która pod kierownictwem
          <strong>Florenta de Bazelaire</strong> wnosi na polską scenę muzyczną nową jakość
          estetyczną i duchową. Misją zespołu jest zgłębianie człowieczeństwa za pomocą muzyki
          sakralnej, przy jednoczesnym zachowaniu niezwykłej czujności na współczesne tragizmy
          i nadzieje świata. W ramach autorskiego cyklu <em>Koncertów Duchowych</em>, grupa
          przywraca tradycję dawnych <em>Concerts Spirituels</em>, budując pomost między
          historyczną świadomością a potrzebami współczesnego słuchacza.
        </p>
        <p>
          Twórczość VoctEnsemble to fascynujący kalejdoskop stylów, w którym dzieła mistrzów
          Renesansu i Baroku spotykają się z kompozycjami Arvo Pärta czy Bernata Vivancosa.
          Ta artystyczna wymiana pozwala na odkrywanie uniwersalnych prawd ukrytych
          w dźwiękach, czyniąc każdy koncert podróżą w głąb sacrum.
        </p>
        <p>
          Zespół od początku istnienia stawia na interdyscyplinarną współpracę z wybitnymi
          twórcami. Debiutancki projekt <em>Kontemplacja Wcielenia</em> (2024) został
          zarejestrowany przez Jakuba Garbacza (Ars Sonora Studio), co otworzyło grupie drogę
          na ogólnopolskie festiwale — m.in. do Archikatedry Łódzkiej pod auspicjami Fundacji
          Carpe Diem. Wrażliwość zespołu na los drugiego człowieka zaowocowała takimi
          wydarzeniami jak <em>Hymn Poległym</em> w Bazylice Mariackiej — modlitwą o pokój na
          Ukrainie — oraz <em>Aeternam — Epitafium dla Gazy</em>, prezentowanym m.in.
          w krakowskich Mistrzejowicach i Niedzicy.
        </p>
        <p>
          VoctEnsemble to także dbałość o wizualny wymiar duchowości. Dzięki współpracy
          z reżyserką świateł Adą Bystrzycką oraz artystami takimi jak Sebastian Kuźma
