---
/**
 * @file kolofon.astro
 * @description Public colophon — quiet destination linked from every page footer (not in main
 *  nav). One client-generated sigil at center, then five short blocks after it: konstrukcja
 *  (build), typi (fonts), fundatio (foundation legal), auctor (author), gratiarum actio
 *  (past-concert collaborators). The sigil is per-visit (lib/sigil.ts, seeded from
 *  sessionStorage so there is NO persistent client identifier under RODO) and redrawn on every
 *  page-load — same visit, same seal; a fresh one each return. Tone: dark hero → parchment body,
 *  matches the pattern from `/koncerty/[id]`. Copy follows the site's soul rules: positive
 *  framing over apophasis, one Latin·Polish label per idea, honest about what the page loads
 *  (Plausible is disclosed, not denied).
 * @architecture Astro islands 2026
 * @module pages/kolofon
 */
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteChrome from "../components/SiteChrome.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { VaultIsland } from "../islands/landing/VaultIsland";
import { bleedPair } from "../lib/photos";
import "../styles/vault.css";

const title = "Kolofon — VoctEnsemble · VoctFoundation";
const description =
  "Kolofon strony VoctEnsemble — kroje pisma, konstrukcja, fundacja, autorzy. Pieczęć rzemiosła w jednym miejscu.";

const ogImage = (
  await getImage({ src: bleedPair("hero-landing").desktop, width: 1200, format: "webp" })
).src;

// Shared-entity JSON-LD: the page is authored by a named person and published by the SAME
// foundation node the landing/o-nas graphs declare (#foundation), so this reads as one
// entity's colophon — clean E-E-A-T signal for a young nonprofit.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  url: "https://voctensemble.com/kolofon",
  description,
  inLanguage: "pl-PL",
  author: {
    "@type": "Person",
    name: "Krystian Bugalski",
    email: "krystbugalski@gmail.com",
  },
  publisher: {
    "@type": "NGO",
    "@id": "https://voctensemble.com/#foundation",
    name: "VoctFoundation",
  },
};
---

<BaseLayout
  title={title}
  description={description}
  path="/kolofon"
  image={ogImage}
  bodyClass="page-kolofon"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <a class="skip-link" href="#tresc">Przejdź do treści</a>
  <SiteChrome current="/kolofon" tone="dark" />

  <main id="tresc">
    {/* ── Hero: small, dark, restrained ───────────────────────────────────── */}
    <section class="kol-hero" aria-label="Kolofon">
      <div class="kol-hero-inner">
        <p class="kol-eyebrow micro reveal">
          <span class="lat">Colophon</span>
          <span class="kol-dot" aria-hidden="true">·</span>
          <span>Pieczęć rzemiosła</span>
        </p>
        <h1 class="kol-title reveal" data-d="1">Kolofon.</h1>
        <p class="kol-lede reveal" data-d="2">
          Krótka inskrypcja na końcu książki, w&nbsp;której drukarz zapisywał miejsce
          i&nbsp;czas oraz to, kto rzecz wydał. Tu robimy to samo — w&nbsp;swoim rzemiośle.
        </p>
      </div>
    </section>

    {/* ── Sigil — per-visit deterministic SVG ─────────────────────────────── */}
    <section class="kol-band kol-band-deep kol-seal" aria-labelledby="kol-h-sigil">
      <div class="kol-wrap kol-narrow">
        <h2 id="kol-h-sigil" class="kol-section-label micro reveal">
          <span class="lat">Sigillum</span>
          <span class="kol-dot" aria-hidden="true">·</span>
          <span>Pieczęć wizyty</span>
        </h2>
        <figure class="kol-seal-figure reveal" data-d="1">
          <div class="kol-seal-mount" data-sigil-mount role="img" aria-label="Pieczęć Twojej wizyty">
            {/* Client-side fallback: an anchor circle so the layout never collapses
                if JS is unavailable. The sigil script replaces innerHTML. */}
            <svg viewBox="0 0 220 220" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" fill="none">
              <circle cx="110" cy="110" r="92" stroke-width="0.6" stroke-opacity="0.4" />
              <circle cx="110" cy="110" r="2" fill="currentColor" stroke="none" />
            </svg>
          </div>
          <figcaption class="kol-seal-caption micro">
            ta&nbsp;sama, póki tu&nbsp;jesteś · nowa, gdy&nbsp;wrócisz · niczego nie&nbsp;zapisujemy
          </figcaption>
        </figure>
      </div>
    </section>

    {/* ── Konstrukcja — build philosophy + tooling ────────────────────────── */}
    <section class="kol-band kol-band-soft" aria-labelledby="kol-h-constructio">
      <div class="kol-wrap">
        <h2 id="kol-h-constructio" class="kol-section-label micro reveal">
          <span class="lat">Constructio</span>
          <span class="kol-dot" aria-hidden="true">·</span>
          <span>Konstrukcja</span>
        </h2>
        <p class="kol-lead reveal" data-d="1">
          Strona zbudowana w&nbsp;Astro — statyczny HTML, a&nbsp;wyspy Reacta wchodzą tylko
          tam, gdzie potrzebny jest stan po&nbsp;stronie klienta. CSS pisany ręcznie, osobno
          dla każdej strony — bliżej rzemiosła niż biblioteki komponentów.
        </p>
        <dl class="kol-defs reveal" data-d="2">
          <div class="kol-def">
            <dt>Framework</dt>
            <dd>Astro · statyczny HTML + hydratowane wyspy Reacta</dd>
          </div>
          <div class="kol-def">
            <dt>Płynność scrolla</dt>
            <dd>Lenis · hostowany z&nbsp;naszej domeny</dd>
          </div>
          <div class="kol-def">
            <dt>Animacja</dt>
            <dd>CSS, fonty wariacyjne i&nbsp;IntersectionObserver</dd>
          </div>
          <div class="kol-def">
            <dt>Dane</dt>
            <dd>Astro Content Collections · YAML z&nbsp;walidacją Zod</dd>
          </div>
          <div class="kol-def">
            <dt>Obrazy</dt>
            <dd>AVIF i&nbsp;WebP w&nbsp;wielu rozmiarach, generowane przy budowaniu</dd>
          </div>
          <div class="kol-def">
            <dt>Pomiar</dt>
            <dd>Plausible · anonimowo, bez&nbsp;cookies, serwery w&nbsp;UE</dd>
          </div>
          <div class="kol-def">
            <dt>Prywatność</dt>
            <dd>poza Plausible strona nie sięga po&nbsp;zewnętrzny kod — bez Google Analytics i&nbsp;piksela Meta</dd>
          </div>
        </dl>
      </div>
    </section>

    {/* ── Typi — typeface credits ─────────────────────────────────────────── */}
    <section class="kol-band kol-band-soft kol-band-rule-top" aria-labelledby="kol-h-typi">
      <div class="kol-wrap">
        <h2 id="kol-h-typi" class="kol-section-label micro reveal">
          <span class="lat">Typi</span>
          <span class="kol-dot" aria-hidden="true">·</span>
          <span>Kroje pisma</span>
        </h2>
        <ul class="kol-fonts reveal" data-d="1">
          <li class="kol-font kol-font--cormorant" tabindex="0">
            <span class="kol-font-sample">Cormorant Garamond</span>
            <span class="kol-font-meta micro">Christian Thalmann · garaldyckie pismo do oddychania</span>
          </li>
          <li class="kol-font kol-font--inter" tabindex="0">
            <span class="kol-font-sample">Inter</span>
            <span class="kol-font-meta micro">Rasmus Andersson · sans-serif do czytania</span>
          </li>
          <li class="kol-font kol-font--plex" tabindex="0">
            <span class="kol-font-sample">IBM Plex Mono</span>
            <span class="kol-font-meta micro">Bold Monday dla IBM · monospace na meta i&nbsp;daty</span>
          </li>
        </ul>
        <p class="kol-license micro reveal" data-d="2">
          Wszystkie trzy na&nbsp;licencji SIL Open Font License · hostowane z&nbsp;naszej domeny jako woff2
        </p>
      </div>
    </section>

    {/* ── Fundatio — foundation legal ─────────────────────────────────────── */}
    <section class="kol-band kol-band-soft kol-band-rule-top" aria-labelledby="kol-h-fundatio">
      <div class="kol-wrap">
        <h2 id="kol-h-fundatio" class="kol-section-label micro reveal">
          <span class="lat">Fundatio</span>
          <span class="kol-dot" aria-hidden="true">·</span>
          <span>Fundacja</span>
        </h2>
        <p class="kol-lead kol-lead-tight reveal" data-d="1">
          Fundacja VoctFoundation działa w&nbsp;obszarze kultury, sztuki oraz ochrony
          dziedzictwa; VoctEnsemble jest jej zespołem-rezydentem. Dochód przeznaczamy
          w&nbsp;całości na&nbsp;cele statutowe.
        </p>
        <dl class="kol-defs kol-defs-tight reveal" data-d="2">
          <div class="kol-def">
            <dt>Siedziba</dt>
            <dd>ul.&nbsp;Św.&nbsp;Filipa 23/3 · 31-150 Kraków</dd>
          </div>
          <div class="kol-def">
            <dt>KRS</dt>
            <dd>0001237252</dd>
          </div>
          <div class="kol-def">
            <dt>NIP</dt>
            <dd>6762718992</dd>
          </div>
          <div class="kol-def">
            <dt>REGON</dt>
            <dd>544621525</dd>
          </div>
          <div class="kol-def">
            <dt>Zarząd</dt>
            <dd>Florent de Bazelaire · Anna Marcisz · Krystian Bugalski</dd>
          </div>
          <div class="kol-def">
            <dt>Statut</dt>
            <dd>
              <a href="/docs/Statut-VoctFoundation.pdf" target="_blank" rel="noopener" class="kol-link">
                Statut Fundacji VoctFoundation (PDF) <span aria-hidden="true">↗</span>
              </a>
            </dd>
          </div>
          <div class="kol-def">
            <dt>Polityka</dt>
            <dd>
              <a href="/polityka-prywatnosci" class="kol-link">Polityka prywatności</a>
            </dd>
          </div>
        </dl>
      </div>
    </section>

    {/* ── Auctor — author block ───────────────────────────────────────────── */}
    <section class="kol-band kol-band-soft kol-band-rule-top" aria-labelledby="kol-h-auctor">
      <div class="kol-wrap">
        <h2 id="kol-h-auctor" class="kol-section-label micro reveal">
          <span class="lat">Auctor</span>
          <span class="kol-dot" aria-hidden="true">·</span>
          <span>Autor</span>
        </h2>
        <p class="kol-author-name reveal" data-d="1">Krystian Bugalski</p>
        <p class="kol-author-role reveal" data-d="1">projekt · kod · obecność cyfrowa</p>
        <p class="kol-author-contact reveal" data-d="2">
          <a href="mailto:krystbugalski@gmail.com" rel="author" class="kol-link">
            krystbugalski@gmail.com <span aria-hidden="true">↗</span>
          </a>
        </p>
      </div>
    </section>

    {/* ── Gratiarum actio — factual credits for past concerts (not personal endorsements) ─── */}
    <section class="kol-band kol-band-soft kol-band-rule-top kol-gratia" aria-labelledby="kol-h-gratia">
      <div class="kol-wrap">
        <h2 id="kol-h-gratia" class="kol-section-label micro reveal">
          <span class="lat">Gratiarum actio</span>
          <span class="kol-dot" aria-hidden="true">·</span>
          <span>Podziękowania</span>
        </h2>
        <p class="kol-lead kol-lead-tight reveal" data-d="1">
          Twórczynie i&nbsp;twórcy, których praca składała się na&nbsp;kolejne koncerty cyklu
          — credits z&nbsp;plakatów i&nbsp;programów, ułożone tu&nbsp;jako wpis archiwalny.
        </p>
        <ul class="kol-collab reveal" data-d="2">
          <li>
            <span class="kol-collab-name">Jakub Garbacz · Ars Sonora Studio</span>
            <span class="kol-collab-role micro">realizacja nagrań · Kontemplacja Wcielenia, 2024</span>
          </li>
          <li>
            <span class="kol-collab-name">Ada Bystrzycka · Multiscena</span>
            <span class="kol-collab-role micro">reżyseria świateł · wybrane koncerty 2024–2025</span>
          </li>
          <li>
            <span class="kol-collab-name">Sebastian Kuźma · ART Agencja Rzemieślników Teatralnych</span>
            <span class="kol-collab-role micro">animacja wizualna · wybrane koncerty 2024–2025</span>
          </li>
          <li>
            <span class="kol-collab-name">Radu Ropotan</span>
            <span class="kol-collab-role micro">skrzypce · Wołanie Gór, 2024</span>
          </li>
          <li>
            <span class="kol-collab-name">Krzysztof Michałek · Michał Piechnik</span>
            <span class="kol-collab-role micro">organy · Hymn Poległym, 2025</span>
          </li>
          <li>
            <span class="kol-collab-name">Fundacja Carpe Diem · Ośrodek Kultury Norwida</span>
            <span class="kol-collab-role micro">współorganizacja · wybrane wydarzenia</span>
          </li>
        </ul>
        <p class="kol-close micro reveal">Cracoviae · MMXXVI · Laus&nbsp;Deo</p>
      </div>
    </section>
  </main>

  <SiteFooter />

  <VaultIsland client:idle />
  <script>
    import "../scripts/vault-triggers.ts";
    import { buildSigilSvg, getOrCreateVisitSeed } from "../lib/sigil";

    // Redraw on every page-load, not just once: the sigil script is a module that runs once
    // on first import, but a ClientRouter return to /kolofon swaps in fresh SSR markup (the
    // bare fallback circle) without re-running module top-level code. Binding to
    // `astro:page-load` (fires on initial load AND after each view-transition swap) keeps the
    // seal present on return. Guarded on the mount element — a no-op on every other page.
    const drawSigil = () => {
      const mount = document.querySelector<HTMLElement>("[data-sigil-mount]");
      if (!mount) return;
      mount.innerHTML = buildSigilSvg(getOrCreateVisitSeed(), { size: 220 });
    };
    document.addEventListener("astro:page-load", drawSigil);
  </script>
</BaseLayout>

<style>
  /* Colophon runs darker ink than the body default (--ink-soft); background comes from base.css. */
  .page-kolofon { color: var(--ink); }

  /* Hero */
  .kol-hero { background: var(--dark); color: var(--paper); padding: clamp(120px, 16vw, 200px) var(--gutter) clamp(64px, 9vw, 100px); }
  .kol-hero-inner { max-width: 760px; margin: 0 auto; }
  .kol-eyebrow { display: inline-flex; align-items: center; gap: 10px; font-family: var(--mono); font-size: 11px; letter-spacing: .26em; text-transform: uppercase; color: rgba(244, 241, 233, .68); margin: 0 0 28px; }
  .kol-eyebrow .lat { font-family: var(--serif); font-style: italic; text-transform: none; letter-spacing: 0; font-size: 16px; color: var(--candle); }
  .kol-title { font-family: var(--serif); font-weight: 300; line-height: .95; font-size: clamp(56px, 8vw, 120px); letter-spacing: -.01em; margin: 0; color: var(--paper); }
  .kol-lede { margin: clamp(28px, 4vw, 44px) 0 0; font-family: var(--serif); font-style: italic; font-weight: 300; font-size: clamp(18px, 1.8vw, 24px); line-height: 1.5; color: rgba(244, 241, 233, .82); max-width: 50ch; }
  .kol-dot { color: rgba(244, 241, 233, .42); }

  /* Bands */
  .kol-band { padding: clamp(72px, 11vw, 140px) var(--gutter); position: relative; }
  .kol-band-soft { background: var(--paper); color: var(--ink); }
  .kol-band-deep { background: var(--dark); color: var(--paper); }
  .kol-band-rule-top { padding-top: clamp(48px, 7vw, 84px); }
  .kol-band-rule-top::before { content: ""; display: block; width: 60px; height: 1px; background: var(--line); margin-bottom: clamp(48px, 7vw, 84px); }
  .kol-wrap { max-width: 1180px; margin: 0 auto; }
  .kol-narrow { max-width: 760px; margin: 0 auto; }

  /* Section labels are the document's real h2s, styled as quiet Latin·Polish rubrics. */
  .kol-section-label { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 10.5px; font-weight: 400; letter-spacing: .26em; text-transform: uppercase; color: var(--candle); margin: 0 0 28px; }
  .kol-section-label .lat { font-family: var(--serif); font-style: italic; text-transform: none; letter-spacing: 0; font-size: 14px; }

  /* Sigil */
  .kol-seal { padding-bottom: clamp(72px, 11vw, 140px); }
  .kol-seal-figure { display: flex; flex-direction: column; align-items: center; gap: 28px; margin: 36px 0 0; color: var(--candle); }
  .kol-seal-mount { width: 220px; height: 220px; display: block; }
  .kol-seal-mount :global(svg) { width: 100%; height: 100%; display: block; }
  .kol-seal-caption { max-width: 42ch; text-align: center; color: rgba(244, 241, 233, .56); }

  /* Body lead + definition lists */
  .kol-lead { font-family: var(--serif); font-style: italic; font-weight: 300; font-size: clamp(20px, 2.2vw, 28px); line-height: 1.5; color: var(--ink); max-width: 30ch; margin: 0 0 clamp(40px, 5vw, 56px); letter-spacing: -.005em; }
  .kol-lead-tight { font-size: clamp(18px, 1.8vw, 22px); line-height: 1.6; max-width: 38ch; }

  .kol-defs { display: grid; grid-template-columns: repeat(2, 1fr); gap: clamp(20px, 3vw, 32px) clamp(28px, 4vw, 56px); margin: 0; padding: 0; max-width: 880px; }
  .kol-defs-tight { gap: clamp(16px, 2vw, 24px) clamp(28px, 4vw, 56px); }
  .kol-def { display: grid; grid-template-columns: max-content 1fr; gap: clamp(16px, 2vw, 28px); align-items: baseline; padding-top: 14px; border-top: 1px solid var(--line); }
  .kol-def dt { font-family: var(--mono); font-size: 10.5px; letter-spacing: .22em; text-transform: uppercase; color: var(--ink-muted); margin: 0; min-width: 88px; }
  .kol-def dd { margin: 0; font-family: var(--serif); font-size: clamp(15px, 1.3vw, 18px); line-height: 1.5; color: var(--ink); }

  /* Fonts list — hover/focus demonstrates each typeface on the axes it actually ships:
     Cormorant is a variable weight axis (its signature); Inter ships as a variable weight
     face; Plex ships as two static weights (300/400), so its demo snaps between the real
     faces and shifts tracking rather than pretending to a weight axis it doesn't have. */
  .kol-fonts { list-style: none; margin: 0; padding: 0; display: grid; gap: clamp(28px, 4vw, 44px); max-width: 760px; }
  .kol-fonts li.kol-font {
    display: grid;
    gap: 6px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
    cursor: default;
    outline: none;
  }
  .kol-fonts li.kol-font:focus-visible { outline: 1px solid var(--candle); outline-offset: 6px; border-radius: 2px; }

  .kol-font-sample {
    display: inline-block;
    font-size: clamp(28px, 3.4vw, 44px);
    line-height: 1.1;
    color: var(--ink);
    transition:
      font-variation-settings 1.1s var(--ease-slow, ease),
      font-weight 1.1s var(--ease-slow, ease),
      letter-spacing 1.1s var(--ease-slow, ease),
      font-style 0.5s var(--ease, ease);
  }
  .kol-font-meta { color: var(--ink-muted); transition: color 0.5s var(--ease, ease); }
  .kol-font:hover .kol-font-meta,
  .kol-font:focus-visible .kol-font-meta { color: var(--candle); }

  /* Cormorant Garamond — italic axis is its signature, weight breathes wider on attention */
  .kol-font--cormorant .kol-font-sample {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-variation-settings: "wght" 320;
    letter-spacing: -0.005em;
  }
  .kol-font--cormorant:hover .kol-font-sample,
  .kol-font--cormorant:focus-visible .kol-font-sample {
    font-variation-settings: "wght" 560;
    letter-spacing: 0.008em;
  }

  /* Inter — variable weight; on attention the wide weight range opens up with a touch of tracking */
  .kol-font--inter .kol-font-sample {
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 320;
    letter-spacing: -0.01em;
  }
  .kol-font--inter:hover .kol-font-sample,
  .kol-font--inter:focus-visible .kol-font-sample {
    font-weight: 620;
    letter-spacing: 0.005em;
  }

  /* IBM Plex Mono — two shipped static weights (300 → 400) + tracking; the grid stays fixed */
  .kol-font--plex .kol-font-sample {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-weight: 300;
    letter-spacing: 0;
  }
  .kol-font--plex:hover .kol-font-sample,
  .kol-font--plex:focus-visible .kol-font-sample {
    font-weight: 400;
    letter-spacing: 0.05em;
  }

  .kol-license { color: var(--ink-muted); margin: clamp(28px, 4vw, 40px) 0 0; max-width: 60ch; }

  @media (prefers-reduced-motion: reduce) {
    .kol-font-sample { transition: none; }
  }

  /* Author block */
  .kol-author-name { font-family: var(--serif); font-weight: 300; font-size: clamp(36px, 5vw, 60px); line-height: 1.05; letter-spacing: -.01em; color: var(--ink); margin: 0; }
  .kol-author-role { margin: 12px 0 0; font-family: var(--mono); font-size: 11.5px; letter-spacing: .22em; text-transform: uppercase; color: var(--candle); }
  .kol-author-contact { margin: clamp(20px, 3vw, 28px) 0 0; font-family: var(--serif); font-size: clamp(18px, 1.6vw, 22px); color: var(--ink); }

  /* Collaborators */
  .kol-collab { list-style: none; margin: 0 0 clamp(36px, 5vw, 56px); padding: 0; display: grid; gap: clamp(14px, 2vw, 20px); max-width: 760px; }
  .kol-collab li { display: grid; grid-template-columns: 1fr max-content; gap: 16px; padding-top: 12px; border-top: 1px solid var(--line); align-items: baseline; }
  .kol-collab-name { font-family: var(--serif); font-size: clamp(18px, 1.8vw, 22px); color: var(--ink); }
  .kol-collab-role { color: var(--ink-muted); text-align: right; }
  .kol-close { color: var(--ink-muted); margin: 0; letter-spacing: .26em; }

  /* Links */
  .kol-link { color: var(--ink); border-bottom: 1px solid var(--line-strong); padding-bottom: 1px; transition: color .3s var(--ease, ease), border-color .3s var(--ease, ease); }
