---
/**
 * @file koncerty.astro
 * @description Public concerts page (/koncerty). Dark full-bleed stations rendered from the
 *  `concerts` collection, then — stepping out of the night nave into parchment light — the
 *  "Reguły wieczoru" rite section and the seven-century repertoire catalog. Stations/repertoire
 *  are DATA (src/content/*.yaml) — the team edits YAML, not markup. Program lists use native
 *  <details> (zero JS); the Via rail + chrome light/dark tone are driven by IntersectionObservers
 *  (page-scoped).
 * @architecture Astro islands 2026
 * @module pages/koncerty
 */
import { getCollection } from "astro:content";
import { getImage, Picture } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteChrome from "../components/SiteChrome.astro";
import SiteFooter from "../components/SiteFooter.astro";
import BleedImage from "../components/BleedImage.astro";
import { photo, bleedPair } from "../lib/photos";
import { VaultIsland } from "../islands/landing/VaultIsland";
import "../styles/vault.css";

const title = "Koncerty Duchowe — VoctEnsemble";
// Count-free on purpose: the old "Sześć programów…" became a lie the moment a seventh
// concert lands. The "od … po …" framing stays hand-written so it reads natively in Polish.
const description =
  "Programy cyklu Koncerty Duchowe VoctEnsemble — od Kontemplacji Wcielenia po liturgię św. Andrzeja Boboli — oraz repertuar siedmiu wieków muzyki sakralnej.";

const hero = bleedPair("koncerty-hero");

const concerts = (await getCollection("concerts")).sort((a, b) => a.data.order - b.data.order);
const stationCount = concerts.length;
const stations = concerts.map((c, i) => ({
  ...c.data,
  id: c.id,
  // Via-rail fill is derived from position, not stored per-entry: adding a concert
  // no longer means re-percentaging every other YAML row by hand.
  viaStep: `${Math.round(((i + 1) / stationCount) * 100)}%`,
  // Station backdrops are PRE-BLURRED + pre-darkened WebP files in src/assets/photos,
  // named after the concert's `bg`. Blurring offline means the browser runs ZERO filter
  // passes on six full-bleed layers (the old runtime blur was the jank). Astro emits them
  // as content-hashed asset URLs. Recipe to regenerate them: docs/station-backgrounds.md.
  bgSrc: photo(c.data.bg).src,
  posterImg: c.data.poster ? photo(c.data.poster) : null,
}));

const eras = (await getCollection("repertoire")).sort((a, b) => a.data.order - b.data.order);

// The four recurring rules of a Concert Duchowy — documented practice from the ensemble's
// own programme books, not an invented framework: the Jesuit introduction, the "kolejność
// jest bardzo ważna" note, the printed request for silence, Ada Bystrzycka's light direction.
const rites = [
  { n: "01", h: "Słowo", p: "Zanim wejdzie muzyka, ktoś nazywa intencję wieczoru. Każdy koncert poprzedza krótkie wprowadzenie — najczęściej jezuity, jak o. Jarek Naliwajko czy o. Przemysław Wysogląd." },
  { n: "02", h: "Porządek", p: "Kolejność utworów jest częścią kompozycji. Przy każdym programie w notatkach zespołu wraca ten sam dopisek: «kolejność jest bardzo ważna»." },
  { n: "03", h: "Cisza", p: "Między utworami zostaje cisza — prosimy o nią wprost. Cisza po ostatnim akordzie też należy do muzyki." },
  { n: "04", h: "Światło", p: "Światło jest częścią wykonania. Subtelna reżyseria — nad wieloma wieczorami czuwała Ada Bystrzycka — prowadzi wzrok tak, jak akustyka nawy prowadzi dźwięk." },
];

// Roman numeral for the still-unwritten station (Nondum) — computed, not a fixed lookup
// table, so the sequence keeps going no matter how many concerts eventually land.
const toRoman = (n: number): string => {
  const table: readonly (readonly [number, string])[] = [
    [10, "X"], [9, "IX"], [5, "V"], [4, "IV"], [1, "I"],
  ];
  let out = "";
  let rem = n;
  for (const [value, sym] of table) {
    while (rem >= value) {
      out += sym;
      rem -= value;
    }
  }
  return out;
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Koncerty Duchowe — VoctEnsemble",
  itemListElement: stations.map((s, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "MusicEvent",
      name: s.title,
      // startDate only when a real day is known — vague YAML dates ("2024", "jesień
      // 2025") stay out rather than emit an invalid schema.org date.
      ...(s.date ? { startDate: s.date } : {}),
      eventStatus: "https://schema.org/EventCompleted",
      eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
      location: { "@type": "Place", name: s.venue ?? s.meta },
      performer: { "@type": "MusicGroup", name: "VoctEnsemble" },
      ...(s.hasPage ? { url: `https://voctensemble.com/koncerty/${s.id}` } : {}),
    },
  })),
};

const ogImage = (await getImage({ src: hero.desktop, width: 1200, format: "webp" })).src;
---

<BaseLayout title={title} description={description} path="/koncerty" image={ogImage} bodyClass="page-koncerty">
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <a class="skip-link" href="#tresc">Przejdź do treści</a>
  <SiteChrome current="/koncerty" tone="dark" />

  <aside class="via-rail" aria-hidden="true">
    <span class="via-num">I</span>
    <span class="via-line"><span class="via-fill"></span></span>
    <span class="via-date">sty 2024</span>
  </aside>

  <main id="tresc">
    {/* ── Intro hero ───────────────────────────────────────────────────── */}
    <section class="intro" aria-label="Koncerty Duchowe">
      <div class="intro-media" aria-hidden="true">
        <BleedImage desktop={hero.desktop} mobile={hero.mobile} alt="" position="center 38%" eager animate />
      </div>
      <div class="intro-inner">
        <p class="eyebrow reveal"><span class="lat">Via</span>  ·  Droga koncertów</p>
        <h1>
          <span class="line"><span class="reveal">Koncerty</span></span>
          <span class="line"><span class="reveal" data-d="1"><em>Duchowe.</em></span></span>
        </h1>
        <p class="intro-lede reveal" data-d="2">
          Zapis kolejnych intencji cyklu — od Wcielenia, przez góry, psalmy, pamięć
          i lament, po liturgię.
        </p>
        <p class="intro-note reveal" data-d="3">
          Każdy wieczór ma osobną intencję. To współczesna forma dawnych
          <em>Concerts Spirituels</em> — przejdź je po kolei, w stronę tego,
          który jeszcze się nie wydarzył.
        </p>
        <span class="scroll-cue reveal" data-d="4">Wejdź na drogę</span>
      </div>
    </section>

    {/* ── Stations (from the `concerts` collection) ────────────────────── */}
    {
      stations.map((s) => (
        <section
          class:list={[
            "station",
            { reverse: s.reverse, "station--memoriam": s.variant === "memoriam", "station--liturgy": s.variant === "liturgy" },
          ]}
          aria-label={s.title}
          data-via-num={s.roman}
          data-via-date={s.viaDate}
          data-via-step={s.viaStep}
          style={`--accent:${s.accent}`}
        >
          <div
            class="station-bg"
            aria-hidden="true"
            style={`--bg:url('${s.bgSrc}')`}
            data-parallax="0.4"
          />
          {/* The accent light is its OWN plane — it drifts about half as fast as the stone
              behind it (0.10 vs 0.22), so light and masonry separate on scroll instead of
              moving as one photograph. Reuses the global [data-parallax] controller; the
              scale path keeps its resting position identical to the old static glow. */}
          <div
            class="station-light"
            aria-hidden="true"
            data-parallax="0.2"
            data-parallax-scale="1.3"
          />

          {s.variant === "liturgy" ? (
            <div class="station-inner">
              <div class="station-text station-plate reveal">
                <span class="station-glyph" aria-hidden="true" />
                <p class="station-num">Obraz {s.roman} &nbsp;·&nbsp; {s.latin}</p>
                <h2 class="station-title">{s.title}</h2>
                <p class="station-meta">{s.meta}</p>
                <p class="station-essence">{s.essence}</p>
                {s.facts.length > 0 && (
                  <div class="station-facts" aria-label="Cechy liturgii">
                    {s.facts.map((f) => (
                      <span>{f}</span>
                    ))}
                  </div>
                )}
                {s.links.length > 0 && (
                  <div class="station-actions">
                    {s.links.map((l) => (
                      <a class="link-min" href={l.href} target="_blank" rel="noopener noreferrer">
                        {l.label}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ) : (
            <div class="station-inner">
              {s.posterImg && (
                <figure class="station-poster reveal">
                  <span class="frame" aria-hidden="true" />
                  <Picture
                    src={s.posterImg}
                    formats={["avif", "webp"]}
                    widths={[280, 420, 560]}
                    sizes="(max-width: 820px) 72vw, 348px"
                    alt={s.posterAlt ?? ""}
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              )}
              <div class="station-text">
                <p class="station-num reveal">Obraz {s.roman} &nbsp;·&nbsp; {s.latin}</p>
                <h2 class="station-title reveal" data-d="1">{s.title}</h2>
                <p class="station-meta reveal" data-d="1">{s.meta}</p>
                <p class="station-essence reveal" data-d="2">{s.essence}</p>
                {s.inscriptio && (
                  <p class="station-inscriptio reveal" data-d="2" aria-label="Incipit programu">
                    <em class="station-inscriptio-src">{s.inscriptio}</em>
                    {s.inscriptioPl && <span class="station-inscriptio-pl">{s.inscriptioPl}</span>}
                    {s.inscriptioRef && <span class="station-inscriptio-ref">{s.inscriptioRef}</span>}
                  </p>
                )}
                {s.facts.length > 0 && (
                  <div class="station-facts reveal" data-d="2" aria-label="Cechy programu">
                    {s.facts.map((f) => (
                      <span>{f}</span>
                    ))}
                  </div>
                )}
                {(s.hasPage || s.spotify || s.realizacja || s.links.length > 0) && (
                  <div class="station-actions reveal" data-d="3">
                    {s.hasPage && (
                      <a class="pill" href={`/koncerty/${s.id}`}>
                        Otwórz stronę koncertu →
                      </a>
                    )}
                    {s.spotify && (
                      <a class="pill" href={s.spotify} target="_blank" rel="noopener noreferrer">
                        ▸ Posłuchaj programu
                      </a>
                    )}
                    {s.realizacja && <span class="station-credit">{s.realizacja}</span>}
                    {s.links.map((l) => (
                      <a class="link-min" href={l.href} target="_blank" rel="noopener noreferrer">
                        {l.label}
                      </a>
                    ))}
                  </div>
                )}
                {s.program.length > 0 && (
                  <details class="prog-d reveal" data-d="3">
                    <summary>
                      Program koncertu <span class="chev" aria-hidden="true">↓</span>
                    </summary>
                    <div class="station-program">
                      <ul class="prog-list">
                        {s.program.map((p, i) => (
                          <li class:list={[{ bis: p.bis }]}>
                            <span class="prog-n" aria-hidden="true">{p.bis ? "—" : String(i + 1).padStart(2, "0")}</span>
                            <span class="pc">{p.composer}</span> — {p.work}
                          </li>
                        ))}
                      </ul>
                    </div>
                  </details>
                )}
              </div>
            </div>
          )}
        </section>
      ))
    }

    {/* ── The unwritten station — the Via's payoff. Not a `.station` (the via-rail
          observer only tracks walked concerts); a threshold, not a memory. "No fake
          upcoming concert" holds: we promise nothing but say plainly the next one
          waits on patrons. Numeral continues the sequence. ──────────────── */}
    <section class="station-next" aria-label="Następny Koncert Duchowy">
      <div class="station-next-inner reveal">
        <span class="station-next-glyph" aria-hidden="true"></span>
        <p class="station-num">{toRoman(stationCount + 1)} &nbsp;·&nbsp; <span class="lat">Nondum</span></p>
        <h2 class="station-title">Następne wybrzmienie.</h2>
        <p class="station-meta">Termin i przestrzeń wyznaczą darczyńcy</p>
        <p class="station-essence">
          Ten koncert istnieje już w partyturach i próbach — brakuje mu tylko przestrzeni,
          w której wybrzmi. Każda darowizna przybliża jego datę.
        </p>
        <div class="station-actions">
          <a class="pill pill-gold" href="/?donate" data-vault-open="100">Pomóż mu wybrzmieć →</a>
        </div>
      </div>
    </section>

    {/* ── The evening's four rules — the method behind the walk, read AFTER it (like a
          programme-book essay). Parchment: the page steps out of the night nave into
          light, the same arc a listener walks — enters from the street, leaves quieter.
          Documented practice, not an invented framework (see the `rites` const). ─────── */}
    <section class="rite-map tone-light" aria-label="Reguły wieczoru">
      <div class="rite-wrap">
        <div class="rite-head reveal">
          <span class="eyebrow"><span class="lat">Concert spirituel</span>  ·  Reguły wieczoru</span>
          <h2>Każdy wieczór prowadzą te same cztery reguły.</h2>
          <p>
            Gdy w XVIII-wiecznym Paryżu na czas świąt milkła opera, w sali pałacu Tuileries
            grano <em>Concerts Spirituels</em> — muzykę sakralną poza ramą nabożeństwa.
            Wracamy do tej tradycji, a każdy nasz program trzyma się czterech powtarzalnych
            reguł.
          </p>
        </div>
        <div class="rite-grid">
          {
            rites.map((r, i) => (
              <article class="rite-card reveal" data-d={String((i % 3) + 1)}>
                <span class="r-num">{r.n}</span>
                <h3>{r.h}</h3>
                <p>{r.p}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    {/* ── Repertoire (from the `repertoire` collection) ────────────────── */}
    <section class="repertoire tone-light" id="repertuar" aria-label="Repertuar VoctEnsemble">
      <div class="rep-wrap">
        <div class="rep-head reveal">
          <span class="eyebrow"><span class="lat">Repertorium</span>  ·  Siedem wieków</span>
          <h2>Repertuar, z którego budujemy programy.</h2>
          <p>
            Renesansowa polifonia, barok, romantyczna modlitwa i współczesny minimalizm
            spotykają się w jednym wieczorze. Liczy się napięcie między epokami — to z niego
            rodzi się program.
          </p>
        </div>

        {
          eras.map((era) => {
            // Two explicit column lists (not CSS `columns`): each list's :first-child is
            // deterministically the column top, so it can drop the hairline that would
            // otherwise double the era's own rule. Multicol balances by HEIGHT (entries run
            // 1–3 works), so its column-break index is unpredictable — a count-split is stable.
            const half = Math.ceil(era.data.entries.length / 2);
            const columns = [era.data.entries.slice(0, half), era.data.entries.slice(half)];
            return (
              <div class="rep-era">
                <div class="rep-era-head reveal">
                  <h3 class="rep-era-title">{era.data.title}</h3>
                  <span class="rep-era-span">{era.data.span}</span>
                </div>
                <div class="rep-cols">
                  {columns.map(
                    (col, ci) =>
                      col.length > 0 && (
                        <ul class:list={["rep-col", { "rep-col-2": ci === 1 }]}>
                          {col.map((entry, ei) => (
                            <li class="reveal rep-row" data-d={String((ei % 3) + 1)}>
                              <span class="composer">
                                {entry.composer}
                                {entry.years && <span class="years">{entry.years}</span>}
                              </span>
                              <span class="works">
                                {entry.works.map((w, i) => (
                                  <>
                                    {i > 0 && " · "}
                                    {w.title}
                                    {w.year && <span class="yr"> {w.year}</span>}
                                  </>
                                ))}
                              </span>
                            </li>
                          ))}
                        </ul>
                      ),
                  )}
                </div>
              </div>
            );
          })
        }

      </div>
    </section>

    {/* ── CTA ──────────────────────────────────────────────────────────── */}
    <section class="cta-band tone-light" aria-label="Zaproszenie">
      <div class="reveal">
        <h2>Śpiewaliśmy w bazylikach, katedrze i wiejskim kościele.</h2>
        <p>
          Bazyliki NSPJ i Mariacka w Krakowie, św. Antoniego w Rybniku, archikatedra w Łodzi,
          sanktuarium w Warszawie, dworek zdrojowy w Szczawnicy, kościół w Niedzicy — każda
          z tych przestrzeni układała program na nowo. Przygotujemy koncert duchowy, oprawę liturgii
          albo uroczystość na konkretne miejsce i okazję.
        </p>
        <div class="btn-row">
          <a class="btn btn-gold" href="/kontakt">Napisz do nas</a>
          <a class="btn" href="/o-nas">Poznaj zespół</a>
          <a class="btn" href="/?donate" data-vault-open="100">Wesprzyj fundację</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />

  <VaultIsland client:idle />
  <script>
    import "../scripts/vault-triggers.ts";
  </script>
</BaseLayout>

<style>
  :global(body.page-koncerty) { background: var(--night); color: var(--ink-soft); }

  /* Intro hero */
  .intro { position: relative; min-height: 100svh; display: flex; align-items: flex-end; padding: 0 max(28px, 5vw) clamp(64px, 9vw, 112px); color: var(--paper); overflow: hidden; isolation: isolate; }
  .intro-media { position: absolute; inset: 0; z-index: -2; }
  /* Photo keeps full brightness; text pocket (bottom-left) deepened via the diagonal (see o-nas). */
  .intro::after { content: ""; position: absolute; inset: 0; z-index: -1; background: linear-gradient(180deg, rgba(8,8,7,.5) 0%, rgba(8,8,7,.12) 38%, rgba(16,15,13,.84) 100%), linear-gradient(72deg, rgba(8,8,7,.76) 0%, rgba(8,8,7,.24) 46%, transparent 72%); }
  .intro-inner { max-width: 1180px; width: 100%; margin: 0 auto; }
  .intro h1 { font-family: var(--serif); font-weight: 300; line-height: .98; font-size: clamp(50px, 9vw, 130px); letter-spacing: -.01em; margin: 18px 0 0; }
  .intro h1 em { color: var(--candle); }
  .intro-lede { font-family: var(--serif); font-style: italic; font-weight: 300; font-size: clamp(19px, 2.2vw, 28px); line-height: 1.42; max-width: 34ch; margin: 24px 0 0; color: rgba(244,241,233,.9); }
  .intro-note { margin: 20px 0 0; font-family: var(--serif); font-weight: 300; font-size: clamp(18px, 1.8vw, 23px); line-height: 1.45; color: rgba(244,241,233,.7); max-width: 38ch; }
  .scroll-cue { margin-top: 38px; font-family: var(--mono); font-size: 10px; letter-spacing: .26em; text-transform: uppercase; color: rgba(244,241,233,.62); display: inline-flex; align-items: center; gap: 10px; }
  .scroll-cue::after { content: ""; width: 38px; height: 1px; background: currentColor; opacity: .6; animation: cuepulse 3.4s var(--ease-slow) infinite; }

  /* Stations */
  .station { position: relative; min-height: 100svh; display: flex; align-items: center; padding: clamp(96px,13vh,150px) max(28px,5vw) clamp(72px,10vh,110px); color: var(--paper); overflow: hidden; isolation: isolate; }
  /* Backdrops are pre-blurred + pre-darkened offline (src/assets/photos), so there is NO
     runtime `filter` here — a live blur() on six full-bleed layers was the jank. No
     `will-change`: the parallax controller sets a `translate3d` only while a station is near
     the viewport, so only visible layers get promoted; off-screen ones un-promote. */
  .station-bg { position: absolute; inset: -30% -5%; z-index: -2; background-image: var(--bg); background-size: cover; background-position: center; }
  .station::before { content: ""; position: absolute; inset: 0; z-index: -1; background: radial-gradient(120% 90% at 50% 42%, rgba(16,15,13,.2) 0%, rgba(16,15,13,.76) 100%); }
  /* Accent light — a real layer (not a pseudo) so the parallax controller can drift it as a
     separate plane from the stone. transform-origin pins the top-anchored shaft so the scale
     grows downward, not off the top edge; radius trimmed (54/40 vs 72/52) to offset the 1.3×
     scale so the on-screen glow stays the size it was. Rests exactly where the old ::after glow
     sat (scale path → base 0); under reduced motion the controller sets no transform at all, so
     it degrades to the same still glow. */
  .station-light { position: absolute; inset: 0; z-index: -1; pointer-events: none; mix-blend-mode: screen; opacity: .5; transform-origin: 50% top; background: radial-gradient(54% 40% at 50% 6%, color-mix(in srgb, var(--accent, var(--candle)) 34%, transparent) 0%, transparent 60%); }
  .station-inner { max-width: 1120px; width: 100%; margin: 0 auto; display: grid; grid-template-columns: clamp(220px, 26vw, 348px) 1fr; gap: clamp(36px,5vw,80px); align-items: center; }
  .station.reverse .station-inner { grid-template-columns: 1fr clamp(220px, 26vw, 348px); }
  .station.reverse .station-poster { order: 2; }
  .station-poster { position: relative; box-shadow: 0 40px 90px -30px rgba(0,0,0,.8); }
  .station-poster :global(picture) { display: block; }
  .station-poster :global(img) { width: 100%; height: auto; display: block; }
  .station-poster .frame { position: absolute; left: -10px; top: -10px; width: 40px; height: 40px; border-top: 1px solid var(--accent, var(--candle)); border-left: 1px solid var(--accent, var(--candle)); opacity: .8; z-index: 1; }
  .station-num { font-family: var(--serif); font-size: clamp(20px, 2vw, 28px); letter-spacing: .3em; color: var(--accent, var(--candle)); font-style: italic; }
  .station-title { font-family: var(--serif); font-weight: 300; line-height: 1.02; font-size: clamp(36px, 5.4vw, 76px); letter-spacing: -.01em; margin: 10px 0 0; color: var(--paper); }
  .station-meta { margin: 18px 0 0; font-family: var(--mono); font-size: 11px; letter-spacing: .2em; text-transform: uppercase; color: rgba(244,241,233,.66); }
  .station-essence { font-family: var(--serif); font-style: italic; font-size: clamp(19px, 2vw, 26px); line-height: 1.45; color: rgba(244,241,233,.92); margin: 22px 0 0; max-width: 42ch; }
  /* Incipit — the concert's first sung words, engraved under the essence. The source line
     (Latin / Ukrainian) reads in the accent; its translation + reference sit quieter below. */
  .station-inscriptio { margin: 22px 0 0; max-width: 42ch; padding-left: 16px; border-left: 1px solid color-mix(in srgb, var(--accent, var(--candle)) 45%, transparent); }
  .station-inscriptio-src { display: block; font-family: var(--serif); font-style: italic; font-size: clamp(16px, 1.6vw, 21px); line-height: 1.4; color: var(--accent, var(--candle)); }
  .station-inscriptio-pl { display: block; margin-top: 6px; font-family: var(--serif); font-size: clamp(14px, 1.2vw, 16px); line-height: 1.45; color: rgba(244,241,233,.64); }
  .station-inscriptio-ref { display: block; margin-top: 8px; font-family: var(--mono); font-size: 9.5px; letter-spacing: .2em; text-transform: uppercase; color: rgba(244,241,233,.44); }
  .station-actions { margin: 30px 0 0; display: flex; flex-wrap: wrap; gap: 14px 26px; align-items: center; }
  .station-facts { margin: 24px 0 0; display: flex; flex-wrap: wrap; gap: 10px; }
  .station-facts span { display: inline-flex; align-items: center; min-height: 32px; padding: 8px 12px; border: 1px solid rgba(244,241,233,.18); color: rgba(244,241,233,.68); font-family: var(--mono); font-size: 10.5px; letter-spacing: .14em; line-height: 1.35; text-transform: uppercase; }
  .pill { display: inline-flex; align-items: center; gap: 9px; font-family: var(--mono); font-size: 10.5px; letter-spacing: .16em; text-transform: uppercase; color: var(--paper); border: 1px solid rgba(244,241,233,.4); padding: 11px 18px; transition: background-color .4s var(--ease), border-color .4s var(--ease), color .4s var(--ease); }
  .pill:hover { background: var(--accent, var(--candle)); border-color: var(--accent, var(--candle)); color: var(--ink); }
  /* Filled by default (the Via's one call to give); hover inverts to hollow. */
  .pill-gold { background: var(--candle); border-color: var(--candle); color: var(--ink); }
  .pill-gold:hover { background: transparent; border-color: var(--candle); color: var(--candle); }
  .link-min { font-family: var(--mono); font-size: 10.5px; letter-spacing: .16em; text-transform: uppercase; color: rgba(244,241,233,.74); border-bottom: 1px solid rgba(244,241,233,.34); padding-bottom: 3px; transition: color .35s var(--ease), border-color .35s var(--ease); }
  .link-min:hover { color: var(--accent, var(--candle)); border-color: var(--accent, var(--candle)); }
  /* Production credit — a signature, not a link (no underline, no hover affordance). */
  .station-credit { font-family: var(--mono); font-size: 10.5px; letter-spacing: .16em; text-transform: uppercase; color: rgba(244,241,233,.5); }

  /* Program — native <details>, no JS */
  .prog-d { margin-top: 24px; }
  .prog-d summary { list-style: none; display: inline-flex; align-items: center; gap: 10px; font-family: var(--mono); font-size: 10.5px; letter-spacing: .16em; text-transform: uppercase; color: rgba(244,241,233,.72); cursor: pointer; transition: color .35s var(--ease); }
  .prog-d summary::-webkit-details-marker { display: none; }
  .prog-d summary:hover { color: var(--accent, var(--candle)); }
  .prog-d .chev { transition: transform .4s var(--ease); }
  .prog-d[open] .chev { transform: rotate(180deg); }
  .prog-list { list-style: none; margin: 0; padding: 22px 0 0; columns: 2; column-gap: 44px; }
  .prog-list li { break-inside: avoid; padding: 8px 0; font-size: 13.5px; line-height: 1.5; color: rgba(244,241,233,.78); border-top: 1px solid var(--paper-line, rgba(244,241,233,.16)); }
  .prog-list li .pc { font-family: var(--serif); font-style: italic; font-size: 1.15em; color: var(--paper); }
  /* Ordinal — the order is part of the work ("kolejność jest bardzo ważna"), so it shows. */
  .prog-list li .prog-n { font-family: var(--mono); font-size: 10px; letter-spacing: .08em; color: var(--accent, var(--candle)); margin-right: 10px; }
  .prog-list li.bis { color: var(--accent, var(--candle)); }
  @media (max-width: 620px) { .prog-list { columns: 1; } }
  @media (max-width: 820px) {
    .station-inner, .station.reverse .station-inner { grid-template-columns: 1fr; gap: 30px; }
    .station.reverse .station-poster { order: 0; }
    .station-poster { max-width: 280px; }
  }

  /* Liturgy station (no poster) */
  .station--liturgy .station-inner { grid-template-columns: 1fr; max-width: 880px; }
  .station-plate { border: 1px solid var(--paper-line, rgba(244,241,233,.16)); padding: clamp(28px,4vw,52px); background: rgba(244,241,233,.03); }
  .station-glyph { width: 26px; height: 60px; flex-shrink: 0; margin-bottom: 20px; background: linear-gradient(165deg, #e6d3a0 0%, #c6a45b 52%, #ad8a44 100%); -webkit-mask: url(/logo-mark.png) center / contain no-repeat; mask: url(/logo-mark.png) center / contain no-repeat; opacity: .8; }

  /* In memoriam (quieter, centered) */
  .station--memoriam .station-inner { grid-template-columns: 1fr; max-width: 720px; justify-items: center; text-align: center; gap: clamp(26px, 4vw, 40px); }
  .station--memoriam .station-poster { max-width: 224px; opacity: .8; }
  .station--memoriam .station-essence { margin-left: auto; margin-right: auto; }
  /* Centred memoriam: the incipit loses its left rule and centres like the essence. */
  .station--memoriam .station-inscriptio { margin-left: auto; margin-right: auto; padding-left: 0; border-left: 0; text-align: center; }
  .station--memoriam .station-facts { align-items: center; justify-content: center; }
  .station--memoriam .station-actions { justify-content: center; }
  /* memoriam backdrops (hymn, aeternam) are exported darker/desaturated offline — see
     docs/station-backgrounds.md — so no CSS filter override is needed here. */
  .station--memoriam .station-light { opacity: .3; }
  @media (max-width: 820px) { .station--memoriam .station-poster { max-width: 200px; } }

  /* The unwritten station — night, no photo (the rite doesn't market the next one by face),
     a faint gold aura where a backdrop would be. Reuses .station-num/-title/-meta/-essence. */
  .station-next { position: relative; min-height: 82svh; display: flex; align-items: center; justify-content: center; padding: clamp(96px,13vh,150px) max(28px,5vw); color: var(--paper); text-align: center; overflow: hidden; isolation: isolate; }
  .station-next::before { content: ""; position: absolute; inset: 0; z-index: -1; pointer-events: none; background: radial-gradient(78% 58% at 50% 30%, color-mix(in srgb, var(--candle) 13%, transparent) 0%, transparent 62%); }
  .station-next::after { content: ""; position: absolute; left: 0; right: 0; top: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(244,241,233,.16), transparent); }
  .station-next-inner { max-width: 660px; display: grid; justify-items: center; gap: 0; }
  .station-next-glyph { width: 26px; height: 60px; margin-bottom: 24px; background: linear-gradient(165deg, #e6d3a0 0%, #c6a45b 52%, #ad8a44 100%); -webkit-mask: url(/logo-mark.png) center / contain no-repeat; mask: url(/logo-mark.png) center / contain no-repeat; opacity: .85; }
  .station-next .station-num { margin: 0; }
  .station-next .station-num .lat { font-style: italic; }
  .station-next .station-title { margin: 14px 0 0; }
  .station-next .station-meta { margin: 18px 0 0; }
  .station-next .station-essence { margin: 22px auto 0; }
  .station-next .station-actions { margin: 34px 0 0; justify-content: center; }

  /* Via rail */
  .via-rail { position: fixed; left: max(16px, 2vw); top: 50%; transform: translateY(-50%); z-index: 45; width: 84px; display: flex; flex-direction: column; align-items: center; gap: 14px; opacity: 0; visibility: hidden; pointer-events: none; transition: opacity .7s var(--ease), visibility .7s var(--ease); }
  .via-rail.is-active { opacity: 1; visibility: visible; }
  .via-num { font-family: var(--serif); font-style: italic; font-size: 19px; line-height: 1; color: var(--candle); }
  .via-line { position: relative; width: 1px; height: 34vh; max-height: 300px; background: rgba(244,241,233,.16); overflow: hidden; }
  .via-fill { position: absolute; left: 0; top: 0; width: 100%; height: 0%; background: linear-gradient(180deg, var(--candle), rgba(198,164,91,.35)); transition: height .55s var(--ease-slow); }
  .via-date { font-family: var(--mono); font-size: 9px; letter-spacing: .12em; text-transform: uppercase; color: rgba(244,241,233,.58); white-space: nowrap; text-align: center; }
  @media (max-width: 980px) { .via-rail { display: none; } }
  @media (prefers-reduced-motion: reduce) { .via-fill { transition: none; } }

  /* Rite map (light) */
  .rite-map { background: var(--paper); color: var(--ink-soft); padding: clamp(84px, 12vw, 168px) max(28px,5vw); }
  .rite-wrap { max-width: 1120px; margin: 0 auto; }
  .rite-head { margin: 0 0 clamp(42px, 6vw, 76px); max-width: 760px; }
  .rite-head .eyebrow { display: block; margin-bottom: 20px; }
  .rite-head h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(38px, 5.6vw, 78px); line-height: 1.02; letter-spacing: -.01em; color: var(--ink); margin: 0; }
  .rite-head p { margin: 24px 0 0; max-width: 58ch; color: var(--ink-soft); font-size: clamp(16px, 1.25vw, 18px); }
  .rite-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(20px, 3vw, 42px); }
  .rite-card { display: grid; gap: 16px; padding-top: 24px; border-top: 1px solid var(--line-strong); }
  .rite-card .r-num { font-family: var(--mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--candle); }
  .rite-card h3 { margin: 0; font-family: var(--serif); font-weight: 300; font-size: clamp(24px, 2.5vw, 34px); line-height: 1.08; color: var(--ink); }
  .rite-card p { margin: 0; color: var(--ink-muted); font-size: clamp(14.5px, 1.1vw, 16px); line-height: 1.75; }
  @media (max-width: 980px) { .rite-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) { .rite-grid { grid-template-columns: 1fr; } }

  /* Repertoire (light) */
  .repertoire { background: var(--paper); color: var(--ink-soft); padding: clamp(84px,12vw,168px) max(28px,5vw); }
  .rep-wrap { max-width: 1120px; margin: 0 auto; }
  .rep-head { margin: 0 0 clamp(40px,6vw,72px); max-width: 640px; }
  .rep-head .eyebrow { display: block; margin-bottom: 20px; }
  .rep-head h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(36px,5.4vw,72px); line-height: 1.02; letter-spacing: -.01em; color: var(--ink); margin: 0 0 18px; }
  .rep-head p { color: var(--ink-soft); max-width: 56ch; }
  .rep-era { margin: 0 0 clamp(46px, 6vw, 84px); }
  .rep-era:last-of-type { margin-bottom: 0; }
  .rep-era-head { display: flex; align-items: baseline; gap: 16px; margin: 0 0 22px; padding-bottom: 14px; border-bottom: 1px solid var(--line-strong); }
  .rep-era-title { font-family: var(--serif); font-weight: 300; font-size: clamp(26px, 3.2vw, 40px); line-height: 1; letter-spacing: -.01em; color: var(--ink); margin: 0; }
  .rep-era-span { font-family: var(--mono); font-size: 10.5px; letter-spacing: .18em; text-transform: uppercase; color: var(--ink-muted); }
  .rep-cols { display: grid; grid-template-columns: 1fr 1fr; column-gap: clamp(40px,5vw,80px); align-items: start; }
  .rep-col { list-style: none; margin: 0; padding: 0; }
  .rep-col li { padding: 14px 0; border-top: 1px solid var(--line); }
  /* Column top: sits directly under the era's own rule — drop the redundant hairline. */
  .rep-col li:first-child { border-top: 0; padding-top: 0; }
  .rep-col .composer { font-family: var(--serif); font-size: clamp(19px,1.8vw,23px); color: var(--ink); font-weight: 400; }
  .rep-col .composer .years { font-size: .62em; color: var(--ink-muted); font-family: var(--mono); letter-spacing: .04em; margin-left: 8px; }
  .rep-col .works { display: block; margin-top: 4px; font-size: 14.5px; color: var(--ink-soft); }
  .rep-col .works .yr { color: var(--candle); font-family: var(--mono); font-size: .82em; }
  @media (max-width: 720px) {
    .rep-cols { grid-template-columns: 1fr; }
    /* Stacked into one column, so column 2 now follows column 1 — its top item needs its rule back. */
    .rep-col-2 li:first-child { border-top: 1px solid var(--line); padding-top: 14px; }
  }
  /* Per-work line reveal — lighter than the page-level .reveal: dense rows settle from a
     short drop with NO blur (a whole column of 6px-blur transitions was heavy and busy).
     opacity:0 is inherited from the global hidden state; data-d gives a rolling cascade
     (transition-delay longhand re-applies --reveal-delay after the shorthand resets it). */
  @media (prefers-reduced-motion: no-preference) {
    html.reveal-ready .rep-col li.rep-row {
      transform: translateY(16px);
      filter: none;
      transition: opacity .5s var(--ease), transform .5s var(--ease);
      transition-delay: var(--reveal-delay, 0s);
    }
    html.reveal-ready .rep-col li.rep-row.is-in { transform: none; }
  }

  /* CTA (light) */
  .cta-band { background: var(--paper-soft); color: var(--ink); text-align: center; padding: clamp(84px,12vw,160px) max(28px,5vw); }
  .cta-band h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(40px, 7vw, 88px); line-height: 1; color: var(--ink); margin: 0 0 14px; letter-spacing: -.01em; }
  .cta-band p { max-width: 48ch; margin: 0 auto 38px; color: var(--ink-soft); }
  .btn-row { display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; }
  .btn { font-family: var(--mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; padding: 16px 30px; border: 1px solid var(--ink); color: var(--ink); transition: background-color .4s var(--ease), color .4s var(--ease), border-color .4s var(--ease); }
  .btn:hover { background: var(--ink); color: var(--paper); }
  .btn-gold { border-color: var(--candle); color: var(--ink); background: var(--candle); }
  .btn-gold:hover { background: transparent; color: var(--ink); border-color: var(--candle); }

  /* Variable-font heading breath */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .station-title, .rite-head h2, .rep-head h2 {
        font-variation-settings: "wght" var(--wght);
        animation: headingBreath linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 55%;
      }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-cue::after { animation: none; }
  }
  @keyframes cuepulse { 0%, 100% { transform: scaleX(.4); opacity: .3; } 50% { transform: scaleX(1); opacity: .7; } }
</style>

<script>
  // Page-scoped behavior, ClientRouter-safe: re-bind on every page-load, drop stale observers.
  let toneIO: IntersectionObserver | undefined;
  let viaIO: IntersectionObserver | undefined;
  // Guard so the program disclosures are wired exactly once per element across page-loads.
  const smoothBound = new WeakSet<HTMLDetailsElement>();

  // Smooth-expand the station program lists — the native <details> snaps open; we animate
  // the `.station-program` wrapper's height/opacity so the list unfolds instead of jumping.
  const setupProgramDetails = () => {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    document.querySelectorAll<HTMLDetailsElement>(".prog-d").forEach((details) => {
      if (smoothBound.has(details)) return;
      const summary = details.querySelector("summary");
      const body = details.querySelector<HTMLElement>(".station-program");
      if (!summary || !body) return;
      smoothBound.add(details);

      body.style.overflow = "hidden";
      body.style.height = details.open ? "auto" : "0px";
      body.style.opacity = details.open ? "1" : "0";

      let animating = false;
      const finish = (toOpen: boolean) => {
        body.style.height = toOpen ? "auto" : "0px";
        body.style.opacity = toOpen ? "1" : "0";
        if (!toOpen) details.removeAttribute("open");
        animating = false;
      };
      const animate = (toOpen: boolean) => {
        if (reduce) {
          if (toOpen) details.setAttribute("open", "");
          finish(toOpen);
          return;
        }
        animating = true;
        if (toOpen) details.setAttribute("open", "");
        const start = body.getBoundingClientRect().height;
        body.style.height = `${start}px`;
        body.style.opacity = toOpen ? "0" : "1";
        void body.getBoundingClientRect();
        const target = toOpen ? body.scrollHeight : 0;
        const duration = toOpen ? 480 : 340;
        body.style.transition = `height ${duration}ms cubic-bezier(0.22, 0.61, 0.16, 1), opacity ${duration}ms ease`;
        requestAnimationFrame(() => {
          body.style.height = `${target}px`;
          body.style.opacity = toOpen ? "1" : "0";
        });
        const done = (event: TransitionEvent) => {
          if (event.target !== body || event.propertyName !== "height") return;
          body.removeEventListener("transitionend", done);
          body.style.transition = "";
          finish(toOpen);
        };
        body.addEventListener("transitionend", done);
      };

      summary.addEventListener("click", (event) => {
        event.preventDefault();
        if (animating) return;
        animate(!details.open);
      });
    });
  };

  const setupKoncerty = () => {
    toneIO?.disconnect();
    viaIO?.disconnect();

    const chrome = document.getElementById("chrome");
    const rail = document.querySelector<HTMLElement>(".via-rail");
    if (!chrome || !rail) return; // not the koncerty page

    // Chrome flips to light while a paper section sits under it.
    const lightSections = [...document.querySelectorAll(".tone-light")];
    const activeLight = new Set<Element>();
    toneIO = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) activeLight.add(e.target);
          else activeLight.delete(e.target);
        }
        chrome.classList.toggle("is-light", activeLight.size > 0);
      },
      { rootMargin: "-64px 0px -90% 0px", threshold: 0 },
    );
    lightSections.forEach((el) => toneIO!.observe(el));

    // Via rail tracks the active station.
    const num = rail.querySelector<HTMLElement>(".via-num");
    const date = rail.querySelector<HTMLElement>(".via-date");
    const fill = rail.querySelector<HTMLElement>(".via-fill");
    const active = new Set<Element>();
    viaIO = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            active.add(e.target);
            const el = e.target as HTMLElement;
            if (num) num.textContent = el.dataset.viaNum ?? "";
            if (date) date.textContent = el.dataset.viaDate ?? "";
            if (fill) fill.style.height = el.dataset.viaStep ?? "0%";
          } else {
            active.delete(e.target);
          }
        }
        rail.classList.toggle("is-active", active.size > 0);
      },
      { threshold: 0.25 },
    );
    document.querySelectorAll(".station").forEach((s) => viaIO!.observe(s));

    setupProgramDetails();
  };

  document.addEventListener("astro:page-load", setupKoncerty);
</script>
