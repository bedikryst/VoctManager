---
/**
 * @file kontakt.astro
 * @description Public contact page (/kontakt). The hero frames the whole page as an
 *  invitation — every past station of the Via began with someone's, and the next can too —
 *  so this reads as where future concerts start, not a generic "write to us" form. Three
 *  prioritised email channels (concerts & liturgy / patronage / general) rendered as a
 *  semantic <dl>, each with a subject-prefilled mailto, a one-line concierge hint, and a
 *  copy-to-clipboard button (hostile bare mailto is a real desktop failure). Prose is pinned
 *  with the shared nbsp() / &nbsp; micro-typography so orphans and honorifics never break.
 *  An honest "three voices" signature —
 *  the foundation board answers together, so we name the three people instead of faking a
 *  per-channel owner or a support desk. Then ONE paper-soft band carrying all the
 *  administrative weight — foundation, a mail-only correspondence address (no map, nobody
 *  works there), and the data-controller (RODO) note — so nothing floats as small print in a
 *  void, and a quiet coda closes. No contact form (RODO — channels only).
 * @architecture Astro islands 2026
 * @module pages/kontakt
 */
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteChrome from "../components/SiteChrome.astro";
import SiteFooter from "../components/SiteFooter.astro";
import BleedImage from "../components/BleedImage.astro";
import { bleedPair } from "../lib/photos";
import { nbsp } from "../lib/typo";
import { VaultIsland } from "../islands/landing/VaultIsland";
import "../styles/vault.css";

const hero = bleedPair("kontakt-hero");

const title = "Kontakt — VoctEnsemble | Fundacja VoctFoundation";
const description =
  "Napisz do VoctEnsemble i Fundacji VoctFoundation: koncerty i oprawy liturgii, mecenat, sprawy ogólne. Odpowiadamy osobiście — po polsku, angielsku i francusku.";

// Prioritised by conversion: the two channels the site exists for first, catch-all last.
// RODO is deliberately NOT a top-level channel — it lives in the controller note below.
const channels = [
  {
    role: "Koncerty i liturgie",
    email: "booking@voctensemble.com",
    subject: "Zaproszenie VoctEnsemble",
    hint: "Napisz, gdzie i kiedy — miejsce, przybliżony termin, okazję i charakter przestrzeni. Odpiszemy z propozycją programu ułożonego pod konkretną akustykę.",
  },
  {
    role: "Mecenat i patronat",
    email: "patronat@voctensemble.com",
    subject: "Mecenat i patronat VoctEnsemble",
    hint: "Darowizna, patronat honorowy albo współpraca instytucjonalna. Powiedz, co jest dla Was ważne — dobierzemy formę i pokażemy, na co idzie wsparcie.",
  },
  {
    role: "Sprawy ogólne",
    email: "kontakt@voctensemble.com",
    subject: "Sprawy ogólne VoctEnsemble",
    hint: "Wszystko pozostałe: pytania, współpraca artystyczna, sprawy fundacji. Jeśli nie wiesz, do kogo pisać — pisz tu; i tak trafi do nas trojga.",
  },
] as const;

// The people behind the addresses — the same board as /o-nas. Named, not assigned per
// channel: a young foundation answers together, and saying so is more honest (and more
// premium) than a fabricated "dedicated contact".
const voices = ["Florent de Bazelaire", "Anna Marcisz", "Krystian Bugalski"] as const;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: title,
  url: "https://voctensemble.com/kontakt",
  about: {
    "@type": "Organization",
    name: "Fundacja VoctFoundation",
    alternateName: "VoctEnsemble",
    url: "https://voctensemble.com",
    email: "kontakt@voctensemble.com",
    address: {
      "@type": "PostalAddress",
      streetAddress: "ul. Św. Filipa 23/3",
      postalCode: "31-150",
      addressLocality: "Kraków",
      addressCountry: "PL",
    },
    contactPoint: [
      {
        "@type": "ContactPoint",
        email: "booking@voctensemble.com",
        contactType: "bookings",
        availableLanguage: ["Polish", "English", "French"],
      },
      {
        "@type": "ContactPoint",
        email: "patronat@voctensemble.com",
        contactType: "sponsorship",
        availableLanguage: ["Polish", "English", "French"],
      },
      {
        "@type": "ContactPoint",
        email: "kontakt@voctensemble.com",
        contactType: "general inquiries",
        availableLanguage: ["Polish", "English", "French"],
      },
    ],
    sameAs: [
      "https://www.instagram.com/voctensemble/",
      "https://www.facebook.com/voctensemble/",
      "https://www.youtube.com/@VoctEnsemble-nb7gh",
    ],
  },
};

// Build-time optimized share image derived from the hero original.
const ogImage = (await getImage({ src: hero.desktop, width: 1200, format: "webp" })).src;
---

<BaseLayout
  title={title}
  description={description}
  path="/kontakt"
  image={ogImage}
  bodyClass="page-kontakt"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <a class="skip-link" href="#tresc">Przejdź do treści</a>
  <SiteChrome current="/kontakt" />

  <main id="tresc">
    {/* ── Hero ─────────────────────────────────────────────────────────── */}
    <section class="hero" aria-label="Kontakt">
      <div class="hero-media" aria-hidden="true">
        <BleedImage desktop={hero.desktop} mobile={hero.mobile} alt="" position="center 40%" eager animate />
      </div>
      <div class="hero-inner">
        <p class="eyebrow reveal">
          <span class="lat">Scribe nobis</span>{"  ·  "}Kontakt
        </p>
        <h1>
          <span class="line"><span class="reveal">Napisz</span></span>
          <span class="line"><span class="reveal" data-d="1">do <em>nas.</em></span></span>
        </h1>
        <p class="hero-lede reveal" data-d="2">
          Archikatedra w&nbsp;Łodzi, dworek w&nbsp;Szczawnicy, Synagoga Tempel, śluby
          w&nbsp;Tyńcu — każdy z&nbsp;tych wieczorów zaczął się od czyjegoś zaproszenia.
          Następne może być Twoje.
        </p>
        <span class="scroll-cue reveal" data-d="3">Wybierz drzwi</span>
      </div>
    </section>

    {/* ── Channels — the page's altar ──────────────────────────────────── */}
    <section class="channels-section" aria-label="Kanały kontaktu">
      <div class="channels-wrap">
        <div class="col-head reveal">
          <span class="eyebrow"><span class="lat">Tres ianuae</span>  ·  Troje drzwi</span>
          <h2>Powiedz nam, z&nbsp;czym przychodzisz.</h2>
        </div>
        <p class="contact-intro reveal" data-d="1">
          Każda sprawa ma swój adres, żeby od razu trafiła we&nbsp;właściwe ręce. Po drugiej
          stronie czekają te same <em>trzy osoby</em>, które prowadzą fundację —
          i&nbsp;same czytają każdą wiadomość.
        </p>

        <dl class="channels">
          {
            channels.map((c, i) => (
              <div class="channel reveal" data-d={String((i % 3) + 1)}>
                <dt class="channel-role">{nbsp(c.role)}</dt>
                <dd class="channel-body">
                  <p class="channel-line">
                    <a class="channel-mail" href={`mailto:${c.email}?subject=${encodeURIComponent(c.subject)}`}>
                      {c.email}
                    </a>
                    <button
                      class="channel-copy"
                      type="button"
                      data-copy={c.email}
                      aria-label={`Skopiuj adres ${c.email}`}
                    >
                      <span class="copy-label">Kopiuj</span>
                    </button>
                  </p>
                  <p class="channel-hint">{nbsp(c.hint)}</p>
                </dd>
              </div>
            ))
          }
        </dl>

        <div class="after-channels reveal">
          <p>
            Pisz po polsku, po angielsku albo po francusku — odpowiemy w&nbsp;tym języku,
            w&nbsp;którym zaczniesz. Najszybciej, jak pozwala kalendarz prób i&nbsp;koncertów;
            zwykle w&nbsp;ciągu kilku dni.
          </p>
          <p>
            Dziennikarze i&nbsp;organizatorzy znajdą biogramy, zdjęcia w&nbsp;wysokiej
            rozdzielczości i&nbsp;pełne programy w&nbsp;<a href="/press">materiałach prasowych →</a>
          </p>
        </div>

        <div class="voices reveal">
          <span class="voices-label">Czytają i&nbsp;odpowiadają</span>
          <p class="voices-names">
            {voices.map((v, i) => (
              <>
                {i > 0 && <span class="voices-dot" aria-hidden="true"> · </span>}
                {v}
              </>
            ))}
          </p>
          <p class="voices-note">
            Zarząd Fundacji VoctFoundation. Odpowiadamy wspólnie — i&nbsp;chcemy, żeby tak
            zostało także wtedy, gdy urośniemy.
          </p>
        </div>
      </div>
    </section>

    {/* ── Foundation, correspondence address & data-controller — all the administrative
          weight in ONE paper-soft band so the page never floats small print in a void.
          No map, no "come find us": the seat is a mailing address, nobody works there. ── */}
    <section class="locus" aria-label="Fundacja i dane">
      <div class="locus-wrap">
        <div class="col-head reveal">
          <span class="eyebrow"><span class="lat">Fundatio</span>  ·  Fundacja</span>
          <h2>Za głosem stoi fundacja.</h2>
        </div>
        <div class="locus-grid">
          <div class="aside-block reveal" data-d="1">
            <h3>Fundacja</h3>
            <p class="fund-mission">
              Fundacja VoctFoundation działa w&nbsp;obszarze kultury, sztuki oraz ochrony
              dziedzictwa; VoctEnsemble jest jej zespołem-rezydentem. Dochód przeznaczamy
              w&nbsp;całości na cele statutowe.
            </p>
            <p class="fund-more">
              <a class="fund-link" href="/o-nas#fundacja">Poznaj fundację i zarząd →</a>
            </p>
          </div>

          <div class="aside-block reveal" data-d="2">
            <h3>Adres korespondencyjny</h3>
            <p class="addr">
              Fundacja VoctFoundation<br />
              ul.&nbsp;Św.&nbsp;Filipa 23/3<br />
              31-150 Kraków
            </p>
            <p class="addr-note">
              Biura tu nie prowadzimy — spotykamy się tam, gdzie śpiewamy.
            </p>
          </div>
        </div>

        <div class="locus-legal reveal">
          <p class="rodo-admin">
            <span class="rodo-admin-label">Administrator danych</span>
            Fundacja VoctFoundation · KRS 0001237252 · NIP 6762718992 · REGON 544621525
          </p>
          <p class="rodo-note">
            Pisząc do nas, powierzasz nam swoje dane (imię, adres e-mail oraz treść
            wiadomości). Przetwarzamy je wyłącznie po to, by odpowiedzieć na Twoją wiadomość
            (art.&nbsp;6 ust.&nbsp;1 lit.&nbsp;f RODO). Masz prawo dostępu, sprostowania
            i&nbsp;usunięcia danych —
            <a href="mailto:rodo@voctensemble.com">rodo@voctensemble.com</a>. Więcej
            w&nbsp;<a href="/polityka-prywatnosci">polityce prywatności</a>.
          </p>
        </div>
      </div>
    </section>

    {/* ── Coda — the page wybrzmiewa, nie kończy się drobnym drukiem ────── */}
    <section class="coda" aria-label="Do usłyszenia">
      <div class="coda-inner reveal">
        <span class="coda-glyph" aria-hidden="true"></span>
        <h2>Do usłyszenia.</h2>
        <p>A najlepiej — na żywo, w&nbsp;akustyce, która pamięta.</p>
        <div class="coda-links">
          <a href="/koncerty">Zobacz koncerty →</a>
          <a href="/?donate" data-vault-open="100">Wesprzyj fundację →</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />

  <VaultIsland client:idle />
  <script>
    import "../scripts/vault-triggers.ts";

    // Copy-to-clipboard for contact channels. Document-delegated + guarded so it binds once
    // and survives ClientRouter DOM swaps (the buttons only exist on this page; the listener
    // no-ops everywhere else). A bare mailto is a real desktop failure when no mail client is
    // configured — the copy button is the escape hatch.
    if (!(window as unknown as { __voctCopy?: boolean }).__voctCopy) {
      (window as unknown as { __voctCopy?: boolean }).__voctCopy = true;
      document.addEventListener("click", (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;
        const btn = target.closest<HTMLButtonElement>("[data-copy]");
        if (!btn) return;
        const value = btn.dataset.copy;
        const label = btn.querySelector<HTMLElement>(".copy-label");
        if (!value || !label || !navigator.clipboard) return;
        navigator.clipboard
          .writeText(value)
          .then(() => {
            const prev = label.textContent;
            btn.classList.add("is-copied");
            label.textContent = "Skopiowano";
            window.setTimeout(() => {
              btn.classList.remove("is-copied");
              label.textContent = prev;
            }, 1800);
          })
          .catch(() => {});
      });
    }
  </script>
</BaseLayout>

<style>
  /* Hero */
  .hero { position: relative; min-height: 84svh; display: flex; align-items: flex-end; padding: 0 var(--gutter) clamp(54px, 8vw, 92px); color: var(--paper); overflow: hidden; isolation: isolate; }
  .hero-media { position: absolute; inset: 0; z-index: -2; }
  /* Photo keeps full brightness; text pocket (bottom-left) deepened via the diagonal (see o-nas). */
  .hero::after { content: ""; position: absolute; inset: 0; z-index: -1; background: linear-gradient(180deg, rgba(8,8,7,.48) 0%, rgba(8,8,7,.12) 40%, rgba(8,8,7,.8) 100%), linear-gradient(72deg, rgba(8,8,7,.72) 0%, rgba(8,8,7,.22) 46%, transparent 72%); }
  .hero-inner { max-width: 1180px; width: 100%; margin: 0 auto; padding: 0; }
  .hero h1 { font-family: var(--serif); font-weight: 300; line-height: .98; font-size: clamp(48px, 8.4vw, 116px); letter-spacing: -.01em; margin: 16px 0 0; }
  .hero h1 em { color: var(--candle); }
  .hero-lede { font-family: var(--serif); font-style: italic; font-weight: 300; font-size: clamp(19px, 2.2vw, 28px); line-height: 1.42; max-width: 36ch; margin: 22px 0 0; color: rgba(244, 241, 233, .9); }
  .scroll-cue { margin-top: 34px; font-family: var(--mono); font-size: 10px; letter-spacing: .26em; text-transform: uppercase; color: rgba(244,241,233,.62); display: inline-flex; align-items: center; gap: 10px; }
  .scroll-cue::after { content: ""; width: 38px; height: 1px; background: currentColor; opacity: .6; animation: cuepulse 3.4s var(--ease-slow) infinite; }

  /* Shared section head (channels + locus) */
  .col-head { margin: 0; }
  .col-head .eyebrow { display: block; margin-bottom: 16px; }
  .col-head h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(30px, 3.6vw, 48px); line-height: 1.05; color: var(--ink); margin: 0; letter-spacing: -.01em; }

  /* Channels — the altar */
  .channels-section { padding: clamp(72px, 11vw, 150px) var(--gutter); }
  .channels-wrap { max-width: 920px; margin: 0 auto; }
  .contact-intro { font-family: var(--serif); font-style: italic; font-weight: 300; font-size: clamp(19px, 2vw, 25px); line-height: 1.5; color: var(--ink-soft); max-width: 40ch; margin: 18px 0 0; }
  .contact-intro em { color: var(--candle); }

  .channels { margin: clamp(40px, 5vw, 64px) 0 0; }
  .channel { display: grid; gap: 12px; padding: clamp(26px, 3.6vw, 40px) 0; border-top: 1px solid var(--line); }
  .channel:last-of-type { border-bottom: 1px solid var(--line); }
  .channel-role { font-family: var(--mono); font-size: 10.5px; letter-spacing: .18em; text-transform: uppercase; color: var(--candle); margin: 0; }
  .channel-body { margin: 0; }
  .channel-line { display: flex; flex-wrap: wrap; align-items: baseline; gap: 10px 18px; margin: 0; }
  .channel-mail { font-family: var(--serif); font-size: clamp(22px, 3.2vw, 34px); color: var(--ink); border-bottom: 1px solid transparent; transition: border-color .3s var(--ease); overflow-wrap: anywhere; }
  .channel-mail:hover { border-bottom-color: var(--candle); }
  .channel-copy { display: inline-flex; align-items: center; gap: 6px; align-self: center; font-family: var(--mono); font-size: 9.5px; letter-spacing: .16em; text-transform: uppercase; color: var(--ink-muted); background: transparent; border: 1px solid var(--line); border-radius: 999px; padding: 5px 12px; cursor: pointer; transition: color .3s var(--ease), border-color .3s var(--ease); }
  .channel-copy:hover { color: var(--ink); border-color: var(--line-strong); }
  .channel-copy.is-copied { color: var(--sage); border-color: var(--sage); }
  .channel-hint { margin: 12px 0 0; max-width: 56ch; font-size: clamp(14px, 1.1vw, 15.5px); line-height: 1.7; color: var(--ink-muted); }

  /* After channels — languages, rhythm, media pointer */
  .after-channels { margin: clamp(34px, 5vw, 54px) 0 0; display: grid; gap: 16px; }
  .after-channels p { max-width: 62ch; font-size: clamp(14.5px, 1.15vw, 16px); line-height: 1.72; color: var(--ink-soft); }
  .after-channels a { border-bottom: 1px solid var(--line-strong); transition: color .3s var(--ease), border-color .3s var(--ease); }
  .after-channels a:hover { color: var(--candle-blue); border-color: var(--candle-blue); }

  /* Three voices — honest signature */
  .voices { margin: clamp(40px, 5vw, 60px) 0 0; padding-top: clamp(28px, 3.6vw, 40px); border-top: 1px solid var(--line); }
  .voices-label { font-family: var(--mono); font-size: 10px; letter-spacing: .22em; text-transform: uppercase; color: var(--ink-muted); }
  .voices-names { margin: 14px 0 0; font-family: var(--serif); font-weight: 300; font-size: clamp(22px, 2.6vw, 30px); line-height: 1.35; color: var(--ink); }
  .voices-dot { color: var(--candle); }
  .voices-note { margin: 12px 0 0; max-width: 48ch; font-size: 16px; line-height: 1.72; color: var(--ink-muted); }

  /* Seat & foundation */
  .locus { background: var(--paper-soft); padding: clamp(72px, 11vw, 150px) var(--gutter); }
  .locus-wrap { max-width: 920px; margin: 0 auto; }
  .locus-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(36px, 5vw, 72px); align-items: start; margin-top: clamp(36px, 5vw, 56px); }
  @media (max-width: 620px) { .locus-grid { grid-template-columns: 1fr; gap: 40px; } }
  .aside-block { margin: 0; }
  .aside-block h3 { font-family: var(--mono); font-size: 10px; letter-spacing: .24em; text-transform: uppercase; color: var(--ink-muted); margin: 0 0 16px; font-weight: 400; }
  .addr { font-family: var(--mono); font-size: 13px; line-height: 1.9; letter-spacing: .02em; color: var(--ink-soft); }
  .addr-note { margin: 14px 0 0; font-size: 13.5px; line-height: 1.7; color: var(--ink-muted); max-width: 34ch; }
  .fund-mission { font-size: 16px; line-height: 1.75; color: var(--ink-soft); margin: 0 0 16px; max-width: 42ch; }
  .fund-more { margin: 0; }
  .fund-link { font-family: var(--mono); font-size: 10.5px; letter-spacing: .14em; text-transform: uppercase; color: var(--ink-muted); border-bottom: 1px solid var(--line-strong); padding-bottom: 3px; transition: color .3s var(--ease), border-color .3s var(--ease); }
  .fund-link:hover { color: var(--candle-blue); border-color: var(--candle-blue); }

  /* Administrative fine print — lives inside the locus band, hairline-separated, so it
     reads as the practical tail of one section instead of floating small print on paper. */
  .locus-legal { margin-top: clamp(40px, 5vw, 64px); padding-top: clamp(26px, 3.2vw, 36px); border-top: 1px solid var(--line); }
  .rodo-admin { font-family: var(--mono); font-size: 11px; line-height: 1.85; letter-spacing: .03em; color: var(--ink-muted); margin: 0 0 14px; }
  .rodo-admin-label { display: block; font-size: 9.5px; letter-spacing: .2em; text-transform: uppercase; color: var(--candle); margin-bottom: 6px; }
  .rodo-note { margin: 0; font-family: var(--mono); font-size: 10.5px; line-height: 1.85; letter-spacing: .02em; color: var(--ink-muted); max-width: 78ch; }
  .rodo-note a { border-bottom: 1px solid var(--line); transition: color .3s var(--ease), border-color .3s var(--ease); }
  .rodo-note a:hover { color: var(--ink); border-color: var(--line-strong); }

  /* Coda — the page wybrzmiewa. No divider line: the paper-soft → paper step and the gold
     aura carry the turn, so nothing reads as a stray rule floating in space. */
  .coda { position: relative; padding: clamp(64px, 8vw, 104px) var(--gutter) clamp(84px, 12vw, 150px); text-align: center; overflow: hidden; isolation: isolate; }
  .coda::before { content: ""; position: absolute; inset: 0; z-index: -1; pointer-events: none; background: radial-gradient(66% 56% at 50% 30%, color-mix(in srgb, var(--candle) 16%, transparent) 0%, transparent 62%); }
  .coda-inner { max-width: 620px; margin: 0 auto; display: grid; justify-items: center; }
  .coda-glyph { width: 80px; height: 220px; margin-bottom: 46px; background: linear-gradient(165deg, #e6d3a0 0%, #c6a45b 52%, #ad8a44 100%); -webkit-mask: url(/logo-mark.png) center / contain no-repeat; mask: url(/logo-mark.png) center / contain no-repeat; opacity: .85; }
  .coda h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(40px, 7vw, 84px); line-height: 1; letter-spacing: -.01em; color: var(--ink); margin: 0; }
  .coda p { margin: 18px 0 0; font-family: var(--serif); font-style: italic; font-weight: 300; font-size: clamp(18px, 2vw, 24px); line-height: 1.45; color: var(--ink-soft); }
  .coda-links { margin: 34px 0 0; display: flex; flex-wrap: wrap; gap: 14px 30px; justify-content: center; }
  .coda-links a { font-family: var(--mono); font-size: 10.5px; letter-spacing: .18em; text-transform: uppercase; color: var(--ink-muted); border-bottom: 1px solid var(--line); padding-bottom: 4px; transition: color .3s var(--ease), border-color .3s var(--ease); }
  .coda-links a:hover { color: var(--candle); border-color: var(--candle); }

  /* Variable-font heading breath (native, sparing). */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .hero h1, .col-head h2, .coda h2 {
        font-variation-settings: "wght" var(--wght);
        animation: headingBreath linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 55%;
      }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-cue::after { animation: none; }
  }
