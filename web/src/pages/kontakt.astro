---
/**
 * @file kontakt.astro
 * @description Public contact page (/kontakt). Four direct email channels, address block
 *  with OpenStreetMap link, foundation info + legal + socials, RODO note. No contact form
 *  (RODO-compliance; backend `contact` app intentionally not wired). First page ported to
 *  Astro — proves the pattern: salvaged CSS de-scoped, native reveals, shared chrome/footer.
 * @architecture Astro islands 2026
 * @module pages/kontakt
 */
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteChrome from "../components/SiteChrome.astro";
import SiteFooter from "../components/SiteFooter.astro";
import BleedImage from "../components/BleedImage.astro";
import { bleedPair } from "../lib/photos";
import { VaultIsland } from "../islands/landing/VaultIsland";
import "../styles/vault.css";

const hero = bleedPair("kontakt-hero");

const title = "Kontakt — VoctEnsemble | Fundacja VoctFoundation";
const description =
  "Napisz do VoctEnsemble i Fundacji VoctFoundation: koncerty i oprawy liturgii, mecenat, sprawy ogólne. Po drugiej stronie czeka człowiek, nie formularz.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: title,
  url: "https://voctensemble.com/kontakt",
  about: {
    "@type": "Organization",
    name: "Fundacja VoctFoundation",
    alternateName: "VoctEnsemble",
    url: "https://voctensemble.com",
    email: "kontakt@voctensemble.com",
    address: {
      "@type": "PostalAddress",
      streetAddress: "ul. Św. Filipa 23/3",
      postalCode: "31-150",
      addressLocality: "Kraków",
      addressCountry: "PL",
    },
    sameAs: [
      "https://www.instagram.com/voctensemble/",
      "https://www.facebook.com/voctensemble/",
      "https://www.youtube.com/@VoctEnsemble-nb7gh",
    ],
  },
};

// Build-time optimized share image derived from the hero original.
const ogImage = (await getImage({ src: hero.desktop, width: 1200, format: "webp" })).src;
---

<BaseLayout
  title={title}
  description={description}
  path="/kontakt"
  image={ogImage}
  bodyClass="page-kontakt"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <a class="skip-link" href="#tresc">Przejdź do treści</a>
  <SiteChrome current="/kontakt" />

  <main id="tresc">
    <section class="hero" aria-label="Kontakt">
      <div class="hero-media" aria-hidden="true">
        <BleedImage desktop={hero.desktop} mobile={hero.mobile} alt="" position="center 40%" eager animate />
      </div>
      <div class="hero-inner">
        <p class="eyebrow reveal">
          <span class="lat">Contactus</span>{"  ·  "}Kontakt
        </p>
        <h1>
          <span class="line"><span class="reveal">Napiszcie</span></span>
          <span class="line"><span class="reveal" data-d="1">do <em>nas.</em></span></span>
        </h1>
        <p class="hero-lede reveal" data-d="2">
          Zaproszenie na koncert, oprawa liturgii lub uroczystości, mecenat, współpraca —
          albo po prostu wspólnota słuchania.
        </p>
      </div>
    </section>

    <section class="contact" aria-label="Dane kontaktowe">
      <div class="contact-wrap">
        <div class="col-head reveal">
          <span class="eyebrow">Napisz do nas</span>
          <h2>Powiedz nam, z czym przychodzisz.</h2>
        </div>
        <p class="contact-intro reveal" data-d="1">
          Każdy wątek ma swój adres — a po drugiej stronie czeka <em>człowiek</em>, nie
          formularz. Odpowiadamy najszybciej, jak pozwala kalendarz prób i koncertów.
        </p>

        <div class="channels-hero reveal" data-d="1">
          <div class="channel">
            <span class="role">Sprawy ogólne</span>
            <a class="mail" href="mailto:kontakt@voctensemble.com">kontakt@voctensemble.com</a>
          </div>
          <div class="channel">
            <span class="role">Koncerty i oprawy</span>
            <a class="mail" href="mailto:booking@voctensemble.com">booking@voctensemble.com</a>
          </div>
          <div class="channel">
            <span class="role">Mecenat i patronat</span>
            <a class="mail" href="mailto:patronat@voctensemble.com">patronat@voctensemble.com</a>
          </div>
          <div class="channel">
            <span class="role">Ochrona danych (RODO)</span>
            <a class="mail" href="mailto:rodo@voctensemble.com">rodo@voctensemble.com</a>
          </div>
        </div>

        <hr class="contact-rule reveal" aria-hidden="true" />

        <div class="contact-meta reveal">
          <div class="aside-block">
            <h3>Siedziba</h3>
            <p class="addr">
              Fundacja VoctFoundation<br />
              ul. Św. Filipa 23/3<br />
              31-150 Kraków<br />
              <a
                class="map-link"
                href="https://www.openstreetmap.org/search?query=%C5%9Bw.%20Filipa%2023%2C%2031-150%20Krak%C3%B3w"
                target="_blank"
                rel="noopener noreferrer"
              >
                Pokaż na mapie ↗
              </a>
            </p>
          </div>

          <div class="aside-block">
            <h3>Fundacja</h3>
            <p class="fund-mission">
              Fundacja VoctFoundation działa w obszarze kultury, sztuki oraz ochrony
              dziedzictwa; VoctEnsemble jest jej zespołem-rezydentem. Dochód przeznaczamy w
              całości na cele statutowe.
            </p>
            <p class="legal-mini">
              <strong>Fundacja VoctFoundation</strong><br />
              KRS 0001237252 · NIP 6762718992<br />
              REGON 544621525
            </p>
            <div class="socials">
              <a href="https://www.instagram.com/voctensemble/" target="_blank" rel="noopener noreferrer">Instagram ↗</a>
              <a href="https://www.facebook.com/voctensemble/" target="_blank" rel="noopener noreferrer">Facebook ↗</a>
              <a href="https://www.youtube.com/@VoctEnsemble-nb7gh" target="_blank" rel="noopener noreferrer">YouTube ↗</a>
            </div>
          </div>
        </div>

        <p class="rodo-note">
          Pisząc do nas, powierzasz nam swoje dane (imię, adres e-mail oraz treść
          wiadomości). Administratorem jest <strong>Fundacja VoctFoundation</strong> (ul. Św.
          Filipa 23/3, 31-150 Kraków); przetwarzamy je wyłącznie po to, by odpowiedzieć na
          Twoją wiadomość (art. 6 ust. 1 lit. f RODO). Masz prawo dostępu, sprostowania i
          usunięcia danych — <a href="mailto:rodo@voctensemble.com">rodo@voctensemble.com</a>.
          Więcej w <a href="/polityka-prywatnosci">polityce prywatności</a>.
        </p>
      </div>
    </section>
  </main>

  <SiteFooter />

  <VaultIsland client:idle />
  <script>
    import "../scripts/vault-triggers.ts";
  </script>
</BaseLayout>

<style>
  /* Hero */
  .hero { position: relative; min-height: 78svh; display: flex; align-items: flex-end; padding: 0 max(28px, 5vw) clamp(54px, 8vw, 92px); color: var(--paper); overflow: hidden; isolation: isolate; }
  .hero-media { position: absolute; inset: 0; z-index: -2; }
  .hero::after { content: ""; position: absolute; inset: 0; z-index: -1; background: linear-gradient(180deg, rgba(8,8,7,.46) 0%, rgba(8,8,7,.12) 40%, rgba(8,8,7,.72) 100%), linear-gradient(72deg, rgba(8,8,7,.6) 0%, rgba(8,8,7,.16) 44%, transparent 70%); }
  .hero-inner { max-width: 1180px; width: 100%; margin: 0 auto; padding: 0; }
  .hero h1 { font-family: var(--serif); font-weight: 300; line-height: .98; font-size: clamp(48px, 8.4vw, 116px); letter-spacing: -.01em; margin: 16px 0 0; }
  .hero h1 em { color: var(--candle); }
  .hero-lede { font-family: var(--serif); font-style: italic; font-weight: 300; font-size: clamp(19px, 2.2vw, 28px); line-height: 1.42; max-width: 36ch; margin: 22px 0 0; color: rgba(244, 241, 233, .9); }

  /* Main */
  .contact { padding: clamp(72px, 11vw, 150px) max(28px, 5vw); }
  .contact-wrap { max-width: 920px; margin: 0 auto; }

  .col-head { margin: 0; }
  .col-head .eyebrow { display: block; margin-bottom: 16px; }
  .col-head h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(30px, 3.6vw, 48px); line-height: 1.05; color: var(--ink); margin: 0; letter-spacing: -.01em; }

  .contact-intro { font-family: var(--serif); font-style: italic; font-weight: 300; font-size: clamp(19px, 2vw, 25px); line-height: 1.5; color: var(--ink-soft); max-width: 34ch; margin: 18px 0 0; }
  .contact-intro em { color: var(--candle); }

  .channels-hero { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(28px, 4vw, 46px); margin: clamp(40px, 5vw, 64px) 0 0; }
  .channels-hero .channel { gap: 7px; }
  .channels-hero a.mail { font-size: clamp(20px, 2.8vw, 30px); }
  @media (max-width: 620px) { .channels-hero { grid-template-columns: 1fr; gap: 30px; } }

  .contact-rule { height: 1px; background: var(--line); border: 0; margin: clamp(46px, 6vw, 74px) 0; }

  .contact-meta { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(36px, 5vw, 72px); align-items: start; }
  .contact-meta .aside-block { margin: 0; }
  @media (max-width: 620px) { .contact-meta { grid-template-columns: 1fr; gap: 40px; } }

  .fund-mission { font-size: 14px; line-height: 1.75; color: var(--ink-soft); margin: 0 0 16px; max-width: 40ch; }

  .rodo-note { margin: clamp(40px, 5vw, 64px) 0 0; font-family: var(--mono); font-size: 10.5px; line-height: 1.85; letter-spacing: .02em; color: var(--ink-muted); max-width: 72ch; }
  .rodo-note strong { color: var(--ink-soft); font-weight: 400; }
  .rodo-note a { border-bottom: 1px solid var(--line); transition: color .3s var(--ease), border-color .3s var(--ease); }
  .rodo-note a:hover { color: var(--ink); border-color: var(--line-strong); }

  /* Aside — direct contact */
  .aside-block { margin: 0 0 38px; }
  .aside-block h3 { font-family: var(--mono); font-size: 10px; letter-spacing: .24em; text-transform: uppercase; color: var(--ink-muted); margin: 0 0 16px; font-weight: 400; }
  .channel { display: grid; gap: 3px; }
  .channel .role { font-family: var(--mono); font-size: 10px; letter-spacing: .14em; text-transform: uppercase; color: var(--candle); }
  .channel a.mail { font-family: var(--serif); font-size: clamp(20px, 2vw, 25px); color: var(--ink); border-bottom: 1px solid transparent; transition: border-color .3s var(--ease); width: max-content; max-width: 100%; }
  .channel a.mail:hover { border-bottom-color: var(--candle); }

  .addr { font-family: var(--mono); font-size: 13px; line-height: 1.9; letter-spacing: .02em; color: var(--ink-soft); }
  .addr .map-link { display: inline-block; margin-top: 10px; font-size: 10.5px; letter-spacing: .16em; text-transform: uppercase; color: var(--ink-muted); border-bottom: 1px solid var(--line-strong); padding-bottom: 3px; transition: color .3s var(--ease), border-color .3s var(--ease); }
  .addr .map-link:hover { color: var(--candle-blue); border-color: var(--candle-blue); }

  .legal-mini { border-top: 1px solid var(--line); padding-top: 22px; font-family: var(--mono); font-size: 11.5px; line-height: 1.9; letter-spacing: .03em; color: var(--ink-muted); }
  .legal-mini strong { color: var(--ink); font-weight: 400; }
  .socials { display: flex; flex-wrap: wrap; gap: 10px 22px; margin-top: 18px; }
  .socials a { font-family: var(--mono); font-size: 11px; letter-spacing: .1em; color: var(--ink-soft); border-bottom: 1px solid var(--line); transition: color .3s var(--ease), border-color .3s var(--ease); }
  .socials a:hover { color: var(--candle); border-color: var(--candle); }

  /* Variable-font heading breath (native, sparing). */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .hero h1, .col-head h2 {
        font-variation-settings: "wght" var(--wght);
        animation: headingBreath linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 55%;
      }
    }
  }
</style>
