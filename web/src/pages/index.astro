---
/**
 * @file index.astro
 * @description Public landing (`/`). Reads as a partytura: metadata, jsonLd, then the
 *  rite as three movements braided by AetherInterlude (I · Lumen, II · Vox, III · Sustinete).
 *  Session/motion plumbing lives behind named components (PreloaderGate, MotionGate,
 *  VaultBuffer) so this file stays declarative.
 * @architecture Astro islands 2026
 * @module pages/index
 */
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { bleedPair } from "../lib/photos";
import "../styles/landing.css";

import HeroSection from "../components/landing/HeroSection.astro";
import ManifestSection from "../components/landing/ManifestSection.astro";
import AetherInterlude from "../components/landing/AetherInterlude.astro";
import ImageRiteSection from "../components/landing/ImageRiteSection.astro";
import EnsembleSection from "../components/landing/EnsembleSection.astro";
import DirectorSection from "../components/landing/DirectorSection.astro";
import PathSection from "../components/landing/PathSection.astro";
import SilenceMoment from "../components/landing/SilenceMoment.astro";
import FinalSupportSection from "../components/landing/FinalSupportSection.astro";
import CodaSection from "../components/landing/CodaSection.astro";
import MotionGate from "../components/landing/MotionGate.astro";
import PreloaderGate from "../components/landing/PreloaderGate.astro";
import VaultBuffer from "../components/landing/VaultBuffer.astro";

import { AudioController } from "../islands/landing/AudioController";
import { Preloader } from "../islands/landing/Preloader";
import { StickyHeader } from "../islands/landing/StickyHeader";
import { SiteFooter } from "../islands/landing/SiteFooter";
import { VaultIsland } from "../islands/landing/VaultIsland";
import { VoxMoment } from "../islands/landing/VoxMoment";
import { VideoLightbox } from "../islands/landing/VideoLightbox";
import { MovementSpine } from "../islands/landing/MovementSpine";

const title = "VoctEnsemble — Z ciszy głos. Koncerty Duchowe";
const description =
  "Profesjonalny zespół wokalny VoctEnsemble pod dyrekcją Florenta de Bazelaire. Koncert jako próg, nie spektakl — muzyka sakralna od renesansu po współczesne misteria. Projekt Fundacji VoctFoundation.";

const ogImage = (
  await getImage({ src: bleedPair("hero-landing").desktop, width: 1200, format: "webp" })
).src;

// Poster for the concert reel (Vox moment + lightbox). EDITABLE: swap the source photo
// when a real video still exists — bleedPair name only, the optimization stays.
const voxPoster = (
  await getImage({ src: bleedPair("chor-spot").desktop, width: 1600, format: "webp" })
).src;

// TODO (when the REAL files land in web/public/video/ — MODAL_VIDEO/VOX_VIDEO in
// data/landing/video.ts): add a `video` VideoObject member here so Google can show a video
// rich result. Deliberately absent until real footage ships. See landing-vox-video-spec Part J.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MusicGroup",
  // Shared entity ids — /o-nas declares an AboutPage graph pointing at the SAME
  // ensemble/foundation nodes, so search engines see one entity, not per-page twins.
  "@id": "https://voctensemble.com/#ensemble",
  name: "VoctEnsemble",
  url: "https://voctensemble.com",
  genre: ["Sacred music", "Choral music", "Polifonia"],
  description:
    "Profesjonalny zespół wokalny wykonujący muzykę sakralną — cykl Koncerty Duchowe. Rezydujący zespół Fundacji VoctFoundation.",
  founder: { "@type": "Person", name: "Florent de Bazelaire" },
  funder: {
    "@type": "NGO",
    "@id": "https://voctensemble.com/#foundation",
    name: "VoctFoundation",
    identifier: "KRS 0001237252",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Św. Filipa 23/3",
      postalCode: "31-150",
      addressLocality: "Kraków",
      addressCountry: "PL",
    },
  },
  sameAs: [
    "https://www.instagram.com/voctensemble/",
    "https://www.facebook.com/voctensemble/",
    "https://www.youtube.com/@VoctEnsemble-nb7gh",
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  path="/"
  image={ogImage}
  bodyClass="theme-marketing"
  reveal={false}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <MotionGate />
    <PreloaderGate />
    <VaultBuffer />
  </Fragment>

  <div class="voct-landing">
    <a class="skip-link" href="#main">Przejdź do treści</a>

    <Preloader client:load />
    <AudioController client:load />

    <StickyHeader client:load />
    <MovementSpine client:idle />

    <main id="main">
      <HeroSection />
      <ManifestSection />

      <section class="movement" id="ruch-i" data-movement="lumen" aria-label="I · Lumen quaerit">
        <AetherInterlude variant="passage" roman="I" latin="Lumen quaerit" />
        <ImageRiteSection />
        <EnsembleSection />
        <DirectorSection />
      </section>

      <section class="movement" id="ruch-ii" data-movement="vox" aria-label="II · Vox memoriae">
        <AetherInterlude variant="memory" roman="II" latin="Vox memoriae" />
        <SilenceMoment />
        <VoxMoment client:visible poster={voxPoster} />
        <PathSection />
      </section>

      <section class="movement" id="ruch-iii" data-movement="sustinete" aria-label="III · Sustinete nos">
        <AetherInterlude variant="offering" roman="III" latin="Sustinete nos" />
        <FinalSupportSection />
      </section>

      <CodaSection />
    </main>

    <SiteFooter client:visible />

    <VaultIsland client:idle />
    <VideoLightbox client:idle poster={voxPoster} />
  </div>

  <style is:global>
    /* Reveal hidden-state gate: only engage when JS marked motion live (mirrors base.css's
       reveal-ready trick, but for the landing's own unlayered `.reveal` system). */
    html:not(.voct-motion) .voct-landing .reveal {
      opacity: 1 !important;
      transform: none !important;
    }

    /* Once-per-session preloader skip: hide the SSR'd overlay BEFORE first paint for
       returning visitors. The body.preload-open scroll-lock is also neutralised so the
       page is immediately interactive on a ClientRouter return to "/". EXCEPTION: when
       the rite resolves into the threshold choice (`.is-choice` — e.g. the saved choice
       expired mid-session), the overlay must show despite the session skip; its scroll
       lock is `threshold-open`, which this neutralisation deliberately doesn't touch. */
    html.preloader-skip .preloader { display: none !important; }
    html.preloader-skip .preloader.is-choice { display: grid !important; }
    html.preloader-skip body.preload-open { overflow: visible !important; }
  </style>

  <script>
    import "../scripts/landing.ts";
  </script>
</BaseLayout>
