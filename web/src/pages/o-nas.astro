---
/**
 * @file o-nas.astro
 * @description Public "About us" page (/o-nas), structured as the founder's own catechism —
 *  "Skąd się wzięliśmy? / Co robimy? / Co śpiewamy?": hero, the founder's letter (the single
 *  origin statement, verbatim founding text, portrait alongside), ensemble prose (roster
 *  rotates per project around a stable core — no group photo by design), pull-quote plate
 *  ("Nade wszystko, dzielimy się."), "Co robimy" activity cards (named events, `doings`),
 *  "Co śpiewamy" credo linking to the /koncerty repertoire catalog, concert milestones
 *  derived from the `concerts` collection (about.* fields), VoctFoundation legal section,
 *  governance board (portraits render only once ALL files exist), CTA closed by the votive
 *  glyph. Full-bleed media via <BleedImage>; in-flow media via <Picture>. Reveals use
 *  BaseLayout's IntersectionObserver controller; heading-breath is native scroll-driven.
 * @architecture Astro islands 2026
 * @module pages/o-nas
 */
import { getCollection } from "astro:content";
import { getImage, Picture } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteChrome from "../components/SiteChrome.astro";
import SiteFooter from "../components/SiteFooter.astro";
import BleedImage from "../components/BleedImage.astro";
import { photo, photoOptional, bleedPair } from "../lib/photos";
import { nbsp } from "../lib/typo";
import { VaultIsland } from "../islands/landing/VaultIsland";
import "../styles/vault.css";

const SITE = "https://voctensemble.com";

const hero = bleedPair("o-nas-hero");
const plate = bleedPair("swiatlo-krzyz");
const florent = photo("florent");

const title = "O nas — VoctEnsemble | Fundacja VoctFoundation";
const description =
  "VoctEnsemble — krakowska formacja wokalna i zespół-rezydent Fundacji VoctFoundation. Koncerty duchowe, liturgie i muzyka sakralna od średniowiecznej polifonii po współczesny minimalizm.";

// Milestones — derived from the `concerts` collection (single source of truth with
// /koncerty): appending a concert to concerts.yaml extends this list automatically.
// `about.*` carries the o-nas short editorial; place falls back to venue, blurb to
// essence, and a missing img renders the row text-only (no placeholder art).
const concerts = (await getCollection("concerts")).sort((a, b) => a.data.order - b.data.order);
const milestones = concerts.map((c, i) => ({
  year: c.data.date?.slice(0, 4) ?? c.data.viaDate.match(/\d{4}/)?.[0] ?? c.data.viaDate,
  place: c.data.about?.place ?? c.data.venue ?? c.data.meta,
  title: c.data.title,
  img: c.data.about?.img ? photoOptional(c.data.about.img) : undefined,
  d: String((i % 3) + 1),
  body: nbsp(c.data.about?.blurb ?? c.data.essence),
}));

const goals = [
  "Twórczość muzyczna: produkcja, koprodukcja, organizacja i prezentacja projektów w kraju i za granicą.",
  "Dziedzictwo: dokumentowanie, archiwizowanie i udostępnianie muzyki oraz praktyk wykonawczych.",
  "Edukacja i dostępność: popularyzowanie kultury oraz wspieranie uczestnictwa w niej.",
  "Młodzi artyści: rozwój, promocja, mentoring, rezydencje i projekty wykonawcze.",
  "Współpraca: praca z artystami, instytucjami kultury, uczelniami, mediami i organizacjami społecznymi.",
] as const;

const board = [
  {
    name: "Florent de Bazelaire", role: "Kierownictwo artystyczne · dyrygent",
    vision: "Odpowiada za profil artystyczny, repertuar, pracę nad brzmieniem i długą linię rozwoju zespołu.",
    img: photoOptional("o-nas-florent"),
  },
  {
    name: "Anna Marcisz", role: "Produkcja · relacje · komunikacja",
    vision: "Prowadzi organizację projektów, kontakt z partnerami, wizerunek zespołu i rytm pracy poza sceną.",
    img: photoOptional("o-nas-ania"),
  },
  {
    name: "Krystian Bugalski", role: "Digital · technologia · stabilność",
    vision: "Odpowiada za obecność cyfrową, narzędzia, publikację, bezpieczeństwo i stabilność infrastruktury fundacji.",
    img: photoOptional("o-nas-krystian"),
  },
] as const;

// Portraits are all-or-nothing: with only some files present the three-card grid goes
// ragged (one 4:5 portrait, two bare). They appear only once every portrait exists in
// src/assets/photos (o-nas-florent / o-nas-ania / o-nas-krystian).
const boardPortraitsComplete = board.every((b) => b.img);

// "Co robimy?" — the founder's second question, answered with real activities and named
// events (Bobola liturgy, Dzień Judaizmu / Synagoga Tempel, wedding liturgies), NOT an
// invented "how we work" framework. Only OUR performances + public church figures are named
// here — collaborator name-drops (lights/sound/visuals) wait for consent (see voces-collab).
const doings: { k: string; p: string; href?: string; cta?: string }[] = [
  {
    k: "Koncerty Duchowe",
    p: "Autorski cykl — współczesna forma dawnych Concerts Spirituels. Każdy wieczór ma osobną intencję.",
    href: "/koncerty",
    cta: "Zobacz drogę koncertów →",
  },
  {
    k: "Liturgia i uroczystości",
    p: "Oprawa mszy i kościelnych świąt. Ostatnio — liturgia w uroczystość św. Andrzeja Boboli w Warszawie, w 100-lecie polskich prowincji jezuickich: Msza pod przewodnictwem abp. Adriana Galbasa, homilia o. Artura Sosy SJ.",
  },
  {
    k: "Dialog tradycji",
    p: "Śpiewaliśmy podczas 28. Dnia Judaizmu w Kościele katolickim, w krakowskiej Kaplicy św. Doroty, i wystąpiliśmy w Synagodze Tempel — muzyka jako miejsce spotkania.",
  },
  {
    k: "Śluby i sakramenty",
    p: "Oprawialiśmy liturgie ślubne w Kolegiacie św. Anny w Krakowie i w Opactwie Benedyktynów w Tyńcu. Jesteśmy dyspozycyjni dla takich uroczystości.",
  },
];

// One graph, three nodes: the AboutPage points at the SAME MusicGroup entity the landing
// declares (shared @id — no duplicate ensemble with a divergent URL), and the foundation
// is the ensemble's parentOrganization (resident-ensemble relation; landing says `funder`),
// carrying the full legal identity (KRS/NIP/REGON) this page shows in the open. The board
// belongs to the NGO node — they are foundation officers, not MusicGroup performers.
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AboutPage",
      "@id": `${SITE}/o-nas`,
      url: `${SITE}/o-nas`,
      name: title,
      description,
      inLanguage: "pl",
      mainEntity: { "@id": `${SITE}/#ensemble` },
    },
    {
      "@type": "MusicGroup",
      "@id": `${SITE}/#ensemble`,
      name: "VoctEnsemble",
      url: SITE,
      genre: ["Sacred music", "Choral music", "Polifonia"],
      foundingDate: "2024",
      foundingLocation: { "@type": "Place", name: "Kraków, Polska" },
      founder: { "@type": "Person", name: "Florent de Bazelaire" },
      parentOrganization: { "@id": `${SITE}/#foundation` },
      sameAs: [
        "https://www.instagram.com/voctensemble/",
        "https://www.facebook.com/voctensemble/",
        "https://www.youtube.com/@VoctEnsemble-nb7gh",
      ],
    },
    {
      "@type": "NGO",
      "@id": `${SITE}/#foundation`,
      name: "Fundacja VoctFoundation",
      url: `${SITE}/o-nas#fundacja`,
      identifier: [
        { "@type": "PropertyValue", propertyID: "KRS", value: "0001237252" },
        { "@type": "PropertyValue", propertyID: "NIP", value: "6762718992" },
        { "@type": "PropertyValue", propertyID: "REGON", value: "544621525" },
      ],
      address: {
        "@type": "PostalAddress",
        streetAddress: "Św. Filipa 23/3",
        postalCode: "31-150",
        addressLocality: "Kraków",
        addressCountry: "PL",
      },
      member: board.map((b) => ({ "@type": "Person", name: b.name, jobTitle: b.role })),
    },
  ],
};

const ogImage = (await getImage({ src: hero.desktop, width: 1200, format: "webp" })).src;
---

<BaseLayout title={title} description={description} path="/o-nas" image={ogImage} bodyClass="page-o-nas">
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <a class="skip-link" href="#tresc">Przejdź do treści</a>
  <SiteChrome current="/o-nas" />

  <main id="tresc">
    {/* ── Hero ─────────────────────────────────────────────────────────── */}
    <section class="hero" aria-label="O nas">
      <div class="hero-media" aria-hidden="true">
        <BleedImage desktop={hero.desktop} mobile={hero.mobile} alt="" position="center 30%" eager animate />
      </div>
      <div class="hero-inner">
        <p class="eyebrow reveal"><span class="lat">De nobis</span>  ·  O nas</p>
        <h1>
          <span class="line"><span class="reveal">Zaczęło się</span></span>
          <span class="line"><span class="reveal" data-d="1">od <em>tęsknoty.</em></span></span>
        </h1>
        <p class="hero-lede reveal" data-d="2">
          {nbsp(
            "VoctEnsemble — krakowska formacja wokalna i zespół-rezydent Fundacji VoctFoundation. Zaczynamy od trzech pytań: skąd się wzięliśmy, co robimy i co śpiewamy.",
          )}
        </p>
        <span class="scroll-cue reveal" data-d="3">Przeczytaj list</span>
      </div>
    </section>

    {/* ── List założyciela — the single origin statement. VERBATIM founding text, not
          copywriting: stanza I (Z tęsknoty) + II (W ciszy) are from Florent's "Skąd się
          wzięliśmy?", stanza IV (Kruchość) from "Co śpiewamy?", stanza III (Wymiana) from the
          Kontemplacja Wcielenia booklet ("Dlaczego powstaje nasz zespół"). All Florent,
          across three source docs — never rewrite into brochure-speak. ──────── */}
    <section class="band letter" aria-label="List Florenta">
      <div class="wrap letter-wrap">
        <div class="section-head letter-head reveal">
          <span class="eyebrow"><span class="lat">Initium</span>  ·  List założyciela</span>
          <h2>Skąd się wzięliśmy?</h2>
          <p class="letter-lead">Odpowiedź założyciela — cztery akapity, od&nbsp;tęsknoty po&nbsp;kruchość.</p>
        </div>

        <div class="letter-body">
          <div class="letter-stanza reveal" data-d="1">
            <p class="letter-mark"><span class="lat">I</span> · Z tęsknoty</p>
            <p class="letter-para">
              Z tęsknoty, natchnienia i marzenia. Jak anachoreci, w odosobnieniu, z&nbsp;daleka od zgiełku i&nbsp;muzyki zatęskniono za muzyką. Wizja muzyki jako powiew ducha, który przemienia świat swoją polifonią, otulając i&nbsp;przenikając do głębi człowieka — rezonując i&nbsp;znajdując miejsce w&nbsp;jego duszy niczym żywy organizm.
            </p>
          </div>

          <div class="letter-stanza reveal" data-d="2">
            <p class="letter-mark"><span class="lat">II</span> · W ciszy</p>
            <p class="letter-para">
              W ciszy rodzi się muzyka. W&nbsp;ciszy się kontempluje. Muzyka jest kontemplacją duszy w&nbsp;czasie. Tak powstał Voct — z&nbsp;ciszy i&nbsp;kontemplacji.
            </p>
          </div>

          <div class="letter-stanza reveal" data-d="3">
            <p class="letter-mark"><span class="lat">III</span> · Wymiana</p>
            <p class="letter-para">
              Wymiana myśli i&nbsp;próba zanurzenia się w&nbsp;interpretację drugiego człowieka pobudzała inwencję muzyczną, otwierając na nowe ścieżki interpretacyjne. Interpretacja opiera się na wymianie ludzkich umiejętności i&nbsp;intuicji, które dynamicznie splatają się, by odkryć głębie ukryte w&nbsp;utworze.
            </p>
          </div>

          <div class="letter-stanza reveal" data-d="4">
            <p class="letter-mark"><span class="lat">IV</span> · Kruchość</p>
            <p class="letter-para">
              Nie czulibyśmy się sobą, śpiewając muzykę, która nie obejmowałaby całego człowieka, dotykała jego głębi i&nbsp;próbowała urzec go pięknem mimo jego złożoności i&nbsp;kruchości.
            </p>
          </div>

          <p class="letter-signature reveal" data-d="4">
            <span class="letter-sig-name">Florent de Bazelaire</span>
            <span class="letter-sig-meta">kierownictwo artystyczne · 2024</span>
          </p>
        </div>

        <figure class="letter-portrait reveal" data-d="2">
          <span class="frame-rule" aria-hidden="true"></span>
          <Picture
            src={florent}
            formats={["avif", "webp"]}
            widths={[420, 640, 840]}
            sizes="(max-width: 880px) min(70vw, 340px), clamp(240px, 26vw, 320px)"
            alt="Florent de Bazelaire prowadzący VoctEnsemble"
            loading="lazy"
            decoding="async"
          />
          <figcaption>Florent de Bazelaire · kierownictwo artystyczne</figcaption>
        </figure>
      </div>
    </section>

    {/* ── Ensemble — prose only: the roster rotates per project around a stable
          core, so no single group photo claims to be "the ensemble". ─────── */}
    <section class="band band-soft" id="zespol" aria-label="Kim jesteśmy">
      <div class="wrap">
        <div class="section-head reveal measure">
          <span class="eyebrow"><span class="lat">Voces</span>  ·  Zespół</span>
          <h2>Krakowski zespół wokalny prowadzony jak kameralna wspólnota.</h2>
        </div>
        <div class="prose measure reveal" data-d="1">
          <p class="lead">
            {nbsp(
              "Na scenie spotyka się zwykle dwanaście głosów — profesjonalnych i pre-profesjonalnych muzyków, dla których precyzja jest punktem wyjścia.",
            )}
          </p>
          <p>
            {nbsp(
              "Skład jest żywy: wokół stałego rdzenia obsada zmienia się z projektu na projekt — głosy dobieramy do programu, przestrzeni i intencji, tak jak dobiera się repertuar.",
            )}
          </p>
          <p>
            Pod kierownictwem Florenta de Bazelaire budujemy brzmienie, w&nbsp;którym
            dyscyplina i&nbsp;czułość trzymają się razem. Nazwa łączy <em>voces</em> (głosy),
            <em>octo</em> (osiem) i&nbsp;<em>ensemble</em> — obietnicę głosów, które słuchają
            siebie nawzajem, związanych więzią zarówno muzyczną, jak i&nbsp;międzyludzką.
          </p>
        </div>
        <div class="voces-collab reveal" data-d="2">
          <span class="collab-label">Współpraca</span>
          <p>
            {nbsp(
              "Na scenie i przy realizacjach spotykamy się m.in. z reżyserką świateł Adą Bystrzycką, realizatorem dźwięku Jakubem Garbaczem (Ars Sonora Studio), Sebastianem Kuźmą (animacja wizualna) i skrzypkiem Radu Ropotanem; instytucjonalnie — z Fundacją Carpe Diem i Ośrodkiem Kultury Norwida w krakowskich Mistrzejowicach.",
            )}
          </p>
        </div>
      </div>
    </section>

    {/* ── Pull-quote plate — the thesis of "Co śpiewamy?" (Florent's founding text), lifted
          into display type. It sets up the Co śpiewamy section below (call → elaboration).
          "próg" now lives once on the landing hero; this page carries "dzielimy się". ─────── */}
    <section class="plate" aria-label="Idea">
      <div class="plate-media" aria-hidden="true">
        <BleedImage desktop={plate.desktop} mobile={plate.mobile} alt="" position="center" />
      </div>
      <blockquote class="reveal">
        Nade wszystko, dzielimy się.
        <cite>VoctEnsemble</cite>
      </blockquote>
    </section>

    {/* ── Co robimy — the founder's second question, answered with real activities and
          named events (see the `doings` const). ───────────────────────────── */}
    <section class="band band-soft" aria-label="Co robimy">
      <div class="wrap">
        <div class="section-head reveal measure">
          <span class="eyebrow"><span class="lat">Operatio</span>  ·  Co robimy?</span>
          <h2>Koncerty duchowe, liturgia, ważne uroczystości.</h2>
        </div>
        <div class="prose measure reveal" data-d="1">
          <p class="lead">
            {nbsp(
              "Głównym nurtem są autorskie Koncerty Duchowe — współczesna forma dawnych Concerts Spirituels. Poza nimi śpiewamy tam, gdzie liturgia i uroczystość proszą o głos.",
            )}
          </p>
        </div>
        <div class="doings-grid">
          {
            doings.map((d, i) => (
              <article class="doing reveal" data-d={String((i % 3) + 1)}>
                <h3>{d.k}</h3>
                <p>{nbsp(d.p)}</p>
                {d.href && (
                  <a class="inline" href={d.href}>
                    {d.cta}
                  </a>
                )}
              </article>
            ))
          }
        </div>
      </div>
    </section>

    {/* ── Co śpiewamy — the founder's third question ("Co śpiewamy?"): the credo, verbatim in
          spirit. The seven-century repertoire catalog lives on /koncerty#repertuar (one home
          per idea) — this section links to it instead of re-listing composers. ─────── */}
    <section class="band" aria-label="Co śpiewamy">
      <div class="wrap">
        <div class="section-head reveal measure">
          <span class="eyebrow"><span class="lat">Cantus</span>  ·  Co śpiewamy?</span>
          <h2>Muzyka jako odbicie duszy słowa.</h2>
        </div>
        <div class="prose measure reveal" data-d="1">
          <p class="lead">
            {nbsp(
              "Dzielimy się śpiewem i przemyślanymi narracjami — utkanymi z utworów, w których muzyka i słowo są swoimi lustrzanymi odbiciami.",
            )}
          </p>
          <p>
            {nbsp(
              "Interesuje nas świat: widzialny — przyroda i całe stworzenie — oraz ten niematerialny, którego szukamy i próbujemy zrozumieć. Muzyka sakralna jest w tej wędrówce dobrą towarzyszką.",
            )}
          </p>
          <p>
            {nbsp(
              "Czerpie z geniuszu ludzkiego, z Biblii i z mądrości przodków, po którą kompozytorzy wciąż sięgają, by wyrazić na wskroś osobisty sposób to, co przeżywają i co ich najbardziej dotyka.",
            )}
          </p>
          <p class="cantus-more">
            <a class="inline" href="/koncerty#repertuar">
              Repertuar siedmiu wieków — od Llibre Vermell po współczesność →
            </a>
          </p>
        </div>
      </div>
    </section>

    {/* ── Milestones — rendered from the `concerts` collection ─────────── */}
    <section class="band band-soft" aria-label="Droga koncertów">
      <div class="wrap">
        <div class="section-head reveal measure">
          <span class="eyebrow"><span class="lat">Via</span>  ·  Co już wybrzmiało</span>
          <h2>Krótka droga, ale już zapisana miejscami i intencjami.</h2>
        </div>
        <ol class="milestones">
          {
            milestones.map((m) => (
              <li class:list={["reveal", { "no-media": !m.img }]} data-d={m.d}>
                <span class="milestone-date">{m.year}</span>
                {m.img && (
                  <figure class="milestone-media">
                    <Picture
                      src={m.img}
                      formats={["avif", "webp"]}
                      widths={[320, 480, 640, 840]}
                      sizes="(max-width: 700px) min(92vw, 420px), clamp(200px, 24vw, 320px)"
                      alt=""
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
                <div class="milestone-body">
                  <span class="milestone-place">{m.place}</span>
                  <h3>{m.title}</h3>
                  <p>{m.body}</p>
                </div>
              </li>
            ))
          }
        </ol>
        <div class="prose milestones-more reveal" data-d="4">
          <p><a class="inline" href="/koncerty">Zobacz repertuar i szczegóły koncertów →</a></p>
        </div>
      </div>
    </section>

    {/* ── Foundation ───────────────────────────────────────────────────── */}
    <section class="band" id="fundacja" aria-label="Fundacja VoctFoundation">
      <div class="wrap">
        <div class="section-head reveal measure">
          <span class="eyebrow"><span class="lat">Fundatio</span>  ·  Fundacja</span>
          <h2>Forma, która pozwala muzyce mieć ciągłość.</h2>
        </div>
        <div class="prose measure reveal" data-d="1">
          <p class="lead">
            {nbsp(
              "VoctFoundation jest prawnym i organizacyjnym zapleczem działalności artystycznej. To dzięki niej zespół może myśleć nie tylko o kolejnym koncercie, ale o archiwum, edukacji, produkcji i długim trwaniu repertuaru.",
            )}
          </p>
          <p>
            Statutowo Fundacja działa w&nbsp;obszarze <strong>kultury, sztuki, ochrony dóbr kultury
            i&nbsp;dziedzictwa narodowego</strong>. Może prowadzić projekty artystyczne
            i&nbsp;interdyscyplinarne, utrwalać nagrania, wspierać młodych artystów oraz działać przez
            stały zespół artystyczny w&nbsp;formule zespołu-rezydenta.
          </p>
        </div>
        <ol class="goals reveal" data-d="2" aria-label="Cele statutowe Fundacji">
          {
            goals.map((g, i) => (
              <li>
                <span class="g-num">{String(i + 1).padStart(2, "0")}</span>
                <span>{nbsp(g)}</span>
              </li>
            ))
          }
        </ol>
        <div class="legal-card reveal" data-d="3">
          <div class="legal-grid">
            <div><span class="k">KRS</span><span class="v">0001237252</span></div>
            <div><span class="k">NIP</span><span class="v">6762718992</span></div>
            <div><span class="k">REGON</span><span class="v">544621525</span></div>
          </div>
          <p class="legal-note">
            {nbsp(
              "Dochody Fundacji przeznaczane są w całości na realizację celów statutowych. Nie podlegają podziałowi między fundatora, członków organów ani osoby związane z Fundacją; działalność gospodarcza, jeżeli jest prowadzona, pozostaje pomocnicza wobec misji statutowej.",
            )}
          </p>
          <div class="legal-foot">
            <span>Fundacja VoctFoundation · ul. Św. Filipa 23/3, 31-150 Kraków</span>
            <a class="btn" href="/docs/Statut-VoctFoundation.pdf" target="_blank" rel="noopener">
              Statut fundacji ↗
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ── Governance ───────────────────────────────────────────────────── */}
    <section class="band band-deep" id="zarzad" aria-label="Zarząd fundacji">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="eyebrow"><span class="lat">Consilium</span>  ·  Zarząd</span>
          <h2>Odpowiedzialność rozpisana na trzy głosy.</h2>
        </div>
        <p class="board-intro reveal" data-d="1">
          {nbsp(
            "Fundacja ma jedno zadanie: utrzymać jakość — artystyczną, organizacyjną i cyfrową — tak, aby projekty mogły dojrzewać, wracać i zostawiać po sobie ślad.",
          )}
        </p>
        <div class="board">
          {
            board.map((b, i) => (
              <article class="board-card reveal" data-d={String(i + 1)}>
                {boardPortraitsComplete && b.img && (
                  <figure class="board-portrait">
                    <Picture
                      src={b.img}
                      formats={["avif", "webp"]}
                      widths={[240, 360, 480]}
                      sizes="(max-width: 860px) 90vw, 30vw"
                      alt={`${b.name} — ${b.role}`}
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
                <h3>{b.name}</h3>
                <p class="role">{b.role}</p>
                <p class="vision">{nbsp(b.vision)}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    {/* ── CTA — closed by the votive glyph (every subpage wybrzmiewa) ──── */}
    <section class="band cta-band" aria-label="Zaproszenie do kontaktu">
      <div class="wrap reveal">
        <span class="cta-glyph" aria-hidden="true"></span>
        <h2>Zaproście nas do przestrzeni, która potrzebuje głosu.</h2>
        <p>
          {nbsp(
            "Koncert duchowy, oprawa liturgii, ważna uroczystość, mecenat albo współpraca artystyczna. Czekamy na Wasz kontakt.",
          )}
        </p>
        <div class="btn-row">
          <a class="btn btn-gold" href="/kontakt">Napisz do nas</a>
          <a class="btn" href="/koncerty">Koncerty Duchowe</a>
          <a class="btn" href="/?donate" data-vault-open="100">Wesprzyj fundację</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />

  <VaultIsland client:idle />
  <script>
    import "../scripts/vault-triggers.ts";
  </script>
</BaseLayout>

