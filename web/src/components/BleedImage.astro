---
/**
 * @file BleedImage.astro
 * @description Art-directed full-bleed image for heroes / full-screen sections. Takes
 *  separate desktop + mobile source imports (originals living under src/assets) and emits an
 *  optimized <picture>: AVIF + WebP at responsive widths, generated at build time by Astro's
 *  image pipeline (Sharp). Carries its own cover crop + native scroll-driven parallax (zero JS).
 *  Content (in-flow) images should use <Image> directly; this is only for edge-to-edge media.
 * @architecture Astro islands 2026
 * @module components/BleedImage
 */
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  desktop: ImageMetadata;
  mobile: ImageMetadata;
  alt: string;
  /** object-position for the cover crop, e.g. "center 40%". */
  position?: string;
  /** Above-the-fold hero → eager + high fetch priority. */
  eager?: boolean;
  /** max-width (px) below which the mobile crop is served. */
  breakpoint?: number;
  /** Add slow Ken Burns animation. */
  animate?: boolean;
}

const { desktop, mobile, alt, position = "center", eager = false, breakpoint = 760, animate = false } =
  Astro.props;

const DESKTOP_WIDTHS = [1280, 1920, 2560];
const MOBILE_WIDTHS = [640, 828, 1080, 1290];

async function srcset(
  img: ImageMetadata,
  widths: number[],
  format: "avif" | "webp",
): Promise<string> {
  const usable = widths.filter((w) => w <= img.width);
  if (usable.length === 0) usable.push(img.width);
  const built = await Promise.all(
    usable.map((w) => getImage({ src: img, width: w, format })),
  );
  return built.map((b, i) => `${b.src} ${usable[i]}w`).join(", ");
}

const [dAvif, dWebp, mAvif, mWebp, fallback] = await Promise.all([
  srcset(desktop, DESKTOP_WIDTHS, "avif"),
  srcset(desktop, DESKTOP_WIDTHS, "webp"),
  srcset(mobile, MOBILE_WIDTHS, "avif"),
  srcset(mobile, MOBILE_WIDTHS, "webp"),
  getImage({ src: desktop, width: 1920, format: "webp" }),
]);

const mq = `(max-width: ${breakpoint}px)`;
---

<picture class="bleed" style={`--bleed-pos:${position}`} data-parallax="0.16">
  <source media={mq} type="image/avif" srcset={mAvif} sizes="100vw" />
  <source media={mq} type="image/webp" srcset={mWebp} sizes="100vw" />
  <source type="image/avif" srcset={dAvif} sizes="100vw" />
  <source type="image/webp" srcset={dWebp} sizes="100vw" />
  <img
    src={fallback.src}
    width={desktop.width}
    height={desktop.height}
    alt={alt}
    loading={eager ? "eager" : "lazy"}
    fetchpriority={eager ? "high" : "auto"}
    decoding="async"
    class={animate ? "is-animated" : undefined}
  />
</picture>

<style>
  .bleed {
    display: block;
    position: absolute;
    top: -10%;
    left: 0;
    width: 100%;
    height: 120%;
    will-change: transform;
  }
  .bleed img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--bleed-pos, center);
  }
  .bleed img.is-animated {
    will-change: transform;
    animation: bleedKenBurns 38s ease-in-out infinite alternate;
  }
  @keyframes bleedKenBurns {
    0% { transform: scale(1.06) translate3d(0, 0, 0); }
    50% { transform: scale(1.12) translate3d(-1.4%, -0.8%, 0); }
    100% { transform: scale(1.08) translate3d(1.2%, 0.6%, 0); }
  }
  /* Parallax drift is applied via JS (the [data-parallax] controller in BaseLayout) so it
     works in every browser — native scroll-driven animation-timeline is still partial in
     Firefox / older Safari. The 120% height gives the drift room to never expose an edge. */
  @media (prefers-reduced-motion: reduce) {
    .bleed { top: 0; height: 100%; transform: none !important; }
    .bleed img.is-animated { animation: none; transform: scale(1.02); }
  }
</style>
