---
/**
 * @file PathSection.astro
 * @description "Wcześniejsze wybrzmienia" — typographic register of past Concerts Spirituels.
 *  Read as a memorium on an altar, not as a portfolio grid: roman numeral + year + tag in the
 *  left rail, title + place in the right rail, optional expandable repertoire/programme below.
 *  Hairline rules separate entries. No poster images — the rite doesn't market itself by face.
 *  Each entry's native <details> snap open/close is upgraded to an animated, exclusive
 *  accordion by scripts/landing.ts (same `.path-card-detail` hook so the JS contract holds).
 * @architecture Astro islands 2026
 * @module components/landing/PathSection
 */
import { PATHS } from "../../data/landing/paths";

const ROMAN = ["I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX", "X"] as const;
---

<section class="section path" id="droga" aria-label="Wcześniejsze wybrzmienia">
  <div class="section-grid">
    <div class="section-label micro"><span>Z drogi</span></div>
    <div class="path-body">
      <h2 class="section-title reveal">Wcześniejsze<br />wybrzmienia.</h2>
      <p class="path-lede reveal">
        Od renesansowej polifonii po współczesne misteria — koncerty, które pozostają
        żywe i mogą wybrzmieć na nowo w kolejnych przestrzeniach.
      </p>

      <ol class="path-register" aria-label="Wcześniejsze koncerty cyklu">
        {
          PATHS.map((path, i) => (
            <li class="path-entry reveal">
              <div class="path-entry-rail">
                <span class="path-entry-roman">{ROMAN[i]}</span>
                <span class="path-entry-year">{path.year}</span>
                <span class="path-entry-tag">{path.tag}</span>
              </div>
              <div class="path-entry-body">
                <h3 class="path-entry-title">{path.title}</h3>
                <p class="path-entry-place">{path.place}</p>
                <p class="path-entry-summary">{path.note}</p>
                <details class="path-card-detail path-entry-detail">
                  <summary>
                    <span>{path.detail.summary}</span>
                    <span class="path-detail-icon" aria-hidden="true" />
                  </summary>
                  {path.detail.content.works && (
                    <ol class="path-works">
                      {path.detail.content.works.map((work) => (
                        <li class:list={[{ "path-works-bis": work.bis }]}>
                          {work.text}
                          {work.italic && <em>{work.italic}</em>}
                        </li>
                      ))}
                    </ol>
                  )}
                  {path.detail.content.paragraphs?.map((paragraph) => (
                    <p class="path-detail-text">{paragraph}</p>
                  ))}
                  {path.detail.content.note && (
                    <p class="path-works-note">{path.detail.content.note}</p>
                  )}
                </details>
              </div>
            </li>
          ))
        }
      </ol>

      {/* The register's open card — the narrative payoff of the whole section:
          manifest → memory of past concerts → the next one depends on you. The
          numeral continues the sequence; the entry stays "unwritten" until the
          listeners write it. When a concert is scheduled, this card becomes its
          announcement (title, date, place) and a new blank one takes its seat. */}
      <aside class="path-entry path-next reveal" aria-label="Następny koncert cyklu">
        <div class="path-entry-rail">
          <span class="path-entry-roman">{ROMAN[PATHS.length]}</span>
          <span class="path-entry-year">MMXXVI</span>
          <span class="path-entry-tag">powstaje teraz</span>
        </div>
        <div class="path-entry-body">
          <h3 class="path-entry-title">Następne wybrzmienie.</h3>
          <p class="path-entry-place">Termin i przestrzeń wyznaczą darczyńcy</p>
          <p class="path-entry-summary">
            Ten koncert istnieje już w partyturach i próbach — brakuje mu tylko
            przestrzeni, w której wybrzmi. Każda darowizna przybliża jego datę.
          </p>
          <a
            class="primary-link path-next-cta plausible-event-name=path+next+wesprzyj"
            href="#wesprzyj"
            data-no-lenis
            data-vault-open="100"
          >
            Pomóż mu wybrzmieć
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>
