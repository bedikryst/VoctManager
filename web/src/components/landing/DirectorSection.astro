---
/**
 * @file DirectorSection.astro
 * @description Florent de Bazelaire — artistic direction. Side-by-side portrait (<Picture>,
 *  optimized AVIF/WebP) + bio. Lives inside the dark "wnętrze chóru" sequence
 *  (ImageRite → Ensemble → Director) — the .director-dark wrapper turns the section dark
 *  and is also registered in StickyHeader's DARK_SELECTORS so the chrome inverts here.
 *  Copy policy: only verified public facts (the 1725 Concert Spirituel history, the
 *  cycle's real venues and intentions). Florent's personal biography (Warsaw, studies,
 *  Jesuit years) is deliberately ABSENT until he supplies an authorized biogram — never
 *  publish unconfirmed life details.
 * @architecture Astro islands 2026
 * @module components/landing/DirectorSection
 */
import { Picture } from "astro:assets";
import { photo } from "../../lib/photos";

const florent = photo("florent");
---

<section class="section director-dark" aria-label="Kierownictwo artystyczne">
  <div class="director-grid">
    <div class="portrait reveal reveal-img">
      <Picture
        src={florent}
        formats={["avif", "webp"]}
        widths={[480, 760, 1040]}
        sizes="(max-width: 980px) 100vw, 46vw"
        alt="Florent de Bazelaire prowadzący VoctEnsemble"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="director-copy reveal">
      <div class="role micro">Kierownictwo artystyczne</div>
      <h2>Florent<br />de Bazelaire</h2>
      <p>
        Nazwa cyklu sięga Paryża roku 1725: Concert Spirituel śpiewał w te wieczory,
        w które milkła opera. Trzysta lat później Florent de Bazelaire podejmuje tę
        tradycję na nowo — w bazylikach Krakowa i Łodzi, w Szczawnicy i Niedzicy.
      </p>
      <p>
        Każdy program układa wokół jednej intencji: tajemnica Wcielenia na debiut —
        <em>Kontemplacja Wcielenia</em> (2024) — dziewięć kart z Księgi Psalmów,
        modlitwa o pokój w Bazylice Mariackiej, epitafium dla Gazy.
      </p>
      <p>
        Równolegle prowadzi VoctFoundation — fundację, która ma dać tej muzyce stałe
        miejsce.
      </p>
    </div>
  </div>
</section>
