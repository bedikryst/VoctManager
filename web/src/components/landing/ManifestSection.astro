---
/**
 * @file ManifestSection.astro
 * @description Three-stanza ensemble manifest + the answer line. Rigid editorial grid;
 *  the raking light (setupManifestRake in landing.ts) lifts each stanza from half-light
 *  to full ink as it crosses the beam — colour and a faint gold bloom only, never the
 *  weight axis (wght animation reflows glyph widths, which read as the text "jumping").
 *  "Odsłania." is its own group: it arms independently, after stanza III has settled.
 * @architecture Astro islands 2026
 * @module components/landing/ManifestSection
 */
import { MANIFEST_ANSWER, MANIFEST_LINES } from "../../data/landing/manifestLines";
---

<section class="section manifest" id="manifest" aria-label="Manifest chóru VoctEnsemble">
  <div class="manifest-container">
    <div class="manifest-top reveal">
      <div class="manifest-meta-col">
        <span class="manifest-label">01</span>
        <span class="manifest-label">Manifest</span>
      </div>
      <div class="manifest-meta-col" style="text-align: right;">
        <span class="manifest-label">VoctEnsemble</span>
      </div>
    </div>

    <div class="manifest-content">
      {
        MANIFEST_LINES.map((line) => (
          <div class="manifest-line-group reveal">
            <div class="manifest-roman">{line.index}</div>
            <p class="manifest-statement">
              <span class="manifest-text-inner">{line.text}</span>
            </p>
          </div>
        ))
      }

      {/* The answer — no numeral (it is not a fourth thesis), its own beam trigger. */}
      <div class="manifest-line-group manifest-answer reveal">
        <div class="manifest-roman" aria-hidden="true"></div>
        <p class="manifest-statement manifest-answer-statement">
          <em class="manifest-emphasis">{MANIFEST_ANSWER}</em>
        </p>
      </div>
    </div>
  </div>
</section>
