---
/**
 * @file ImageRiteSection.astro
 * @description The "light" section — full-bleed dimmed photo (<BleedImage>, parallax) behind a
 *  centered quote, with a cursor-tracked spotlight (rite-glow) on desktop fine pointers. The
 *  dimming filter is applied in landing.css (.image-rite .bleed img); the spotlight via
 *  scripts/landing.ts.
 * @architecture Astro islands 2026
 * @module components/landing/ImageRiteSection
 */
import BleedImage from "../BleedImage.astro";
import { bleedPair } from "../../lib/photos";

const rite = bleedPair("chor-spot");
---

<section class="image-rite" id="rite" aria-label="Światło">
  <BleedImage desktop={rite.desktop} mobile={rite.mobile} alt="" position="center 42%" />
  <div class="rite-glow" aria-hidden="true"></div>
  <div class="rite-quote reveal">
    <svg class="mark" viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <circle cx="32" cy="32" r="3" stroke="currentColor" stroke-width="1" />
      <path
        d="M32 5V23M32 41V59M5 32H23M41 32H59M13 13L25 25M39 39L51 51M51 13L39 25M25 39L13 51"
        stroke="currentColor"
        stroke-width="1"
      />
    </svg>
    <h2>Światło prowadzi słuchacza.</h2>
    <p>
      Nie jako efekt sceniczny. Jako oddech, napięcie i moment, w którym przestrzeń
      zaczyna słuchać razem z nami.
    </p>
  </div>
</section>
