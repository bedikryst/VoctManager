---
/**
 * @file AetherInterlude.astro
 * @description Liturgical interlude between sections (I · Lumen quaerit, II · Vox memoriae,
 *  III · Sustinete nos). Renders an aether-knot SVG keyed to its variant — ascending wisps,
 *  concentric echo rings, or a vesica piscis. The `#ethereal-glow` filter is defined once in
 *  the "passage" SVG and referenced by id from the others (all three render on the page).
 * @architecture Astro islands 2026
 * @module components/landing/AetherInterlude
 */
type Variant = "passage" | "memory" | "offering";
interface Props {
  variant: Variant;
  roman: string;
  latin: string;
}
const { variant, roman, latin } = Astro.props;
---

<div class="aether-interlude reveal" data-variant={variant} aria-hidden="true">
  <span class="aether-inscription">
    <span class="roman">{roman}</span>
    <span class="dot">·</span>
    <span class="latin">{latin}</span>
  </span>
  <div class="aether-row">
    <div class="aether-line"></div>
    <div class="aether-knot">
      {
        variant === "passage" && (
          <svg viewBox="0 0 180 60" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <defs>
              <filter id="ethereal-glow" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="3" result="blur" />
                <feMerge>
                  <feMergeNode in="blur" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
            </defs>
            <line x1="0" y1="30" x2="180" y2="30" stroke-width="0.5" stroke-opacity="0.2" />
            <path class="knot-wave knot-wave-top" d="M 0,30 C 45,30 60,10 90,10 C 120,10 135,30 180,30" stroke-width="0.75" stroke-opacity="0.5" />
            <path class="knot-wave knot-wave-bottom" d="M 0,30 C 45,30 60,50 90,50 C 120,50 135,30 180,30" stroke-width="0.75" stroke-opacity="0.5" />
            <path class="knot-wave knot-harmonic-top" d="M 20,30 C 50,30 65,20 90,20 C 115,20 130,30 160,30" stroke-width="0.5" stroke-opacity="0.3" />
            <path class="knot-wave knot-harmonic-bottom" d="M 20,30 C 50,30 65,40 90,40 C 115,40 130,30 160,30" stroke-width="0.5" stroke-opacity="0.3" />
            <line class="ascend-wisp w1" x1="90" y1="50" x2="90" y2="34" stroke-width="0.6" stroke-opacity="0.6" />
            <line class="ascend-wisp w2" x1="85" y1="50" x2="85" y2="40" stroke-width="0.35" stroke-opacity="0.4" />
            <line class="ascend-wisp w3" x1="95" y1="50" x2="95" y2="40" stroke-width="0.35" stroke-opacity="0.4" />
            <circle class="knot-light" cx="90" cy="30" r="2" fill="currentColor" stroke="none" filter="url(#ethereal-glow)" />
          </svg>
        )
      }
      {
        variant === "memory" && (
          <svg viewBox="0 0 200 60" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <line x1="0" y1="30" x2="200" y2="30" stroke-width="0.5" stroke-opacity="0.2" />
            <path class="knot-wave knot-wave-top" d="M 10,30 C 55,30 70,10 100,10 C 130,10 145,30 190,30" stroke-width="0.75" stroke-opacity="0.4" />
            <path class="knot-wave knot-wave-bottom" d="M 10,30 C 55,30 70,50 100,50 C 130,50 145,30 190,30" stroke-width="0.75" stroke-opacity="0.4" />
            <circle class="echo-ring r1" cx="100" cy="30" r="6" fill="none" stroke-width="0.5" />
            <circle class="echo-ring r2" cx="100" cy="30" r="11" fill="none" stroke-width="0.45" />
            <circle class="echo-ring r3" cx="100" cy="30" r="17" fill="none" stroke-width="0.4" />
            <circle class="knot-light" cx="100" cy="30" r="2" fill="currentColor" stroke="none" filter="url(#ethereal-glow)" />
          </svg>
        )
      }
      {
        variant === "offering" && (
          <svg viewBox="0 0 180 60" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <line x1="0" y1="30" x2="180" y2="30" stroke-width="0.5" stroke-opacity="0.2" />
            <circle class="vesica-half v-left" cx="80" cy="30" r="14" fill="none" stroke-width="0.6" />
            <circle class="vesica-half v-right" cx="100" cy="30" r="14" fill="none" stroke-width="0.6" />
            <circle class="knot-light" cx="90" cy="30" r="2" fill="currentColor" stroke="none" filter="url(#ethereal-glow)" />
          </svg>
        )
      }
    </div>
    <div class="aether-line"></div>
  </div>
</div>
