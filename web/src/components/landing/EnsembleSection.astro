---
/**
 * @file EnsembleSection.astro
 * @description "Zaczęło się od tęsknoty." — ensemble origin story over a dark full-bleed
 *  choir image (<BleedImage>, parallax) with three fact tiles. The copy QUOTES the founding
 *  text ("Skąd się wzięliśmy?" — anachoreci, "z ciszy i kontemplacji", "ubóstwiamy
 *  heterofonię…"): keep it testimony, never rewrite it into brochure-speak. Fact tiles carry
 *  real, checkable numbers (roster count from Florent's "VE na stronę www" sheet — update
 *  when the roster changes; repertoire span = Llibre Vermell XIV w. → Caroline Shaw 2017).
 *  Dimming filter in landing.css (.ensemble-media .bleed img).
 * @architecture Astro islands 2026
 * @module components/landing/EnsembleSection
 */
import BleedImage from "../BleedImage.astro";
import { bleedPair } from "../../lib/photos";

const ensemble = bleedPair("chor-nawa");

const FACTS = [
  { num: "44", label: "śpiewaków we wspólnocie · na scenie dwanaście głosów" },
  { num: "2024", label: "debiut · Kontemplacja Wcielenia · Bazylika NSPJ" },
  { num: "VII wieków", label: "od Llibre Vermell (XIV w.) po Caroline Shaw (2017)" },
] as const;
---

<section class="ensemble" id="zespol" aria-label="Zespół">
  <div class="ensemble-media" aria-hidden="true">
    <BleedImage desktop={ensemble.desktop} mobile={ensemble.mobile} alt="" position="center 32%" />
  </div>
  <div class="ensemble-inner section">
    {/* Each block is its own .reveal (not one column-sized block) so it enters
        element-by-element as you scroll — the granular register feel of "Z drogi" —
        instead of the whole copy popping in at once on the phone. */}
    <div class="ensemble-copy">
      <div class="ensemble-lede reveal">
        <div class="micro">Skąd się wzięliśmy?</div>
        <h2>Zaczęło się<br />od tęsknoty.</h2>
      </div>
      <p class="ensemble-origin reveal">
        Jak anachoreci — w odosobnieniu, z daleka od zgiełku — zatęskniliśmy za muzyką,
        która otula, przenika i zostaje w duszy niczym żywy organizm. Tak powstał Voct:
        z ciszy i kontemplacji.
      </p>
      <p class="reveal">
        Dziś jest nas ponad czterdzieścioro; na koncert wychodzi zwykle dwanaście
        głosów. Ubóstwiamy heterofonię, politonalność i polifonię — programy tkamy
        z utworów, w których słowo i muzyka są swoimi lustrzanymi odbiciami.
      </p>
      <div class="ensemble-facts reveal">
        {
          FACTS.map((fact) => (
            <div class="fact">
              <span class="fact-num">{fact.num}</span>
              <span class="fact-label">{fact.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
