---
/**
 * @file SiteChrome.astro
 * @description Shared marketing navigation (header). Lifted from MarketingChrome.tsx +
 *  the chrome CSS the SPA duplicated in every page stylesheet — now scoped once here.
 *  The scroll/menu behavior is a tiny document-delegated script (no per-element rebinding),
 *  so it survives ClientRouter swaps without leaking listeners.
 * @architecture Astro islands 2026
 * @module components/SiteChrome
 */
interface Props {
  /** Path of the current page so the matching nav link gets aria-current. */
  current?: string;
  /** "dark" pages (koncerty) get a night solid header + an is-light state over paper sections. */
  tone?: "light" | "dark";
}
const { current, tone = "light" } = Astro.props;

const links = [
  { href: "/o-nas", label: "O nas" },
  { href: "/koncerty", label: "Koncerty" },
  { href: "/kontakt", label: "Kontakt" },
] as const;
---

<header class="chrome" id="chrome" data-tone={tone} aria-label="Nawigacja">
  {/* The brand is part of the page root snapshot — it fades through the dark threshold with
      everything else (transitions.css) rather than morphing as a shared element. A shared
      element only ever showed artifacts here (position slip vs. is-solid padding, ink↔candle
      colour flip, and a different glyph anatomy on the landing), so it was removed. */}
  <a class="chrome-brand" href="/" aria-label="VoctEnsemble — strona główna">
    <span class="brand-mark" aria-hidden="true"></span>
    <span>VoctEnsemble</span>
  </a>

  <nav class="chrome-nav" aria-label="Nawigacja główna">
    {
      links.map((l) => (
        <a href={l.href} aria-current={current === l.href ? "page" : undefined}>
          {l.label}
        </a>
      ))
    }
    <a class="nav-support" href="/?donate" data-vault-open="100">Wesprzyj</a>
  </nav>

  <button
    class="nav-toggle"
    id="navToggle"
    type="button"
    aria-expanded="false"
    aria-controls="navMenu"
    aria-label="Menu"></button>

  {/* "Antyfona" — the shared mobile overlay (nave-menu.css). The card carries NO brand of its
      own: the bar's .chrome-brand persists ABOVE the overlay (z-index 61, tinted to ink — see
      the style block), so the mark never blinks. Each link carries its destination's Latin
      incipit, so the menu reads as the site's antiphon. */}
  <nav class="nave" id="navMenu" aria-label="Nawigacja główna">
    <div class="nave-veil"></div>

    <div class="nave-inner">
      <div class="nave-top">
        <button class="nave-close" id="menuClose" type="button" aria-label="Zamknij menu">Zamknij</button>
      </div>

      <div class="nave-list">
        <a class="voice" href="/" aria-current={current === "/" ? "page" : undefined}>
          <span class="voice-lat">Introitus</span>
          <span class="voice-pl">Główna</span>
        </a>
        <a class="voice" href="/o-nas" aria-current={current === "/o-nas" ? "page" : undefined}>
          <span class="voice-lat">De nobis</span>
          <span class="voice-pl">O nas</span>
        </a>
        <a class="voice" href="/koncerty" aria-current={current === "/koncerty" ? "page" : undefined}>
          <span class="voice-lat">Via</span>
          <span class="voice-pl">Koncerty</span>
        </a>
        <a class="voice" href="/kontakt" aria-current={current === "/kontakt" ? "page" : undefined}>
          <span class="voice-lat">Scribe nobis</span>
          <span class="voice-pl">Kontakt</span>
        </a>
      </div>

      <div class="nave-foot">
        <a class="nave-cta" href="/?donate" data-vault-open="100">Wesprzyj <em>· Sustinete nos</em></a>
        {/* The antiphon names its hour — filled with the live canonical hour on open (script
            below), so the menu carries the time of day, not a static motto. */}
        <span class="nave-colophon">
          <span class="nave-colophon-mark" aria-hidden="true"></span>
          <span class="nave-hora"><span id="naveHoraName">Hora</span> · <em id="naveHoraPoem">canonica</em></span>
        </span>
      </div>
    </div>
  </nav>
</header>

<style>
  .chrome { position: fixed; inset: 0 0 auto 0; z-index: 50; display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: calc(env(safe-area-inset-top, 0px) + 22px) max(28px, 5vw); color: var(--paper); background: transparent; border-bottom: 1px solid transparent; transition: color .5s var(--ease), background-color .5s var(--ease), border-color .5s var(--ease), padding .5s var(--ease), backdrop-filter .5s var(--ease); }
  .chrome::before { content: ""; position: absolute; inset: 0; z-index: -1; pointer-events: none; background: linear-gradient(180deg, rgba(8,8,7,.5) 0%, rgba(8,8,7,0) 100%); opacity: 1; transition: opacity .5s var(--ease); }
  /* Glass rides a ::after LAYER, not the .chrome root. A non-`none` backdrop-filter turns its
     element into the containing block for `position: fixed` descendants — and the "Antyfona"
     overlay (.nave) is a fixed child of .chrome. On the root, a scrolled (solid) bar clipped the
     mobile overlay to the bar height; keeping the root filter-free lets .nave fill the viewport. */
  .chrome::after { content: ""; position: absolute; inset: 0; z-index: -1; pointer-events: none; border-bottom: 1px solid transparent; opacity: 0; transition: opacity .5s var(--ease), background-color .5s var(--ease), border-color .5s var(--ease); }
  .chrome.is-solid::after { opacity: 1; background-color: rgba(244, 241, 233, 0.82); backdrop-filter: blur(20px) saturate(1.5); -webkit-backdrop-filter: blur(20px) saturate(1.5); border-bottom-color: rgba(22, 21, 20, 0.08); }
  .chrome.is-solid { color: var(--ink); padding-top: calc(env(safe-area-inset-top, 0px) + 16px); padding-bottom: 14px; }
  .chrome.is-solid::before { opacity: 0; }

  /* z-index 61 lifts the brand ABOVE the "Antyfona" overlay (.nave, z:60) — it is the ONE bar
     element that persists while the card is open, so the mark never blinks out and back in. */
  .chrome-brand { display: inline-flex; align-items: center; gap: 12px; font-family: var(--serif); font-size: 21px; font-weight: 300; letter-spacing: .03em; color: inherit; position: relative; z-index: 61; }
  .chrome-brand .brand-mark { width: 17px; height: 40px; flex-shrink: 0; background: var(--candle); -webkit-mask: url(/logo-mark.png) center / contain no-repeat; mask: url(/logo-mark.png) center / contain no-repeat; transition: background-color .5s var(--ease); }
  .chrome.is-solid .chrome-brand .brand-mark { background: var(--ink); }

  .chrome-nav { display: flex; align-items: center; gap: clamp(16px, 2.4vw, 34px); }
  .chrome-nav a { font-family: var(--mono); font-size: 10.5px; letter-spacing: .2em; text-transform: uppercase; color: inherit; opacity: .82; position: relative; padding-bottom: 3px; transition: opacity .35s var(--ease); }
  .chrome-nav a::after { content: ""; position: absolute; left: 0; bottom: 0; width: 100%; height: 1px; background: currentColor; transform: scaleX(0); transform-origin: left; transition: transform .4s var(--ease); }
  .chrome-nav a:hover { opacity: 1; }
  .chrome-nav a:hover::after, .chrome-nav a[aria-current="page"]::after { transform: scaleX(1); }
  .chrome-nav a[aria-current="page"] { opacity: 1; color: var(--candle); }
  .chrome-nav .nav-support { color: var(--candle); opacity: 1; }

  /* Mobile menu */
  .nav-toggle { display: none; position: relative; width: 26px; height: 14px; border: 0; background: transparent; color: inherit; cursor: pointer; padding: 0; }
  .nav-toggle::before, .nav-toggle::after { content: ""; position: absolute; right: 0; height: 1px; background: currentColor; transition: width .35s var(--ease); }
  .nav-toggle::before { top: 4px; width: 26px; }
  .nav-toggle::after { top: 10px; width: 15px; }
  .nav-toggle:hover::after { width: 26px; }

  /* When the "Antyfona" card opens, only the TOGGLE clears (the card carries "Zamknij"); the
     brand stays put above the card and eases to ink with the card's fade — see the menu-open
     overrides at the END of this block (they must follow the dark-tone rules to win the tie). */
  .nav-toggle { transition: opacity .3s var(--ease); }
  .chrome.menu-open .nav-toggle,
  .chrome.menu-closing .nav-toggle { opacity: 0; pointer-events: none; transition: opacity .12s var(--ease); }
  .chrome-brand { transition: color .32s var(--ease); }

  /* 759.98 / 760 boundary matches nave-menu.css so no fractional viewport falls between
     "hamburger shown" and "overlay available". */
  @media (max-width: 759.98px) {
    .chrome-nav { display: none; }
    .nav-toggle { display: inline-flex; }
  }

  /* ── Dark-tone pages (koncerty) ─────────────────────────────────────────
     Solid header is night (not paper); when a light section scrolls under it,
     the page toggles .is-light to flip to the paper treatment. */
  .chrome[data-tone="dark"].is-solid::after {
    opacity: 1;
    background-color: rgba(16, 15, 13, 0.72);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    border-bottom-color: rgba(244, 241, 233, 0.12);
  }
  .chrome[data-tone="dark"].is-solid { color: var(--paper); }
  .chrome[data-tone="dark"].is-solid .chrome-brand .brand-mark { background: var(--candle); }

  /* is-light can be set independently of is-solid (a paper section under a not-yet-scrolled bar),
     so the paper glass must carry its own opacity rather than borrow it from is-solid::after. */
  .chrome[data-tone="dark"].is-light::after {
    opacity: 1;
    background-color: rgba(244, 241, 233, 0.82);
    backdrop-filter: blur(20px) saturate(1.1);
    -webkit-backdrop-filter: blur(20px) saturate(1.1);
    border-bottom-color: rgba(22, 21, 20, 0.1);
  }
  .chrome[data-tone="dark"].is-light { color: var(--ink); }
  .chrome[data-tone="dark"].is-light::before { opacity: 0; }
  .chrome[data-tone="dark"].is-light .chrome-brand .brand-mark { background: var(--ink); }

  /* ── "Antyfona" open: the persistent brand goes ink over the parchment card ────────────────
     LAST in this block on purpose — these tie with the tone/scroll mark rules above on
     specificity, and source order is what makes the open state win in every combination. */
  .chrome.menu-open .chrome-brand,
  .chrome.menu-closing .chrome-brand { color: var(--ink); }
  .chrome.menu-open .chrome-brand .brand-mark,
  .chrome.menu-closing .chrome-brand .brand-mark,
  .chrome[data-tone="dark"].menu-open .chrome-brand .brand-mark,
  .chrome[data-tone="dark"].menu-closing .chrome-brand .brand-mark { background: var(--ink); }
  /* A scrolled (is-solid) bar is tighter (16px top pad); while the card is open, return to the
     resting padding so the persistent brand sits exactly on the card's top row — the 6px glide
     rides the bar's existing padding transition. */
  .chrome.menu-open, .chrome.menu-closing { padding-top: calc(env(safe-area-inset-top, 0px) + 22px); }
</style>

<script>
  import { horaForWarsaw } from "../islands/landing/lib/horaeCanonicae";
  import { dismissOverlayEntry, isOverlayEntry, pushOverlayEntry } from "../lib/overlayHistory";

  // Document-delegated so it binds once and survives ClientRouter DOM swaps.
  if (!(window as unknown as { __voctChrome?: boolean }).__voctChrome) {
    (window as unknown as { __voctChrome?: boolean }).__voctChrome = true;

    const chrome = () => document.getElementById("chrome");
    const toggle = () => document.getElementById("navToggle");
    const nave = () => document.getElementById("navMenu");

    const syncSolid = () => {
      const c = chrome();
      if (c) c.classList.toggle("is-solid", window.scrollY > window.innerHeight * 0.5);
    };
    // The overlay fades shut over ~0.24s (nave-menu.css) — one quiet breath, no reverse wipe.
    // `menu-closing` keeps it painted through the fade; the timer then drops both classes → hidden.
    const WIPE_MS = 260;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
    let closeTimer = 0;

    // The overlay is a modal surface: while it is open the page behind goes inert (focus,
    // assistive tech, clicks). The nave itself lives inside <header>, so it stays live.
    const setPageInert = (on: boolean) => {
      document.querySelectorAll("main, footer").forEach((el) => {
        if (on) el.setAttribute("inert", "");
        else el.removeAttribute("inert");
      });
    };

    const clearChosen = () => {
      const c = chrome();
      c?.querySelectorAll(".voice.is-chosen").forEach((v) => v.classList.remove("is-chosen"));
      c?.querySelector(".nave-list.is-committing")?.classList.remove("is-committing");
    };
    const finalizeClose = () => {
      window.clearTimeout(closeTimer);
      const c = chrome();
      c?.classList.remove("menu-open", "menu-closing");
      clearChosen();
      toggle()?.setAttribute("aria-expanded", "false");
      document.body.classList.remove("nav-open");
      setPageInert(false);
    };
    const openMenu = () => {
      window.clearTimeout(closeTimer);
      const c = chrome();
      if (!c) return;
      // History integration: push a hash-marked entry (via ClientRouter's own navigate(), see
      // overlayHistory.ts) so the mobile back button / edge-swipe dismisses the "Antyfona" card
      // with NO document swap. No #menu element exists (nothing scrolls); the hash is transient.
      pushOverlayEntry("navOpen", "menu");
      c.classList.remove("menu-closing");
      c.classList.add("menu-open");
      toggle()?.setAttribute("aria-expanded", "true");
      document.body.classList.add("nav-open");
      setPageInert(true);
      // The antiphon names its hour: fill the foot line with the live canonical hour.
      const hora = horaForWarsaw(new Date());
      const name = document.getElementById("naveHoraName");
      const poem = document.getElementById("naveHoraPoem");
      if (name) name.textContent = hora.name;
      if (poem) poem.textContent = hora.poem;
      window.requestAnimationFrame(() => {
        document.getElementById("menuClose")?.focus({ preventScroll: true });
      });
    };
    // animated=true → play the quiet close fade (Zamknij / Escape). animated=false → snap shut
    // (navigation / reduced motion), where the page swap is the transition instead.
    const closeMenu = (animated = true) => {
      const c = chrome();
      if (!c || !c.classList.contains("menu-open")) return;
      // Hand focus back to the toggle if it currently sits inside the closing overlay.
      const n = nave();
      if (n && document.activeElement && n.contains(document.activeElement)) {
        toggle()?.focus({ preventScroll: true });
      }
      toggle()?.setAttribute("aria-expanded", "false");
      if (!animated || reduce.matches) {
        finalizeClose();
        return;
      }
      c.classList.add("menu-closing");
      window.clearTimeout(closeTimer);
      closeTimer = window.setTimeout(finalizeClose, WIPE_MS);
    };
    // Pure-dismiss closers (Zamknij, Escape) pop the entry pushed on open (→ popstate → animated
    // close) so no "swallowed" back press lingers; a genuine back press lands straight in the
    // popstate handler below. Navigation-adjacent closers (voices, the vault CTA) keep closeMenu.
    const dismissMenu = () => {
      const c = chrome();
      if (c?.classList.contains("menu-open")) dismissOverlayEntry("navOpen", () => closeMenu(true));
      else closeMenu(true);
    };

    window.addEventListener("scroll", syncSolid, { passive: true });
    // Re-evaluate tone after each navigation (new page starts scrolled to top).
    document.addEventListener("astro:page-load", syncSolid);
    // A navigation swap tears down the open overlay; drop the scroll lock with it (no wipe here).
    document.addEventListener("astro:before-swap", () => closeMenu(false));
    // Mobile back button / edge-swipe: the browser pops our pushed entry — fade the card shut.
    // closeMenu no-ops when the card isn't open, so ordinary page-to-page back is unaffected.
    // The isOverlayEntry gate skips the router's synthetic popstate right after the open-push
    // and a forward re-traversal onto a stranded entry — neither is a dismissal.
    window.addEventListener("popstate", () => {
      if (!isOverlayEntry("navOpen")) closeMenu(true);
    });

    // `chrome()` gates both handlers: after a ClientRouter swap onto the landing this script is
    // still live, but the landing's React StickyHeader (no #chrome id) owns its own menu there.
    document.addEventListener("click", (e) => {
      const t = e.target as Element | null;
      if (!t || !chrome()) return;
      if (t.closest("#navToggle")) {
        openMenu();
        return;
      }
      if (t.closest("#menuClose")) {
        dismissMenu();
        return;
      }
      const voice = t.closest(".nave .voice");
      if (voice) {
        // Tapping the page you're already on triggers no swap, so leaving the card open would
        // hang it — just close instead.
        if (voice.getAttribute("aria-current") === "page") {
          closeMenu(false);
          return;
        }
        // A voice is a page. Cross-page voices do NOT snap the card shut: leave it open so the
        // OUTGOING snapshot captures the parchment card, and let the page transition dissolve it
        // into the destination as one motion. `before-swap` tears the card down AFTER that
        // snapshot is taken. Mark the chosen voice so its rubric holds into the fade instead of
        // releasing with :active on touch-up.
        voice.classList.add("is-chosen");
        voice.closest(".nave-list")?.classList.add("is-committing");
        return;
      }
      // The Wesprzyj CTA (→ vault) or any other card link closes immediately (no page swap).
      if (t.closest(".nave a")) closeMenu(false);
    });
    document.addEventListener("keydown", (e) => {
      const c = chrome();
      if (!c) return;
      if (e.key === "Escape") {
        dismissMenu();
        return;
      }
      // Focus trap: while the overlay is open, Tab cycles inside it.
      if (e.key !== "Tab" || !c.classList.contains("menu-open") || c.classList.contains("menu-closing")) return;
      const n = nave();
      if (!n) return;
      const targets = Array.from(n.querySelectorAll<HTMLElement>("a[href], button:not([disabled])"));
      if (!targets.length) return;
      const first = targets[0];
      const last = targets[targets.length - 1];
      const active = document.activeElement as HTMLElement | null;
      if (e.shiftKey && (!active || !n.contains(active) || active === first)) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && (!active || !n.contains(active) || active === last)) {
        e.preventDefault();
        first.focus();
      }
    });
  }
</script>
