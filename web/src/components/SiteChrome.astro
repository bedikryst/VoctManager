---
/**
 * @file SiteChrome.astro
 * @description Shared marketing navigation (header). Lifted from MarketingChrome.tsx +
 *  the chrome CSS the SPA duplicated in every page stylesheet — now scoped once here.
 *  The scroll/menu behavior is a tiny document-delegated script (no per-element rebinding),
 *  so it survives ClientRouter swaps without leaking listeners.
 * @architecture Astro islands 2026
 * @module components/SiteChrome
 */
interface Props {
  /** Path of the current page so the matching nav link gets aria-current. */
  current?: string;
  /** "dark" pages (koncerty) get a night solid header + an is-light state over paper sections. */
  tone?: "light" | "dark";
}
const { current, tone = "light" } = Astro.props;

const links = [
  { href: "/o-nas", label: "O nas" },
  { href: "/koncerty", label: "Koncerty" },
  { href: "/kontakt", label: "Kontakt" },
] as const;
---

<header class="chrome" id="chrome" data-tone={tone} aria-label="Nawigacja">
  {/* view-transition-name: voct-brand → the brand mark becomes a shared element
      across navigations, morphing smoothly between pages instead of cross-fading
      with the page root. The landing StickyHeader carries the same name. */}
  <a class="chrome-brand" href="/" aria-label="VoctEnsemble — strona główna" style="view-transition-name: voct-brand">
    <span class="brand-mark" aria-hidden="true"></span>
    <span>VoctEnsemble</span>
  </a>

  <nav class="chrome-nav" aria-label="Nawigacja główna">
    {
      links.map((l) => (
        <a href={l.href} aria-current={current === l.href ? "page" : undefined}>
          {l.label}
        </a>
      ))
    }
    <a class="nav-support" href="/?donate" data-vault-open="100">Wesprzyj</a>
  </nav>

  <button
    class="nav-toggle"
    id="navToggle"
    type="button"
    aria-expanded="false"
    aria-controls="navMenu"
    aria-label="Menu"></button>

  {/* "Antyfona" — the shared mobile overlay (nave-menu.css). Self-contained: its own brand +
      close, since .chrome.menu-open hides the bar's brand/toggle. Each link carries its
      destination's Latin incipit, so the menu reads as the site's antiphon. */}
  <nav class="nave" id="navMenu" aria-label="Nawigacja główna">
    <div class="nave-veil"></div>
    <div class="nave-seam" aria-hidden="true"></div>
    <div class="nave-spot" aria-hidden="true"></div>

    <div class="nave-inner">
      <div class="nave-top">
        <a class="nave-brand" href="/" aria-label="VoctEnsemble — strona główna">
          <span class="nave-brand-mark" aria-hidden="true"></span>
          <span>VoctEnsemble</span>
        </a>
        <button class="nave-close" id="menuClose" type="button" aria-label="Zamknij menu">Zamknij</button>
      </div>

      <div class="nave-list">
        <a class="voice" href="/" aria-current={current === "/" ? "page" : undefined}>
          <span class="voice-lat">Introitus</span>
          <span class="voice-pl">Główna</span>
        </a>
        <a class="voice" href="/o-nas" aria-current={current === "/o-nas" ? "page" : undefined}>
          <span class="voice-lat">De nobis</span>
          <span class="voice-pl">O nas</span>
        </a>
        <a class="voice" href="/koncerty" aria-current={current === "/koncerty" ? "page" : undefined}>
          <span class="voice-lat">Via</span>
          <span class="voice-pl">Koncerty</span>
        </a>
        <a class="voice" href="/kontakt" aria-current={current === "/kontakt" ? "page" : undefined}>
          <span class="voice-lat">Scribe nobis</span>
          <span class="voice-pl">Kontakt</span>
        </a>
      </div>

      <div class="nave-foot">
        <a class="nave-cta" href="/?donate" data-vault-open="100">Wesprzyj <em>· Sustinete nos</em></a>
        <span class="nave-colophon">
          <span class="nave-colophon-mark" aria-hidden="true"></span>
          <em>Concerts Spirituels</em> · MMXXIV
        </span>
      </div>
    </div>
  </nav>
</header>

<style>
  .chrome { position: fixed; inset: 0 0 auto 0; z-index: 50; display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: calc(env(safe-area-inset-top, 0px) + 22px) max(28px, 5vw); color: var(--paper); background: transparent; border-bottom: 1px solid transparent; transition: color .5s var(--ease), background-color .5s var(--ease), border-color .5s var(--ease), padding .5s var(--ease), backdrop-filter .5s var(--ease); }
  .chrome::before { content: ""; position: absolute; inset: 0; z-index: -1; pointer-events: none; background: linear-gradient(180deg, rgba(8,8,7,.5) 0%, rgba(8,8,7,0) 100%); opacity: 1; transition: opacity .5s var(--ease); }
  .chrome.is-solid { background-color: rgba(244, 241, 233, 0.82); backdrop-filter: blur(20px) saturate(1.5); -webkit-backdrop-filter: blur(20px) saturate(1.5); border-bottom-color: rgba(22, 21, 20, 0.08); color: var(--ink); padding-top: calc(env(safe-area-inset-top, 0px) + 16px); padding-bottom: 14px; }
  .chrome.is-solid::before { opacity: 0; }

  .chrome-brand { display: inline-flex; align-items: center; gap: 12px; font-family: var(--serif); font-size: 21px; font-weight: 300; letter-spacing: .03em; color: inherit; }
  .chrome-brand .brand-mark { width: 17px; height: 40px; flex-shrink: 0; background: var(--candle); -webkit-mask: url(/logo-mark.png) center / contain no-repeat; mask: url(/logo-mark.png) center / contain no-repeat; transition: background-color .5s var(--ease); }
  .chrome.is-solid .chrome-brand .brand-mark { background: var(--ink); }

  .chrome-nav { display: flex; align-items: center; gap: clamp(16px, 2.4vw, 34px); }
  .chrome-nav a { font-family: var(--mono); font-size: 10.5px; letter-spacing: .2em; text-transform: uppercase; color: inherit; opacity: .82; position: relative; padding-bottom: 3px; transition: opacity .35s var(--ease); }
  .chrome-nav a::after { content: ""; position: absolute; left: 0; bottom: 0; width: 100%; height: 1px; background: currentColor; transform: scaleX(0); transform-origin: left; transition: transform .4s var(--ease); }
  .chrome-nav a:hover { opacity: 1; }
  .chrome-nav a:hover::after, .chrome-nav a[aria-current="page"]::after { transform: scaleX(1); }
  .chrome-nav a[aria-current="page"] { opacity: 1; color: var(--candle); }
  .chrome-nav .nav-support { color: var(--candle); opacity: 1; }

  /* Mobile menu */
  .nav-toggle { display: none; position: relative; width: 26px; height: 14px; border: 0; background: transparent; color: inherit; cursor: pointer; padding: 0; }
  .nav-toggle::before, .nav-toggle::after { content: ""; position: absolute; right: 0; height: 1px; background: currentColor; transition: width .35s var(--ease); }
  .nav-toggle::before { top: 4px; width: 26px; }
  .nav-toggle::after { top: 10px; width: 15px; }
  .nav-toggle:hover::after { width: 26px; }

  /* Bar clears when the "Antyfona" overlay (nave-menu.css) opens — it carries its own brand + close.
     Fast fade-out (.12s) so it is gone before the overlay's clip reveals the nave brand in the same
     spot — the mark reads as continuous, not a teleport. The brand eases back in on close. */
  .chrome-brand, .nav-toggle { transition: opacity .3s var(--ease); }
  .chrome.menu-open .chrome-brand, .chrome.menu-open .nav-toggle,
  .chrome.menu-closing .chrome-brand, .chrome.menu-closing .nav-toggle { opacity: 0; pointer-events: none; transition: opacity .12s var(--ease); }

  /* 759.98 / 760 boundary matches nave-menu.css so no fractional viewport falls between
     "hamburger shown" and "overlay available". */
  @media (max-width: 759.98px) {
    .chrome-nav { display: none; }
    .nav-toggle { display: inline-flex; }
  }

  /* ── Dark-tone pages (koncerty) ─────────────────────────────────────────
     Solid header is night (not paper); when a light section scrolls under it,
     the page toggles .is-light to flip to the paper treatment. */
  .chrome[data-tone="dark"].is-solid {
    background-color: rgba(16, 15, 13, 0.72);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    border-bottom-color: rgba(244, 241, 233, 0.12);
    color: var(--paper);
  }
  .chrome[data-tone="dark"].is-solid .chrome-brand .brand-mark { background: var(--candle); }

  .chrome[data-tone="dark"].is-light {
    background-color: rgba(244, 241, 233, 0.82);
    backdrop-filter: blur(20px) saturate(1.1);
    -webkit-backdrop-filter: blur(20px) saturate(1.1);
    border-bottom-color: rgba(22, 21, 20, 0.1);
    color: var(--ink);
  }
  .chrome[data-tone="dark"].is-light::before { opacity: 0; }
  .chrome[data-tone="dark"].is-light .chrome-brand .brand-mark { background: var(--ink); }
</style>

<script>
  // Document-delegated so it binds once and survives ClientRouter DOM swaps.
  if (!(window as unknown as { __voctChrome?: boolean }).__voctChrome) {
    (window as unknown as { __voctChrome?: boolean }).__voctChrome = true;

    const chrome = () => document.getElementById("chrome");
    const toggle = () => document.getElementById("navToggle");

    const syncSolid = () => {
      const c = chrome();
      if (c) c.classList.toggle("is-solid", window.scrollY > window.innerHeight * 0.5);
    };
    // The overlay wipes shut over ~0.55s (nave-menu.css). `menu-closing` keeps it painted and
    // drives the light-shaft erase; when the timer fires we drop both classes → hidden.
    const WIPE_MS = 580;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
    let closeTimer = 0;

    const finalizeClose = () => {
      window.clearTimeout(closeTimer);
      const c = chrome();
      c?.classList.remove("menu-open", "menu-closing");
      toggle()?.setAttribute("aria-expanded", "false");
      document.body.classList.remove("nav-open");
    };
    const openMenu = () => {
      window.clearTimeout(closeTimer);
      const c = chrome();
      c?.classList.remove("menu-closing");
      c?.classList.add("menu-open");
      toggle()?.setAttribute("aria-expanded", "true");
      document.body.classList.add("nav-open");
    };
    // animated=true → play the light-shaft wipe (Zamknij / Escape). animated=false → snap shut
    // (navigation / reduced motion), where the page swap is the transition instead.
    const closeMenu = (animated = true) => {
      const c = chrome();
      if (!c || !c.classList.contains("menu-open")) return;
      toggle()?.setAttribute("aria-expanded", "false");
      if (!animated || reduce.matches) {
        finalizeClose();
        return;
      }
      c.classList.add("menu-closing");
      window.clearTimeout(closeTimer);
      closeTimer = window.setTimeout(finalizeClose, WIPE_MS);
    };

    window.addEventListener("scroll", syncSolid, { passive: true });
    // Re-evaluate tone after each navigation (new page starts scrolled to top).
    document.addEventListener("astro:page-load", syncSolid);
    // A navigation swap tears down the open overlay; drop the scroll lock with it (no wipe here).
    document.addEventListener("astro:before-swap", () => closeMenu(false));

    document.addEventListener("click", (e) => {
      const t = e.target as Element | null;
      if (!t) return;
      if (t.closest("#navToggle")) openMenu();
      else if (t.closest("#menuClose")) closeMenu(true);
      else if (t.closest(".nave a")) closeMenu(false);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeMenu(true);
    });
  }
</script>
