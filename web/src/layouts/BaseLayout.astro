---
/**
 * @file BaseLayout.astro
 * @description Document shell for every public page. Owns <head> (per-page SEO/OG/canonical),
 *  global styles, native cross-document transitions (<ClientRouter />), and the Lenis
 *  smooth-scroll lifecycle (fine-pointer + motion-allowed only, re-anchored on navigation).
 * @architecture Astro islands 2026
 * @module layouts/BaseLayout
 */
import { ClientRouter } from "astro:transitions";
import { LOCALE_META, LOCALES, SITE, type Locale } from "../i18n/config";
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/cursor.css";
import "../styles/transitions.css";
import "../styles/nave-menu.css";
import "../styles/registrum.css";
import { ScrollTopButton } from "../islands/landing/ScrollTopButton";
import { SiteCursor } from "../islands/landing/SiteCursor";

interface Props {
  title: string;
  description: string;
  /** Absolute path of this page, e.g. "/kontakt" — drives canonical + og:url. */
  path: string;
  /** OG/Twitter share image (absolute path under the build root). Required — the old
      default pointed at /photos/…, a directory that does not exist in public/, so any
      page relying on it shipped a 404 og:image. Every page now passes a real image. */
  image: string;
  /** Optional class on <body> for page-level theming hooks. */
  bodyClass?: string;
  /**
   * Enables the global one-shot reveal controller (adds `reveal-ready`, IO toggles `.is-in`).
   * The landing opts OUT (`false`) — it ships its own reveal system (`.is-visible`/`.is-settled`)
   * scoped to its unlayered stylesheet, which the global `.is-in` rules would otherwise clobber.
   * Parallax stays active regardless (same `data-parallax` contract). Subpages keep the default.
   */
  reveal?: boolean;
  /** Page locale — drives `<html lang>` and og:locale. Defaults to Polish (the un-prefixed site). */
  lang?: Locale;
  /** hreflang alternates for a translated page (absolute URLs incl. x-default). Empty on
      Polish-only pages, where no alternate graph is emitted. See i18n/config.hreflangAlternates. */
  alternates?: { hreflang: string; href: string }[];
}

const {
  title,
  description,
  path,
  image,
  bodyClass = "",
  reveal = true,
  lang = "pl",
  alternates = [],
} = Astro.props;

const canonical = new URL(path, SITE).href;
const ogImage = new URL(image, SITE).href;
const ogLocale = LOCALE_META[lang].ogLocale;
// og:locale:alternate advertises the OTHER locales this same page exists in — only meaningful
// when the page is actually translated (it carries an hreflang graph).
const ogLocaleAlternates =
  alternates.length > 0
    ? LOCALES.filter((l) => l !== lang).map((l) => LOCALE_META[l].ogLocale)
    : [];
---

<!doctype html>
<html lang={LOCALE_META[lang].htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/logo_icon.png" />
    <link rel="apple-touch-icon" href="/logo_icon.png" />
    <meta name="theme-color" content="#100f0d" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {/* hreflang graph — emitted only on translated pages (i18n/config.hreflangAlternates returns
        [] for Polish-only pages). x-default points at the Polish original. */}
    {
      alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
      ))
    }

    <!-- Self-hosted critical fonts — preloaded, GDPR-safe. The latin-ext subsets are
         preloaded FIRST: this is a Polish-language site, so the diacritics (ą ć ę ł ń ó ś ż)
         that live in latin-ext appear in every headline — without these preloads the hero's
         "ł" in "głos" arrived by late discovery and repainted after first render. -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/CormorantGaramond-Variable.latin-ext.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/CormorantGaramond-Variable.latin.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Inter-Variable.latin-ext.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Inter-Variable.latin.woff2"
      crossorigin
    />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VoctEnsemble" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlternates.map((loc) => <meta property="og:locale:alternate" content={loc} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Plausible Analytics — cookieless, EU-hosted (see /polityka-prywatnosci). The
         `tagged-events` variant reports the `plausible-event-name=…` classes already wired
         on CTAs/gate/vault. Auto-tracks pushState, so ClientRouter swaps count as pageviews.
         Production only: in dev the data would be localhost noise. -->
    {
      import.meta.env.PROD && (
        <script
          is:inline
          defer
          data-domain="voctensemble.com"
          src="https://plausible.io/js/script.tagged-events.js"
        />
      )
    }

    <!-- Native cross-page transitions (View Transition API). -->
    <ClientRouter />

    {/* Apply reveal hidden-state before first paint (JS + motion only) → no flash-then-hide.
        Skipped when reveal={false} (landing) so the global `.is-in` controller stays dormant.
        `data-astro-rerun` re-executes this on every ClientRouter swap, otherwise navigating
        away from the landing (where reveal-ready is intentionally NOT set) into a subpage
        would arrive with the class missing → setupReveals would early-return and the hero
        would not animate (the "no reveal on subpages" bug). */}
    {
      reveal && (
        <script is:inline data-astro-rerun>
          if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
            document.documentElement.classList.add("reveal-ready");
          }
        </script>
      )
    }
    {/* Landing opts out of the reveal pipeline — strip the class on swap into "/" so the
        landing's own .is-visible/.is-settled system isn't fighting the global :is-in rules. */}
    {
      !reveal && (
        <script is:inline data-astro-rerun>
          document.documentElement.classList.remove("reveal-ready");
        </script>
      )
    }

    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <slot />
    <SiteCursor client:load transition:persist="site-cursor" />
    <ScrollTopButton client:idle transition:persist="scroll-top" />

    <script>
      // Lenis smooth scroll — only on fine pointers with motion allowed.
      // Resilient to ClientRouter navigations: one RAF loop, instance recreated
      // and scroll re-anchored on swap.
      import Lenis from "lenis";

      const fine = window.matchMedia("(pointer: fine) and (hover: hover)").matches;
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (fine && !reduce) {
        // Awwwards-grade cinematic feel without lag:
        //   • lerp 0.085 (≈10% slower than default 0.1) — the sacred tone reads as "deliberate",
        //     but stays well above the 0.05 threshold where users start perceiving lag.
        //   • duration 1.6s for programmatic scrollTo (vs default 1.2) — when an anchor jumps,
        //     it should travel like a slow camera dolly, not a cut.
        //   • easing: expo-out — same family the section-glow + manifest transitions already use,
        //     so wheel-driven scroll, anchor jumps, and reveal kinematics share one ease.
        //   • wheelMultiplier 0.9 — slightly tames over-eager trackpads on macOS without numbing
        //     ordinary mouse wheels.
        // NB: this whole block is gated behind `(pointer: fine) and (hover: hover)`, so Lenis
        // never runs on touch — mobile keeps fully native momentum scroll. No touch-tuning here
        // on purpose; any `touch*` option would be dead config.
        let lenis = new Lenis({
          lerp: 0.085,
          duration: 1.6,
          easing: (t: number) => (t === 1 ? 1 : 1 - Math.pow(2, -10 * t)),
          wheelMultiplier: 0.9,
          smoothWheel: true,
        });
        // Expose the shared instance so page scripts (e.g. landing anchor smooth-scroll)
        // route through it instead of spawning a second, fighting RAF loop.
        (window as unknown as { __lenis?: Lenis }).__lenis = lenis;
        const raf = (time: number) => {
          lenis.raf(time);
          requestAnimationFrame(raf);
        };
        requestAnimationFrame(raf);

        // Astro (history.scrollRestoration = "manual") has ALREADY applied the correct scroll
        // target by the time astro:after-swap fires — 0 for forward navigations, the saved
        // position for back/forward history traversal. Sync Lenis's virtual position to whatever
        // the document scroll now is, rather than forcing the top: forcing 0 discarded the
        // restored position and made "back" jump to the top (the reported "przeskakiwanie").
        document.addEventListener("astro:after-swap", () => {
          lenis.scrollTo(window.scrollY, { immediate: true, force: true });
        });
      }

      // Hide the native cursor for the duration of a view-transition swap. The pseudo-
      // element snapshot layer that View Transitions renders does NOT inherit the
      // page's `cursor: none` from `.has-custom-cursor`, so without this the system
      // pointer flashes back during the crossfade. Setting `cursor: none` inline on the
      // html element applies to the transition overlay too (it's part of the same
      // document root). Skip on touch / reduced-motion (custom cursor isn't enabled there).
      const cursorFine = window.matchMedia("(pointer: fine) and (hover: hover)").matches;
      const cursorReduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (cursorFine && !cursorReduce) {
        document.addEventListener("astro:before-preparation", () => {
          if (document.body.classList.contains("has-custom-cursor")) {
            document.documentElement.style.cursor = "none";
          }
        });
        document.addEventListener("astro:after-swap", () => {
          document.documentElement.style.cursor = "";
        });
      }

      // Navigation composure — the incoming page must arrive ALREADY composed, so the page
      // transition (transitions.css) reveals a finished hero instead of one that then
      // re-animates (the old "text → blank → text" flash). This fires inside the swap, BEFORE
      // the browser snapshots the new page, so the above-the-fold reveals are captured settled.
      // `vt-nav` (base.css) strips their transition so they snap rather than animate; below-the-
      // fold reveals are left hidden and still animate on scroll. The landing opts out of the
      // global reveal system (no `reveal-ready`) and owns its own entrance, so skip it there.
      document.addEventListener("astro:after-swap", () => {
        const root = document.documentElement;
        if (!root.classList.contains("reveal-ready")) return;
        root.classList.add("vt-nav");
        const vh = window.innerHeight;
        document.querySelectorAll<HTMLElement>(".reveal:not(.is-in)").forEach((el) => {
          if (el.getBoundingClientRect().top < vh) el.classList.add("is-in");
        });
      });

      // One-shot reveal — animates once on enter, then persists. Re-scans after each
      // ClientRouter navigation (fresh DOM). Above-the-fold nodes intersect immediately.
      const setupReveals = () => {
        if (!document.documentElement.classList.contains("reveal-ready")) return;
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-in");
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.1 },
        );
        document.querySelectorAll(".reveal:not(.is-in)").forEach((el) => io.observe(el));
      };
      document.addEventListener("astro:page-load", () => {
        setupReveals();
        // Composure window over: re-enable reveal transitions so the below-the-fold reveals
        // animate on scroll again. The next navigation re-arms vt-nav from scratch.
        document.documentElement.classList.remove("vt-nav");
      });

      // Parallax — JS-driven (cross-browser; scroll-timeline CSS is still partial in FF/Safari).
      // One rAF-throttled scroll loop; layers refreshed per navigation. The image is taller than
      // its frame and centered, so the clamped drift never exposes an edge.
      let layers: HTMLElement[] = [];
      let pTicking = false;
      const applyParallax = () => {
        pTicking = false;
        const vh = window.innerHeight;
        for (const el of layers) {
          const frame = el.parentElement;
          if (!frame) continue;
          const r = frame.getBoundingClientRect();
          if (r.bottom < -200 || r.top > vh + 200) {
            // Off-screen: drop the transform so the layer un-promotes and frees its GPU
            // texture. Decisive on /koncerty, where six full-bleed blurred backdrops would
            // otherwise stay composited at once; re-set the next frame it re-enters the margin.
            if (el.style.transform) el.style.transform = "";
            continue;
          }
          const speed = parseFloat(el.dataset.parallax || "0.16") || 0.16;
          const scale = parseFloat(el.dataset.parallaxScale || "1") || 1;
          // Room to drift without exposing an edge: either the image is taller than its
          // frame, or an inset:0 layer is scaled up (e.g. blurred station backdrops).
          const cap =
            scale > 1
              ? ((frame.offsetHeight * (scale - 1)) / 2) * 0.85
              : Math.max(0, el.offsetHeight - frame.offsetHeight) / 2;
          const base = scale > 1 ? 0 : -cap; // scaled layers are centered; tall imgs top-aligned
          let drift = (r.top + r.height / 2 - vh / 2) * -speed;
          if (drift > cap) drift = cap;
          else if (drift < -cap) drift = -cap;
          const scalePart = scale !== 1 ? ` scale(${scale})` : "";
          el.style.transform = `translate3d(0, ${(base + drift).toFixed(1)}px, 0)${scalePart}`;
        }
      };
      const onParallax = () => {
        if (!pTicking) {
          pTicking = true;
          requestAnimationFrame(applyParallax);
        }
      };
      if (!reduce) {
        window.addEventListener("scroll", onParallax, { passive: true });
        window.addEventListener("resize", onParallax, { passive: true });
      }
      document.addEventListener("astro:page-load", () => {
        if (reduce) return;
        layers = [...document.querySelectorAll<HTMLElement>("[data-parallax]")];
        applyParallax();
      });
    </script>
  </body>
</html>
