# =========================
# SYSTEM & IDE (Globalne)
# =========================
.DS_Store
.idea/
.vscode/
!.vscode/extensions.json
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj
*.sln

# =========================
# ZMIENNE ŚRODOWISKOWE
# =========================
.env
backend/.env
frontend/.env
*.local

# =========================
# BACKEND (Django & Python)
# =========================
backend/venv/
backend/env/
backend/__pycache__/
backend/**/*.pyc
backend/db.sqlite3
*.sqlite3
backend/media/
!backend/media/.gitkeep
backend/static/
gunicorn.ctl

# =========================
# FRONTEND (React & Vite)
# =========================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.tsbuildinfo
frontend/.mypy_cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# --- Frontend Media Assets ---
frontend/public/**/*.jpg
frontend/public/**/*.jpeg
frontend/public/**/*.png
frontend/public/**/*.webp
frontend/public/**/*.mp4
frontend/public/**/*.mov
frontend/public/**/*.webm
frontend/public/**/*.mp3
frontend/public/samples/

# PWA app icons are essential, lightweight build assets (referenced by
# manifest.webmanifest + index.html) — they MUST ship in git, so re-include
# them despite the broad public/*.png media ignore above.
!frontend/public/icons/
!frontend/public/icons/*.png
voct_data/
backend/celerybeat-schedule

