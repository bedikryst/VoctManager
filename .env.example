# ==========================================
# VoctManager Backend Environment Variables
# Author: Krystian Bugalski
# Instructions: Copy this file to '.env' and replace the dummy values.
# ==========================================

# --- Core Django Settings ---
# Cryptographic signing key. KEEP THIS SECRET IN PRODUCTION!
SECRET_KEY=your-super-secret-django-key-replace-me-in-production

# Set to 'False' in production to disable debug pages and enforce security
DEBUG=True

# Comma-separated list of allowed hostnames (e.g., test.voctensemble.com,voctensemble.com)
ALLOWED_HOSTS=localhost,127.0.0.1,web

# --- PostgreSQL Database ---
# Credentials matching your docker-compose.yml postgres service
DB_NAME=voct_db
DB_USER=voct_user
DB_PASSWORD=voct_password
DB_HOST=db
DB_PORT=5432

# --- Redis & Celery ---
# Connection strings for the asynchronous task queue
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Security & CORS ---
# Comma-separated list of allowed frontend origins (no trailing slashes)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Business Logic ---
# Default password automatically assigned to newly created Artist profiles
DEFAULT_ARTIST_PASSWORD=Password123!

# --- Monitoring ---
# Sentry DSN (Leave empty in local dev, set actual URL in production)
SENTRY_DSN=

# --- Email (Anymail / Resend) ---
RESEND_API_KEY=re_123456789_dummy_key_replace_in_prod
DEFAULT_FROM_EMAIL=VoctManager <noreply@voctensemble.com>

# ==========================================
# GOOGLE CLOUD PLATFORM (Logistics & Maps)
# ==========================================
GOOGLE_MAPS_BACKEND_KEY=your-google-maps-backend-api-key-replace-me