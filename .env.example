# ==========================================
# VoctManager Backend Environment Variables
# Author: Krystian Bugalski
# Instructions: Copy this file to '.env' and replace the dummy values.
# ==========================================

# --- Core Django Settings ---
# Cryptographic signing key. KEEP THIS SECRET IN PRODUCTION!
SECRET_KEY=your-super-secret-django-key-replace-me-in-production

# Set to 'False' in production to disable debug pages and enforce security
DEBUG=True

# Comma-separated list of allowed hostnames.
ALLOWED_HOSTS=localhost,127.0.0.1,web,voctensemble.com,www.voctensemble.com,voctensemble.pl,www.voctensemble.pl,voctfoundation.pl,www.voctfoundation.pl,voctfoundation.com,www.voctfoundation.com,voctfoundation.org,www.voctfoundation.org

# --- PostgreSQL Database ---
# Credentials matching your docker-compose.yml postgres service
DB_NAME=voct_db
DB_USER=voct_user
DB_PASSWORD=voct_password
DB_HOST=db
DB_PORT=5432

# --- Redis & Celery ---
# Connection strings for the asynchronous task queue
REDIS_PASSWORD=voct_super_secret_redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0


# --- Security & CORS ---
# Comma-separated list of allowed frontend origins (no trailing slashes).
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173,https://voctensemble.com,https://www.voctensemble.com,https://voctensemble.pl,https://www.voctensemble.pl,https://voctfoundation.pl,https://www.voctfoundation.pl,https://voctfoundation.com,https://www.voctfoundation.com,https://voctfoundation.org,https://www.voctfoundation.org

# Leave empty for host-only cookies when the same deployment serves multiple domains.
CSRF_COOKIE_DOMAIN=localhost

# --- Business Logic ---
# Default password automatically assigned to newly created Artist profiles
DEFAULT_ARTIST_PASSWORD=Password123!

# --- Monitoring ---
# Sentry DSN (Leave empty in local dev, set actual URL in production)
SENTRY_DSN=

# --- Email (Anymail / Resend) ---
RESEND_API_KEY=re_123456789_dummy_key_replace_in_prod
DEFAULT_FROM_EMAIL=VoctManager <voctmanager@notifications.voctensemble.com>

# ==========================================
# GOOGLE CLOUD PLATFORM (Logistics & Maps)
# ==========================================
GOOGLE_MAPS_BACKEND_KEY=your-google-maps-backend-api-key-replace-me

FIREBASE_CREDENTIALS_PATH=./.secrets/firebase-credentials.json

VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_PUBLIC_KEY=your_vapid_public_key_here

# --- AXEPTA BNP PARIBAS ---

AXEPTA_MERCHANT_ID=
AXEPTA_MAC_KEY=
AXEPTA_SERVICE_ID=

AXEPTA_API_URL="https://api.sandbox.axepta.pl/v1"
AXEPTA_TOKEN=
AXEPTA_RETURN_URL="https://voctensemble.com/?donated=success"
AXEPTA_FAILURE_RETURN_URL="https://voctensemble.com/?donated=failure"

# --- API KEYS FOR PDF READING & GENERATION ---
ANTHROPIC_API_KEY=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YOUTUBE_API_KEY=
